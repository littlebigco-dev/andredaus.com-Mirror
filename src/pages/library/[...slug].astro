  .entry-body :global(td) { padding:.875rem 1.25rem;border-bottom:1px solid var(--border-light);color:var(--text-secondary);line-height:1.6;vertical-align:top }
  .entry-body :global(tbody tr:last-child td) { border-bottom:none }
