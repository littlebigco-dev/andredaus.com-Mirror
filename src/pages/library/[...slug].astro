  .concept-desc { font-size:13px;line-height:1.7;color:var(--text-secondary) }

  /* ── In Practice cards ─────────────────────────────────────────────────── */
  .wild-grid { display:flex;flex-direction:column;gap:.75rem;margin-top:1.25rem }
  .wild-card { display:flex;align-items:flex-start;gap:1rem;padding:1.25rem;background:var(--bg-card-alt);border:1px solid var(--border-light);border-radius:3px;text-decoration:none;color:inherit;transition:border-color .2s }
