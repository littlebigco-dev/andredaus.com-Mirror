  .wild-card__title { font-size:14px;font-weight:600;color:var(--text-primary);margin-bottom:.25rem;line-height:1.3;transition:color .2s }
  .wild-card:hover .wild-card__title { color:var(--gold-light) }
  .wild-card__note { font-size:12px;line-height:1.6;color:var(--text-secondary) }

  /* ── Sticky sidebar ────────────────────────────────────────────────────── */
  .entry-sidebar { position:sticky;top:calc(68px + 2rem);display:flex;flex-direction:column;gap:1.5rem }

  .toc { background:var(--bg-card-alt);border:1px solid var(--border-light);border-radius:3px;overflow:hidden }
  .toc__heading { font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);padding:1rem 1.25rem;border-bottom:1px solid var(--border-light) }
  .toc__list { display:flex;flex-direction:column;padding:.5rem 0 }

  .meta-card { background:var(--bg-card);border:1px solid var(--border-light);border-top:2px solid var(--gold-dim);border-radius:3px;overflow:hidden }
  .meta-row { display:flex;justify-content:space-between;align-items:baseline;gap:.75rem;padding:.875rem 1.25rem;border-bottom:1px solid var(--border-light);font-size:13px }
  .meta-row:last-child { border-bottom:none }
  .meta-key { font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-subtle);flex-shrink:0 }
  .meta-val { color:var(--text-secondary);text-align:right;line-height:1.4 }

  .sidebar-cta { background:var(--bg-card);border:1px solid var(--border-light);border-top:2px solid var(--gold-dim);border-radius:3px;padding:1.75rem;display:flex;flex-direction:column;gap:1rem }
  .sidebar-cta__label { font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold) }
  .sidebar-cta__heading { font-family:var(--serif);font-size:1.05rem;font-weight:400;line-height:1.35;color:var(--text-primary) }
  .sidebar-cta__body { font-size:13px;line-height:1.75;color:var(--text-secondary) }
  .sidebar-cta .btn { width:100%;justify-content:center }

  .share-label { font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--text-subtle) }
  .share-row { display:flex;gap:.75rem;align-items:center }
  .share-btn { width:44px;height:44px;background:var(--bg-card-alt);border:1px solid var(--border-light);border-radius:3px;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);cursor:pointer;transition:border-color .2s,color .2s;text-decoration:none }
  .share-btn:hover { border-color:var(--gold-dim);color:var(--gold) }

  @media (max-width:960px) { .entry-layout { grid-template-columns:1fr } .entry-sidebar { display:none } }

  /* ── Mobile CTA ────────────────────────────────────────────────────────── */
  .mobile-cta { display:none;background:var(--bg-card);border-top:1px solid var(--border-light);padding:1.25rem var(--gutter);position:sticky;bottom:0;z-index:50;gap:1rem;justify-content:center;flex-wrap:wrap }
  @media (max-width:960px) { .mobile-cta { display:flex } }

  /* ── Related entries grid ──────────────────────────────────────────────── */
  .related { background:var(--bg-surface);border-top:1px solid var(--border-light);padding-block:var(--section) }
  .related__heading { font-family:var(--serif);font-size:clamp(1.4rem,2.5vw,1.9rem);font-weight:400;color:var(--text-primary);margin-bottom:2rem }
  .related__grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem }
  .related-card { background:var(--bg-card-alt);border:1px solid var(--border-light);border-radius:3px;padding:1.75rem;display:flex;flex-direction:column;gap:.75rem;text-decoration:none;color:inherit;transition:border-color .2s,transform .2s }
  .related-card:hover { border-color:rgba(196,154,60,.25);transform:translateY(-2px) }
  .related-card__badge { font-family:var(--mono);font-size:9px;letter-spacing:.12em;text-transform:uppercase;background:var(--gold-trans);border:1px solid var(--border);padding:3px 8px;border-radius:2px;width:fit-content }
  .related-card__name { font-family:var(--serif);font-size:1.1rem;font-weight:400;line-height:1.25;color:var(--text-primary);transition:color .2s }
  .related-card:hover .related-card__name { color:var(--gold-light) }
  .related-card__def { font-size:13px;line-height:1.7;color:var(--text-secondary) }
  .related-card__read { font-family:var(--mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);display:inline-flex;align-items:center;gap:6px;margin-top:auto;padding-top:.75rem;transition:gap .2s }
  .related-card:hover .related-card__read { gap:12px }
  .related-card__read::after { content:'→' }
  @media (max-width:760px) { .related__grid { grid-template-columns:1fr } }

  /* ── CTA band ──────────────────────────────────────────────────────────── */
  .cta-band { background:var(--bg-elevated);border-top:1px solid var(--border);padding-block:5rem;text-align:center;position:relative;overflow:hidden }
  .cta-band::before { content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 50% 50%,rgba(196,154,60,.06),transparent 70%);pointer-events:none }
  .cta-band__inner { position:relative;z-index:1 }
  .cta-band__label { margin-bottom:1.5rem;justify-content:center }
  .cta-band__label::before { display:none }
  .cta-band__heading { font-family:var(--serif);font-size:clamp(1.9rem,3.5vw,3rem);font-weight:400;line-height:1.15;color:var(--text-primary);max-width:22ch;margin-inline:auto;margin-bottom:1.25rem }
  .cta-band__heading em { font-style:italic;color:var(--gold) }
  .cta-band__sub { font-size:15px;color:var(--text-secondary);max-width:46ch;margin-inline:auto;line-height:1.8;margin-bottom:2.5rem }
  .cta-band__actions { display:flex;gap:1rem;justify-content:center;flex-wrap:wrap }
</style>

