  .entry-body :global(td:first-child) { color:var(--text-primary);font-weight:500 }

  /* Horizontal rule */
  .entry-body :global(hr) { border:none;border-top:1px solid var(--border-light);margin-block:3rem }

  /* Note box — SO signature element (same as insight-box / assumption-box) */
  .entry-body :global(.note-box) {
    background: var(--navy);
    border: 1px solid rgba(196,154,60,.2);
    border-top: 3px solid var(--gold);
    border-radius: 3px;
    padding: 2rem;
    margin-block: 2.5rem;
