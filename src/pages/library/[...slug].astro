  .entry-body :global(.mechanism__example) { font-size:12px;line-height:1.6;color:var(--text-subtle);border-top:1px solid var(--border-light);padding-top:.75rem;margin-top:.25rem }
  @media (max-width:600px) { .entry-body :global(.mechanisms) { grid-template-columns:1fr } }

  /* ── Related concepts (rendered from frontmatter) ──────────────────────── */
  .related-concepts { margin-block: 1.5rem; }
  .concept-row {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
