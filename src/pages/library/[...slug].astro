  .entry-body :global(.note-box__body) { font-size:14px;line-height:1.8;color:var(--text-secondary) }

  /* Mechanisms grid — 3-col visual element for bias mechanisms */
  .entry-body :global(.mechanisms) {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1px;
    background: var(--border-light);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
    margin-block: 2rem;
  }
  .entry-body :global(.mechanism) { background:var(--bg-card-alt);padding:1.5rem;display:flex;flex-direction:column;gap:.75rem }
  .entry-body :global(.mechanism__n) { font-family:var(--serif);font-style:italic;font-size:2.5rem;color:var(--gold);line-height:1 }
  .entry-body :global(.mechanism__name) { font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold) }
