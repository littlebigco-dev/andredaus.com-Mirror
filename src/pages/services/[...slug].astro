---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('services');
  return entries
    .filter(e => e.id.startsWith('en/') && e.data.status === 'active')
    .map(entry => ({
      params: { slug: entry.id.replace(/^en\//, '').replace(/\.md$/, '') },
      props:  { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

// Related services — other active services, excluding this one, up to 3
const allServices = await getCollection('services');
const related = allServices
  .filter(e =>
    e.id.startsWith(isDE ? 'de/' : 'en/') &&
    e.data.status === 'active' &&
    e.id !== entry.id
  )
  .slice(0, 3);

function slugify(e: typeof related[number]) {
  return e.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

const {
  title,
  engagement_type,
  one_liner,
  description,
  format,
  duration,
  group_size,
  delivery,
  suitable_for,
  pull_quote,
  outcomes,
  for_profiles,
  not_for,
  og_title,
  og_image,
} = entry.data;

// Stats strip — only show rows that have values
const stats = [
  { label: isDE ? 'Format'        : 'Format',       value: format       },
  { label: isDE ? 'Dauer'         : 'Duration',      value: duration     },
  { label: isDE ? 'Teilnehmer'    : 'Participants',  value: group_size   },
  { label: isDE ? 'Durchführung'  : 'Delivery',      value: delivery     },
].filter(s => s.value);
---

<Base
  title={`${og_title ?? title} — André Daus`}
  description={description}
  ogImage={og_image}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ── BREADCRUMB ─────────────────────────────────────────────────────── -->
  <div class="breadcrumb">
    <div class="container">
      <nav class="breadcrumb__inner" aria-label="Breadcrumb">
        <a href={`${prefix}/`}        class="breadcrumb__link">
          {isDE ? 'Start' : 'Home'}
        </a>
        <span aria-hidden="true">/</span>
        <a href={`${prefix}/services`} class="breadcrumb__link">
          {isDE ? 'Leistungen' : 'Services'}
        </a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{title}</span>
      </nav>
    </div>
  </div>

  <!-- ── SERVICE HERO ───────────────────────────────────────────────────── -->
  <header class="service-hero" aria-labelledby="service-title">
    <div class="service-hero__grid" aria-hidden="true"></div>
    <div class="container">
      <div class="service-hero__inner">

        <!-- Content side -->
        <div class="service-hero__content">
          {engagement_type && (
            <span class="service-hero__type">{engagement_type}</span>
          )}
          <h1 class="service-hero__title" id="service-title">{title}</h1>
          {one_liner && (
            <p class="service-hero__oneliner">{one_liner}</p>
          )}
          {description && (
            <p class="service-hero__lede">{description}</p>
          )}
          <div class="service-hero__ctas">
            <a href={`${prefix}/contact`} class="btn btn--primary btn-arrow">
              {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
            </a>
            <a href={`${prefix}/services`} class="btn btn--outline">
              {isDE ? 'Alle Leistungen' : 'All services'}
            </a>
          </div>
        </div>

        <!-- Image side — placeholder until real photos are added -->
        <div class="service-hero__image" aria-hidden="true">
          <div class="img-placeholder">
            <span class="img-placeholder__icon">◎</span>
            <span class="img-placeholder__label">{title}</span>
          </div>
        </div>

        <!-- Stats strip — full width, below both columns -->
        {stats.length > 0 && (
          <div
            class="service-hero__stats"
            role="list"
            aria-label={isDE ? 'Leistungsdetails' : 'Service details'}
          >
            {stats.map(stat => (
              <div class="service-hero__stat" role="listitem">
                <span class="service-hero__stat-label">{stat.label}</span>
                <span class="service-hero__stat-value">{stat.value}</span>
              </div>
            ))}
            <div class="service-hero__stat" role="listitem">
              <span class="service-hero__stat-label">
                {isDE ? 'Sprache' : 'Language'}
              </span>
              <span class="service-hero__stat-value">
                {isDE ? 'Deutsch oder Englisch' : 'German or English'}
              </span>
            </div>
            <div class="service-hero__stat" role="listitem">
              <span class="service-hero__stat-label">
                {isDE ? 'Verfügbarkeit' : 'Availability'}
              </span>
              <span class="service-hero__stat-value">
                {isDE ? 'Auf Anfrage — Discovery Call zuerst' : 'By application — discovery call first'}
              </span>
            </div>
          </div>
        )}

      </div>
    </div>
  </header>

  <!-- ── BODY + SIDEBAR ─────────────────────────────────────────────────── -->
  <div class="container">
    <div class="service-body">

      <!-- ── Main article ── -->
      <article class="service-content" aria-label={isDE ? 'Leistungsdetails' : 'Service details'}>

        <!-- Prose body from markdown — problem description, what happens, etc. -->
        {/* Only show if there's actual markdown content */}
        <div class="prose-body fade-up">
          <Content />
        </div>

        <!-- Pull quote -->
        {pull_quote && (
          <blockquote class="pull-quote fade-up">
            <p>"{pull_quote}"</p>
          </blockquote>
        )}

        <!-- Outcomes — "What you leave with" -->
        {outcomes.length > 0 && (
          <section class="content-section fade-up" aria-labelledby="outcomes-heading">
            <span class="content-section__label">
              {isDE ? 'Ergebnisse' : 'Outcomes'}
            </span>
            <h2 class="content-section__heading" id="outcomes-heading">
              {isDE ? 'Was Sie mitnehmen' : 'What you leave with'}
            </h2>
            <p class="content-section__sub">
              {isDE ? 'Keine Deliverables. Fähigkeiten und Klarheit.' : 'Not deliverables. Capabilities and clarity.'}
            </p>
            <ul class="outcomes" aria-label={isDE ? 'Engagement-Ergebnisse' : 'Engagement outcomes'}>
              {outcomes.map(o => (
                <li class="outcome">
                  <span class="outcome__check" aria-hidden="true">✦</span>
                  <div class="outcome__text">
                    <strong>{o.name}</strong>
                    {o.description}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- Who it's for -->
        {(for_profiles.length > 0 || not_for) && (
          <section class="content-section fade-up" aria-labelledby="fit-heading">
            <span class="content-section__label">
              {isDE ? 'Passung' : 'Fit'}
            </span>
            <h2 class="content-section__heading" id="fit-heading">
              {isDE ? 'Das ist für Sie, wenn…' : 'This is for you if…'}
            </h2>
            <div class="for-grid">
              {for_profiles.map(p => (
                <div class="for-card">
                  <strong>{p.title}</strong>
                  {p.body}
                </div>
              ))}
              {not_for && (
                <div class="for-card for-card--not">
                  <strong>{isDE ? 'Das ist nicht für Sie, wenn…' : 'This is not for you if…'}</strong>
                  {not_for}
                </div>
              )}
            </div>
          </section>
        )}

      </article>

      <!-- ── Sidebar ── -->
      <aside
        class="service-body__sidebar"
        aria-label={isDE ? 'Leistungsdetails und Buchung' : 'Service details and booking'}
      >

        <!-- Engagement details card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__heading">
            {isDE ? 'Leistungsdetails' : 'Engagement details'}
          </h3>
          <dl class="sidebar-card__meta">
            <div class="sidebar-card__row">
              <dt class="sidebar-card__label">{isDE ? 'Format' : 'Format'}</dt>
              <dd class="sidebar-card__value">{format}</dd>
            </div>
            {duration && (
              <div class="sidebar-card__row">
                <dt class="sidebar-card__label">{isDE ? 'Dauer' : 'Duration'}</dt>
                <dd class="sidebar-card__value">{duration}</dd>
              </div>
            )}
            {group_size && (
              <div class="sidebar-card__row">
                <dt class="sidebar-card__label">{isDE ? 'Teilnehmer' : 'Participants'}</dt>
                <dd class="sidebar-card__value">{group_size}</dd>
              </div>
            )}
            {delivery && (
              <div class="sidebar-card__row">
                <dt class="sidebar-card__label">{isDE ? 'Durchführung' : 'Delivery'}</dt>
                <dd class="sidebar-card__value">{delivery}</dd>
              </div>
            )}
            <div class="sidebar-card__row">
              <dt class="sidebar-card__label">{isDE ? 'Sprache' : 'Language'}</dt>
              <dd class="sidebar-card__value">
                {isDE ? 'Deutsch oder Englisch' : 'German or English'}
              </dd>
            </div>
            <div class="sidebar-card__row">
              <dt class="sidebar-card__label">{isDE ? 'Verfügbarkeit' : 'Availability'}</dt>
              <dd class="sidebar-card__value">
                {isDE
                  ? 'Auf Anfrage — Discovery Call zuerst'
                  : 'By application — discovery call first'}
              </dd>
            </div>
          </dl>
        </div>

        <!-- CTA card -->
        <div class="sidebar-cta">
          <h3 class="sidebar-cta__heading">
            {isDE ? 'Starten Sie mit einem Discovery Call' : 'Start with a discovery call'}
          </h3>
          <p class="sidebar-cta__body">
            {isDE
              ? '30 Minuten. Ich decke die Annahme auf, die am dringendsten zu untersuchen ist — unabhängig davon, ob wir formal fortfahren.'
              : '30 minutes. I\'ll surface the assumption most worth examining first — regardless of whether we proceed to a formal engagement.'}
          </p>
          <a
            href={`${prefix}/contact`}
            class="btn btn--primary btn-arrow"
            style="width:100%;justify-content:center"
          >
            {isDE ? 'Call buchen' : 'Book a Call'}
          </a>
        </div>

      </aside>
    </div>
  </div>

  <!-- ── RELATED SERVICES ───────────────────────────────────────────────── -->
  {related.length > 0 && (
    <section class="related section" aria-labelledby="related-heading">
      <div class="container">
        <h2 class="related__heading" id="related-heading">
          {isDE ? 'Weitere Möglichkeiten zur Zusammenarbeit' : 'Other ways to work together'}
        </h2>
        <ul class="related__grid">
          {related.map(rel => (
            <li class="related-card fade-up">
              {rel.data.engagement_type && (
                <span class="related-card__type">{rel.data.engagement_type}</span>
              )}
              <h3 class="related-card__title">{rel.data.title}</h3>
              {rel.data.one_liner && (
                <p class="related-card__body">{rel.data.one_liner}</p>
              )}
              <a
                href={`${prefix}/services/${slugify(rel)}`}
                class="related-card__link"
                aria-label={isDE
                  ? `Details zu ${rel.data.title}`
                  : `View ${rel.data.title}`}
              >
                {isDE ? 'Leistung ansehen' : 'View service'}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ── CTA BAND ───────────────────────────────────────────────────────── -->
  <section class="cta-band" aria-labelledby="cta-heading">
    <div class="container cta-band__inner">
      <p class="label cta-band__label">
        {isDE ? 'Nächster Schritt' : 'Next step'}
      </p>
      <h2 class="cta-band__heading" id="cta-heading">
        {isDE
          ? <Fragment>Die richtige Frage ist schon <em>im Raum.</em></Fragment>
          : <Fragment>The right question is already <em>in the room.</em></Fragment>}
      </h2>
      <p class="cta-band__sub">
        {isDE
          ? 'Ein Discovery Call bringt sie ans Licht. 30 Minuten, keine Vorbereitung erforderlich.'
          : 'A discovery call surfaces it. 30 minutes, no preparation required.'}
      </p>
      <div class="cta-band__actions">
        <a href={`${prefix}/contact`}  class="btn btn--primary btn-arrow">
          {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
        </a>
        <a href={`${prefix}/services`} class="btn btn--outline">
          {isDE ? 'Alle Leistungen' : 'All services'}
        </a>
      </div>
    </div>
  </section>

</Base>

<script>
  const io = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    }),
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
</script>

<style>
  /* ── Breadcrumb ────────────────────────────────────────────────────────── */
  .breadcrumb {
    padding-top: 68px;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
  }
  .breadcrumb__inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-block: 0.875rem;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .breadcrumb__link {
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .breadcrumb__link:hover { color: var(--gold); }

  /* ── Service hero ──────────────────────────────────────────────────────── */
  .service-hero {
    background: linear-gradient(160deg, var(--bg-surface) 0%, var(--bg-base) 55%);
    position: relative;
    overflow: hidden;
  }
  .service-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 80% at 30% 50%, black, transparent);
    pointer-events: none;
  }
  .service-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }

  .service-hero__type {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 1.25rem;
    display: block;
  }

  .service-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .service-hero__oneliner {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    color: var(--gold-light);
    line-height: 1.5;
    margin-bottom: 1.75rem;
    max-width: 40ch;
  }

  .service-hero__lede {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 52ch;
    margin-bottom: 2.5rem;
  }

  .service-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Image column */
  .service-hero__image {
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 340px;
    background: var(--bg-elevated);
    border: 1px dashed rgba(196,154,60,0.2);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2.5rem;
    text-align: center;
  }
  .img-placeholder__icon {
    font-size: 2rem;
    opacity: 0.15;
    color: var(--gold);
  }
  .img-placeholder__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  /* Stats strip — spans both columns */
  .service-hero__stats {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: var(--border-light);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 1rem;
  }
  .service-hero__stat {
    background: var(--bg-card-alt);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .service-hero__stat-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .service-hero__stat-value {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
  }

  @media (max-width: 860px) {
    .service-hero__inner { grid-template-columns: 1fr; }
    .service-hero__image { display: none; }
    .service-hero__stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Body layout ───────────────────────────────────────────────────────── */
  .service-body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 5rem;
    align-items: start;
    padding-block: var(--section);
  }
  .service-body__sidebar {
    position: sticky;
    top: calc(68px + 2rem);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  @media (max-width: 960px) {
    .service-body { grid-template-columns: 1fr; }
    .service-body__sidebar { position: static; }
  }

  /* ── Article content ───────────────────────────────────────────────────── */
  .service-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Prose styles from markdown body */
  .prose-body :global(h2) {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    margin-bottom: 1rem;
    margin-top: 2.5rem;
  }
  .prose-body :global(h2:first-child) { margin-top: 0; }

  .prose-body :global(h3) {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    margin-top: 1.75rem;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-dim);
  }

  .prose-body :global(p) {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .prose-body :global(strong) { color: var(--text-primary); font-weight: 600; }

  /* Pull quote */
  .pull-quote {
    border-left: 2px solid var(--gold);
    padding: 1.5rem 2rem;
    background: rgba(196,154,60,0.06);
    border-radius: 0 3px 3px 0;
  }
  .pull-quote p {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--text-primary);
  }

  /* Content sections */
  .content-section { }

  .content-section__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-dim);
    display: block;
    margin-bottom: 1rem;
  }

  .content-section__heading {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .content-section__sub {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  /* Outcomes list */
  .outcomes {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .outcome {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.875rem 1rem;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    transition: border-color 0.2s;
  }
  .outcome:hover { border-color: rgba(196,154,60,0.25); }
  .outcome__check { color: var(--gold); font-size: 0.9rem; margin-top: 0.2rem; }
  .outcome__text { font-size: 14px; line-height: 1.7; color: var(--text-secondary); }
  .outcome__text strong {
    display: block;
    font-weight: 500;
    font-size: 15px;
    color: var(--text-primary);
    margin-bottom: 3px;
  }

  /* For-profiles grid */
  .for-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1.25rem;
  }
  .for-card {
    padding: 1.25rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-light);
    border-top: 2px solid var(--gold-dim);
    border-radius: 3px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .for-card strong {
    display: block;
    color: var(--text-primary);
    font-size: 15px;
    margin-bottom: 0.4rem;
  }
  .for-card--not {
    border-top-color: rgba(255,100,100,0.3);
    background: rgba(255,80,80,0.03);
  }
  .for-card--not strong { color: var(--text-muted); }
  @media (max-width: 600px) {
    .for-grid { grid-template-columns: 1fr; }
  }

  /* ── Sidebar ───────────────────────────────────────────────────────────── */
  .sidebar-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-top: 2px solid var(--gold-dim);
    padding: 1.75rem;
    border-radius: 3px;
  }
  .sidebar-card__heading {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 1.25rem;
  }
  .sidebar-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .sidebar-card__row {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid var(--border-light);
  }
  .sidebar-card__row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }
  .sidebar-card__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .sidebar-card__value {
