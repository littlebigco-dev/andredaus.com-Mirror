---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allEpisodes = await getCollection('podcast');
const episodes = allEpisodes
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.episode_number - a.data.episode_number);

const categories = ['All', ...Array.from(new Set(episodes.map(e => e.data.category))).sort()];

function slugify(entry: typeof episodes[number]) {
  return entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={isDE ? 'Podcast — André Daus' : 'Podcast — André Daus'}
  description={isDE
    ? 'Iconoclast Insights: Episoden zu Strategic Opposition, Entscheidungspsychologie und den Annahmen, die Strategie scheitern lassen.'
    : 'Iconoclast Insights: episodes on Strategic Opposition, decision psychology, and the assumptions that make strategy fail.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="coll-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container">
      <p class="label">{isDE ? 'Podcast' : 'Podcast'}</p>
      <h1 class="coll-hero__heading">
        {isDE
          ? <Fragment>Iconoclast <em>Insights</em></Fragment>
          : <Fragment>Iconoclast <em>Insights</em></Fragment>}
      </h1>
      <p class="coll-hero__sub">
        {isDE
          ? 'Strategic Opposition, Entscheidungspsychologie und die Annahmen, auf denen Organisationen aufgebaut sind. Ein Podcast für Führungskräfte, die anders denken wollen.'
          : 'Strategic Opposition, decision psychology, and the assumptions organisations are built on. A podcast for leaders who want to think differently.'}
      </p>
      <div class="podcast-platforms">
        <a href="https://open.spotify.com/show/placeholder" class="platform-link" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
          </svg>
          Spotify
        </a>
      </div>
    </div>
  </header>

  <!-- EPISODES -->
  <section class="section" aria-label={isDE ? 'Episoden' : 'Episodes'}>
    <div class="container">

      <!-- Category filter -->
      <div class="filter-bar" role="group" aria-label={isDE ? 'Nach Kategorie filtern' : 'Filter by category'}>
        {categories.map(cat => (
          <button
            class="filter-btn"
            data-category={cat}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat === 'All' ? (isDE ? 'Alle' : 'All') : cat}
          </button>
        ))}
      </div>

      {episodes.length === 0 ? (
        <p class="empty-state">{isDE ? 'Noch keine Episoden veröffentlicht.' : 'No episodes published yet.'}</p>
      ) : (
        <ul class="episodes-list" id="episodes-list">
          {episodes.map(entry => (
            <li class="episode-card fade-up" data-category={entry.data.category}>
              <a href={`${prefix}/podcast/${slugify(entry)}`} class="episode-card__link">
                <div class="episode-card__left">
                  <div class="episode-card__cover" aria-hidden="true">
                    <span class="episode-card__num">
                      {String(entry.data.episode_number).padStart(3, '0')}
                    </span>
                  </div>
                </div>
                <div class="episode-card__body">
                  <div class="episode-card__meta">
                    <span class="episode-cat">{entry.data.category}</span>
                    <time datetime={entry.data.date.toISOString()} class="episode-date">
                      {formatDate(entry.data.date)}
                    </time>
                  </div>
                  <h2 class="episode-card__title">{entry.data.title}</h2>
                  {entry.data.summary && (
                    <p class="episode-card__summary">{entry.data.summary}</p>
                  )}
                  <div class="episode-card__actions">
                    <span class="episode-card__read btn-arrow">{isDE ? 'Episode lesen' : 'Read episode'}</span>
                    {entry.data.spotify_url && (
                      <a
                        href={entry.data.spotify_url}
                        class="episode-card__spotify"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={isDE ? 'Auf Spotify anhören' : 'Listen on Spotify'}
                        onclick="event.stopPropagation()"
                      >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                        </svg>
                        {isDE ? 'Auf Spotify' : 'On Spotify'}
                      </a>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('.episode-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;
      btns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      cards.forEach(card => {
        card.style.display = cat === 'All' || card.dataset.category === cat ? '' : 'none';
      });
    });
  });
</script>

<style>
  .coll-hero {
    position: relative;
    padding: calc(68px + var(--section)) 0 var(--section);
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .coll-hero .label { margin-bottom: 1.25rem; }
  .coll-hero__heading {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }
  .coll-hero__heading em { font-style: italic; color: var(--gold); }
  .coll-hero__sub {
    max-width: 52ch;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    margin-bottom: 2rem;
  }

  .podcast-platforms {
    display: flex;
    gap: 1rem;
  }
  .platform-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: 8px 16px;
    border: 1px solid var(--border);
    border-radius: 2px;
    transition: all var(--transition-fast);
    text-decoration: none;
  }
  .platform-link:hover {
    color: var(--gold);
    border-color: var(--gold);
  }

  /* Filter */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }
  .filter-btn {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: transparent;
    color: var(--text-subtle);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-btn:hover,
  .filter-btn[aria-pressed="true"] {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-trans);
  }

  /* Episodes list */
  .episodes-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .episode-card {
    background: var(--bg-card);
    transition: background-color var(--transition-fast);
  }
  .episode-card:hover { background: var(--bg-elevated); }

  .episode-card__link {
    display: flex;
    gap: 2rem;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
  }

  .episode-card__left { flex-shrink: 0; }
  .episode-card__cover {
    width: 80px;
    height: 80px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .episode-card__num {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    color: var(--gold-dim);
    letter-spacing: 0.08em;
  }

  .episode-card__body { flex: 1; min-width: 0; }
  .episode-card__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .episode-cat {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .episode-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .episode-card__title {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }
  .episode-card__summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .episode-card__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .episode-card__read {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .episode-card__read::after { content: ' →'; }
  .episode-card__spotify {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .episode-card__spotify:hover { color: var(--gold); }

  .empty-state { color: var(--text-subtle); font-style: italic; padding: 3rem 0; }

  @media (max-width: 600px) {
    .episode-card__link { flex-direction: column; gap: 1rem; }
    .episode-card__cover { width: 60px; height: 60px; }
  }
</style>
