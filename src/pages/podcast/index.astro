---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allEpisodes = await getCollection('podcast');
const episodes = allEpisodes
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.episode_number - a.data.episode_number);

const episodeCount = episodes.length;
const featured     = episodes[0] ?? null;
const rest         = episodes.slice(1);

// Derive filter categories from the collection
const allCats = Array.from(new Set(episodes.map(e => e.data.category))).sort();

function slugify(e: typeof episodes[number]) {
  return e.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function fmtDuration(d?: string): string {
  if (!d) return '';
  const parts = d.split(':').map(Number);
  if (parts.length === 3) {
    const m = parts[0] * 60 + parts[1];
    return `${m}m`;
  }
  return d;
}

// Artwork lookup
const allArtwork = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/media/thumbnails/*.{jpg,jpeg,webp,png}',
  { eager: true }
);

function getArtwork(ep: typeof episodes[number]): ImageMetadata | null {
  const id = ep.data.episode_id
    ?? ep.data.spotify_url?.match(/spotify\.com\/(?:embed\/)?[a-z]+\/([a-zA-Z0-9]+)/)?.[1]
    ?? null;
  if (!id) return null;
  const found = Object.entries(allArtwork).find(([path]) =>
    path.split('/').pop()?.replace(/\.[^.]+$/, '') === id
  );
  return found?.[1]?.default ?? null;
}

// Show artwork = first episode's artwork, or null
const showArtwork = featured ? getArtwork(featured) : null;

// Spotify icon path
const spPath = 'M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z';
---

<Base
  title={isDE ? 'Iconoclast Insights — Podcast · André Daus' : 'Iconoclast Insights — Podcast · André Daus'}
  description={isDE
    ? 'Solo-Kommentare zu Denkfehlern, bequemen Annahmen und dem Konsens, der Entscheidungen still ruiniert.'
    : 'Solo commentary on the thinking errors, lazy consensus, and comfortable assumptions that quietly run business decisions.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ── SHOW HERO ──────────────────────────────────────────────────────── -->
  <header class="show-hero" aria-labelledby="show-title">
    <div class="show-hero__grid" aria-hidden="true"></div>
    <div class="container">
      <div class="show-hero__inner">

        <!-- Left: show identity -->
        <div class="show-hero__content">
          <p class="label show-hero__label">{isDE ? 'Podcast' : 'Podcast'}</p>
          <h1 class="show-hero__title" id="show-title">
            Iconoclast <em>Insights</em>
          </h1>
          <p class="show-hero__desc">
            {isDE
              ? 'Solo-Kommentare zu Denkfehlern, bequemem Konsens und den Annahmen, die Entscheidungen still ruinieren. Neue Episode, wenn es etwas zu sagen gibt.'
              : 'Solo commentary on the thinking errors, lazy consensus, and comfortable assumptions that quietly run business decisions. New episode when there\'s something worth saying.'}
          </p>

          <!-- Platform links -->
          <nav class="platforms" aria-label={isDE ? 'Auf Plattformen anhören' : 'Listen on platforms'}>
            <a href="https://www.youtube.com/@andredaus" class="platform-link" target="_blank" rel="noopener noreferrer">
              <svg class="platform-link__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
              </svg>
              YouTube
              <span class="platform-link__sub">{isDE ? 'Video + Audio' : 'Video + Audio'}</span>
            </a>
            <a href="https://open.spotify.com/show/36YRWk7nrI6V8w9lMncynG" class="platform-link" target="_blank" rel="noopener noreferrer">
              <svg class="platform-link__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={spPath}/>
              </svg>
              Spotify
              <span class="platform-link__sub">{isDE ? 'Audio' : 'Audio'}</span>
            </a>
            <a href="https://podcasts.apple.com/podcast/iconoclast-insights/id0000000" class="platform-link" target="_blank" rel="noopener noreferrer">
              <svg class="platform-link__icon" xmlns="http://www.w3.org/2000/svg" xml:space="preserve" viewBox="0 0 300 300" aria-hidden="true">
                <linearGradient id="apple-grad-idx" x1="150" x2="150" y1="0" y2="300" gradientUnits="userSpaceOnUse">
                  <stop offset="0" style="stop-color:#f452ff"/>
                  <stop offset="1" style="stop-color:#832bc1"/>
                </linearGradient>
                <path fill="url(#apple-grad-idx)" fill-rule="evenodd" d="M294.1 260c-2.9 7.4-9.6 17.8-19.2 25.2-5.5 4.2-12.1 8.3-21.1 11-9.6 2.9-21.5 3.8-36.3 3.8h-135c-14.8 0-26.6-1-36.3-3.8-9-2.7-15.6-6.7-21.1-11-9.5-7.3-16.3-17.8-19.2-25.2C.1 245.1 0 228.2 0 217.5v-135C0 71.8.1 54.9 5.9 40c2.9-7.4 9.6-17.8 19.2-25.2 5.5-4.2 12.1-8.3 21.1-11C55.9 1 67.7 0 82.5 0h135c14.8 0 26.6 1 36.3 3.8 9 2.7 15.6 6.7 21.1 11 9.5 7.3 16.3 17.8 19.2 25.2 5.9 14.9 5.9 31.9 5.9 42.5v135c0 10.7-.1 27.6-5.9 42.5" clip-rule="evenodd"/>
                <g fill="#fff">
                  <path d="M175.7 181.1c-.4-3.6-1.6-6.2-4-8.6-4.5-4.7-12.4-7.8-21.7-7.8s-17.2 3-21.7 7.8c-2.3 2.5-3.6 5-4 8.6-.8 7-.3 13 .5 22.7.8 9.2 2.3 21.5 4.2 33.9 1.4 8.9 2.5 13.7 3.5 17.1 1.7 5.6 7.8 10.4 17.5 10.4s15.9-4.9 17.5-10.4c1-3.4 2.1-8.2 3.5-17.1 1.9-12.5 3.4-24.7 4.2-33.9.9-9.7 1.3-15.7.5-22.7M174.6 130.1c0 13.6-11 24.6-24.6 24.6s-24.6-11-24.6-24.6 11-24.6 24.6-24.6 24.6 11.1 24.6 24.6"/>
                  <path d="M149.7 33.2C92.3 33.4 45.3 80 44.5 137.4c-.6 46.5 29.1 86.3 70.6 100.9 1 .4 2-.5 1.9-1.5-.5-3.6-1.1-7.2-1.5-10.8-.2-1.3-1-2.3-2.1-2.9-32.8-14.3-55.7-47.2-55.3-85.3.5-50 41.3-90.7 91.2-91.1 51.1-.4 92.8 41 92.8 92 0 37.7-22.8 70.1-55.3 84.4-1.2.5-2 1.6-2.1 2.9l-1.5 10.8c-.2 1.1.9 1.9 1.9 1.5 41.1-14.4 70.6-53.6 70.6-99.6-.2-58.2-47.7-105.6-106-105.5"/>
                  <path d="M147.3 68.2c-37.4 1.4-67.4 32.3-67.9 69.7-.3 24.6 12 46.4 30.9 59.3.9.6 2.2-.1 2.2-1.2-.3-4.3-.3-8.1-.1-12.1.1-1.3-.4-2.5-1.4-3.4-11.5-10.8-18.5-26.2-18.1-43.2.8-30 24.9-54.4 54.9-55.6 32.6-1.3 59.4 24.9 59.4 57.1 0 16.4-7 31.2-18.1 41.7-.9.9-1.4 2.1-1.4 3.4.2 3.9.1 7.7-.1 12-.1 1.1 1.2 1.9 2.2 1.2 18.6-12.7 30.9-34.2 30.9-58.4.1-39.8-33.2-72.1-73.4-70.5"/>
                </g>
              </svg>
              Apple Podcasts
              <span class="platform-link__sub">{isDE ? 'Audio' : 'Audio'}</span>
            </a>
          </nav>

          <!-- Show stats strip -->
          {episodeCount > 0 && (
            <div class="show-stats" role="list" aria-label={isDE ? 'Podcast-Statistiken' : 'Podcast stats'}>
              <div class="show-stat" role="listitem">
                <span class="show-stat__n">{episodeCount}</span>
                <span class="show-stat__l">{isDE ? 'Episoden' : 'Episodes'}</span>
              </div>
              <div class="show-stat" role="listitem">
                <span class="show-stat__n">10–15</span>
                <span class="show-stat__l">{isDE ? 'Minuten' : 'Minutes'}</span>
              </div>
              <div class="show-stat" role="listitem">
                <span class="show-stat__n"><em>Solo</em></span>
                <span class="show-stat__l">{isDE ? 'Format' : 'Format'}</span>
              </div>
            </div>
          )}
        </div>

        <!-- Right: subscription card -->
        <aside class="show-sub" aria-label={isDE ? 'Abonnieren' : 'Subscribe'}>
          {showArtwork && (
            <Image
              src={showArtwork}
              alt="Iconoclast Insights podcast artwork"
              width={160}
              height={160}
              class="show-sub__art"
              loading="eager"
              decoding="async"
            />
          )}
          <h2 class="show-sub__heading">
            {isDE ? 'Abonnieren und auf dem Laufenden bleiben' : 'Subscribe and never miss an episode'}
          </h2>
          <p class="show-sub__body">
            {isDE
              ? 'Neue Episoden erscheinen unregelmäßig — wenn es etwas Wichtiges zu sagen gibt. Abonnieren ist die zuverlässigste Art, es zu erfahren.'
              : 'New episodes appear when there\'s something worth saying. Subscribing is the most reliable way to find out when that is.'}
          </p>
          <a href="https://open.spotify.com/show/36YRWk7nrI6V8w9lMncynG" class="btn btn--primary" target="_blank" rel="noopener noreferrer">
            {isDE ? 'Auf Spotify folgen' : 'Follow on Spotify'}
          </a>
          <a href="/podcast/feed.xml" class="show-sub__rss">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
        </aside>

      </div>
    </div>
  </header>

  <!-- ── FILTER BAR ─────────────────────────────────────────────────────── -->
  <div class="filter-bar" role="navigation" aria-label={isDE ? 'Episoden filtern' : 'Filter episodes'}>
    <div class="container">
      <div class="filter-bar__inner">
        <div class="cat-tabs" role="group" aria-label={isDE ? 'Nach Kategorie filtern' : 'Filter by category'}>
          <button class="cat-btn is-active" data-cat="all" aria-pressed="true">
            {isDE ? 'Alle' : 'All'}
          </button>
          {allCats.map(cat => (
            <button class="cat-btn" data-cat={cat} aria-pressed="false">
              {cat}
            </button>
          ))}
        </div>
        <div class="ep-count-strip" aria-live="polite" aria-atomic="true">
          <span id="visible-count">{episodeCount}</span>
          <span>{isDE ? 'Episoden' : 'episodes'}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ── FEATURED LATEST EPISODE ───────────────────────────────────────── -->
  {featured && (
    <section class="latest" aria-labelledby="latest-heading">
      <div class="container">
        <p class="label latest__label">{isDE ? 'Neueste Episode' : 'Latest episode'}</p>
        <a
          href={`${prefix}/podcast/${slugify(featured)}`}
          class="latest__card"
          aria-label={`${isDE ? 'Episode' : 'Episode'} ${featured.data.episode_number}: ${featured.data.title}`}
        >
          <!-- Thumbnail -->
          <div class="latest__thumb">
            {(() => {
              const art = getArtwork(featured);
              return art ? (
                <Image
                  src={art}
                  alt=""
                  width={400}
                  height={400}
                  class="latest__thumb-img"
                  loading="eager"
                  decoding="async"
                  aria-hidden="true"
                />
              ) : (
                <div class="thumb-ph" aria-hidden="true">
                  <span class="thumb-ph__icon">◎</span>
                  <span class="thumb-ph__label">Ep. {String(featured.data.episode_number).padStart(3,'0')}</span>
                </div>
              );
            })()}
            <div class="play-overlay" aria-hidden="true">
              <div class="play-btn">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Body -->
          <div class="latest__body">
            <p class="latest__ep">
              {isDE ? 'Episode' : 'Episode'} {String(featured.data.episode_number).padStart(3,'0')} · {featured.data.category}
            </p>
            <h2 class="latest__title" id="latest-heading">{featured.data.title}</h2>
            {featured.data.summary && (
              <p class="latest__excerpt">{featured.data.summary}</p>
            )}
            <div class="latest__meta">
              {featured.data.duration && (
                <span class="latest__meta-item">
                  {fmtDuration(featured.data.duration)}
                </span>
              )}
              <time class="latest__meta-item" datetime={featured.data.date.toISOString()}>
                {formatDate(featured.data.date)}
              </time>
              {featured.data.youtube_url && (
                <span class="latest__meta-item">
                  {isDE ? 'Video verfügbar' : 'Video available'}
                </span>
              )}
              <span class="latest__listen">
                {isDE ? 'Episode öffnen' : 'Open episode'}
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ── ALL EPISODES ───────────────────────────────────────────────────── -->
  <section class="episodes" aria-labelledby="episodes-heading">
    <div class="container">
      <div class="episodes__header">
        <h2 class="episodes__heading" id="episodes-heading">
          {isDE ? 'Alle Episoden' : 'All episodes'}
        </h2>
      </div>

      {rest.length === 0 && episodeCount === 0 ? (
        <p class="empty-state">
          {isDE ? 'Noch keine Episoden veröffentlicht.' : 'No episodes published yet.'}
        </p>
      ) : (
        <ol class="ep-grid" id="ep-grid">
          {(featured ? [featured, ...rest] : episodes).map((ep, i) => {
            const art = getArtwork(ep);
            return (
              <li class="fade-up" data-cat={ep.data.category}>
                <a
                  href={`${prefix}/podcast/${slugify(ep)}`}
                  class="ep-row"
                  aria-label={`${isDE ? 'Episode' : 'Episode'} ${ep.data.episode_number}: ${ep.data.title}${ep.data.duration ? ', ' + fmtDuration(ep.data.duration) : ''}`}
                >
                  <!-- Thumbnail -->
                  <div class="ep-thumb" role="img" aria-label="">
                    {art ? (
                      <Image
                        src={art}
                        alt=""
                        width={56}
                        height={56}
                        class="ep-thumb-img"
                        loading="lazy"
                        decoding="async"
                        aria-hidden="true"
                      />
                    ) : (
                      <div class="ep-thumb-ph" aria-hidden="true">
                        {String(ep.data.episode_number).padStart(3,'0')}
                      </div>
                    )}
                    <div class="ep-play" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>

                  <!-- Episode info -->
                  <div class="ep-info">
                    <p class="ep-ep">
                      {isDE ? 'Episode' : 'Episode'} {String(ep.data.episode_number).padStart(3,'0')} · {ep.data.category}
                    </p>
                    <p class="ep-title">{ep.data.title}</p>
                    {ep.data.summary && (
                      <p class="ep-excerpt">{ep.data.summary}</p>
                    )}
                  </div>

                  <!-- Aside: duration, date, arrow -->
                  <div class="ep-aside" aria-label={`${fmtDuration(ep.data.duration)}, ${formatDate(ep.data.date)}`}>
                    {ep.data.duration && (
                      <span class="ep-duration">{fmtDuration(ep.data.duration)}</span>
                    )}
                    <time class="ep-date" datetime={ep.data.date.toISOString()}>
                      {formatDate(ep.data.date)}
                    </time>
                    <span class="ep-arrow" aria-hidden="true">→</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </div>
  </section>

  <!-- ── SUBSCRIBE BAND ─────────────────────────────────────────────────── -->
  <section class="sub-band" aria-labelledby="sub-heading">
    <div class="container">
      <div class="sub-band__inner">
        <div>
          <h2 class="sub-band__heading" id="sub-heading">
            {isDE
              ? <Fragment>Hören, wo<br><em>Sie denken.</em></Fragment>
              : <Fragment>Listen wherever<br><em>you think.</em></Fragment>}
          </h2>
          <p class="sub-band__body">
            {isDE
              ? 'Auf allen großen Plattformen verfügbar. Die Videoversion ist auf YouTube; Audio-only ist überall sonst. Abonnieren und wissen, wenn es etwas Herausforderndes gibt.'
              : 'Available on all major platforms. The video version is on YouTube; audio-only is everywhere else. Subscribe and you\'ll know when something worth challenging shows up.'}
          </p>
        </div>
        <nav aria-label={isDE ? 'Auf Plattform hören' : 'Listen on platform'}>
          <div class="platform-grid">
            <a href="https://www.youtube.com/@andredaus" class="platform-card" target="_blank" rel="noopener noreferrer">
              <span class="platform-card__name">YouTube</span>
              <span class="platform-card__sub">{isDE ? 'Video + Audio' : 'Video + Audio'}</span>
            </a>
            <a href="https://open.spotify.com/show/36YRWk7nrI6V8w9lMncynG" class="platform-card" target="_blank" rel="noopener noreferrer">
              <span class="platform-card__name">Spotify</span>
              <span class="platform-card__sub">{isDE ? 'Audio' : 'Audio'}</span>
            </a>
            <a href="https://podcasts.apple.com/podcast/iconoclast-insights/id0000000" class="platform-card" target="_blank" rel="noopener noreferrer">
              <span class="platform-card__name">Apple Podcasts</span>
              <span class="platform-card__sub">{isDE ? 'Audio' : 'Audio'}</span>
            </a>
            <a href="/podcast/feed.xml" class="platform-card">
              <span class="platform-card__name">RSS</span>
              <span class="platform-card__sub">{isDE ? 'Direkter Feed' : 'Direct feed'}</span>
            </a>
          </div>
        </nav>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ───────────────────────────────────────────────────────── -->
  <section class="cta-band" aria-labelledby="cta-heading">
    <div class="container cta-band__inner">
      <p class="label cta-band__label">{isDE ? 'Jenseits des Podcasts' : 'Beyond the podcast'}</p>
      <h2 class="cta-band__heading" id="cta-heading">
        {isDE
          ? <Fragment>Wenn etwas hier wie<br><em>Ihre Organisation</em> klingt,</Fragment>
          : <Fragment>If something in here<br>sounds like <em>your organisation,</em></Fragment>}
      </h2>
      <p class="cta-band__sub">
        {isDE
          ? 'Ein Discovery Call findet heraus, welche der hier diskutierten Annahmen gerade in Ihrer Strategie aktiv sind.'
          : 'A discovery call is where we find out which of the assumptions being discussed in these episodes are running live in your strategy right now.'}
      </p>
      <div class="cta-band__actions">
        <a href={`${prefix}/contact`} class="btn btn--primary btn-arrow">
          {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
        </a>
        <a href={`${prefix}/use-cases`} class="btn btn--outline">
          {isDE ? 'Use Cases lesen' : 'Read the Use Cases'}
        </a>
      </div>
    </div>
  </section>

</Base>

<script>
  (function () {
    // Category filter
    const btns = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
    const items = document.querySelectorAll<HTMLElement>('#ep-grid > li');
    const counter = document.getElementById('visible-count');

    function updateCount() {
      let n = 0;
      items.forEach(li => { if (li.style.display !== 'none') n++; });
      if (counter) counter.textContent = String(n);
    }

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-pressed', 'true');
        const cat = btn.dataset.cat ?? 'all';
        items.forEach(li => {
          li.style.display = cat === 'all' || li.dataset.cat === cat ? '' : 'none';
        });
        updateCount();
      });
    });

    updateCount();

    // Scroll reveal
    if (!window.matchMedia('(prefers-reduced-motion:reduce)').matches) {
      const io = new IntersectionObserver(es => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      }), { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
    } else {
      document.querySelectorAll('.fade-up').forEach(el => el.classList.add('visible'));
    }
  })();
</script>

<style>
  /* ── Show hero ─────────────────────────────────────────────────────────── */
  .show-hero {
