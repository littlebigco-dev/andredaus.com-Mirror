---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const now = new Date();

const allEpisodes = await getCollection('podcast');
const episodes = allEpisodes
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && (!e.data.publish_date || e.data.publish_date <= now))
  .sort((a, b) => b.data.episode_number - a.data.episode_number);

const categories = ['All', ...Array.from(new Set(episodes.map(e => e.data.category))).sort()];
const featured = episodes[0] ?? null;

function slugify(entry: typeof episodes[number]) {
  return entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}
function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

// ── Local artwork lookup ────────────────────────────────────────────────────
// Matches files by Spotify episode ID extracted from spotify_url stem
const allArtwork = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/media/thumbnails/*.{jpg,jpeg,webp,png}',
  { eager: true }
);

function getArtwork(spotifyUrl: string): ImageMetadata | null {
  const id = spotifyUrl.match(/spotify\.com\/(?:embed\/)?[a-z]+\/([a-zA-Z0-9]+)/)?.[1];
  if (!id) return null;
  const entry = Object.entries(allArtwork).find(([path]) =>
    path.split('/').pop()?.replace(/\.[^.]+$/, '') === id
  );
  return entry?.[1]?.default ?? null;
}

// Show-level cover art (use the first/oldest episode's artwork as the show cover)
const showArtwork = featured ? getArtwork(featured.data.spotify_url) : null;
---

<Base
  title={isDE ? 'Podcast — André Daus' : 'Podcast — André Daus'}
  description={isDE
    ? 'Iconoclast Insights: Episoden zu Strategic Opposition, Entscheidungspsychologie und den Annahmen, die Strategie scheitern lassen.'
    : 'Iconoclast Insights: episodes on Strategic Opposition, decision psychology, and the assumptions that make strategy fail.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <header class="pod-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-noise" aria-hidden="true"></div>

    <div class="container pod-hero__inner">

      <!-- Left: show identity -->
      <div class="pod-hero__content">
        <p class="label">{isDE ? 'Podcast' : 'Podcast'}</p>
        <h1 class="pod-hero__title">
          Iconoclast <em>Insights</em>
        </h1>
        <p class="pod-hero__desc">
          {isDE
            ? 'Strategic Opposition, Entscheidungspsychologie und die Annahmen, auf denen Organisationen aufgebaut sind. Ein Podcast für Führungskräfte, die anders denken wollen.'
            : 'Strategic Opposition, decision psychology, and the assumptions organisations are built on. A podcast for leaders who want to think differently.'}
        </p>

        <div class="pod-hero__meta-row">
          <span class="pod-hero__count">
            <span class="pod-hero__count-num">{episodes.length}</span>
            {isDE ? 'Episoden' : 'Episodes'}
          </span>
          {featured && (
            <span class="pod-hero__latest">
              {isDE ? 'Neueste:' : 'Latest:'}
              <a href={`${prefix}/podcast/${slugify(featured)}`} class="pod-hero__latest-link">
                Ep. {String(featured.data.episode_number).padStart(3,'0')}
              </a>
            </span>
          )}
        </div>

        <div class="pod-hero__platforms">
          <a
            href="https://open.spotify.com/show/placeholder"
            class="platform-pill platform-pill--spotify"
            target="_blank" rel="noopener noreferrer"
            aria-label={isDE ? 'Auf Spotify anhören' : 'Listen on Spotify'}
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            Spotify
          </a>
          <a
            href="https://www.youtube.com/@andredaus"
            class="platform-pill platform-pill--youtube"
            target="_blank" rel="noopener noreferrer"
            aria-label={isDE ? 'Auf YouTube ansehen' : 'Watch on YouTube'}
          >
            <svg width="18" height="13" viewBox="0 0 20 14" fill="none" aria-hidden="true">
              <path d="M19.582 2.186A2.506 2.506 0 0 0 17.822.418C16.254 0 10 0 10 0S3.746 0 2.178.418A2.506 2.506 0 0 0 .418 2.186C0 3.76 0 7 0 7s0 3.24.418 4.814a2.506 2.506 0 0 0 1.76 1.768C3.746 14 10 14 10 14s6.254 0 7.822-.418a2.506 2.506 0 0 0 1.76-1.768C20 10.24 20 7 20 7s0-3.24-.418-4.814Z" fill="currentColor"/>
              <path d="M8 10l5.196-3L8 4v6Z" fill="#090c14"/>
            </svg>
            YouTube
          </a>
        </div>
      </div>

      <!-- Right: show cover art -->
      <div class="pod-hero__cover" aria-hidden="true">
        {showArtwork ? (
          <Image
            src={showArtwork}
            alt=""
            width={400}
            height={400}
            class="pod-hero__cover-img"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="pod-hero__cover-fallback">
            <span class="pod-hero__cover-label">Iconoclast<br/>Insights</span>
          </div>
        )}
        <div class="pod-hero__cover-glow" aria-hidden="true"></div>
      </div>

    </div>
  </header>

  <!-- ── EPISODES ──────────────────────────────────────────────────────── -->
  <section class="section" aria-label={isDE ? 'Episoden' : 'Episodes'}>
    <div class="container">

      <!-- Filter bar -->
      <div class="filter-bar" role="group" aria-label={isDE ? 'Nach Kategorie filtern' : 'Filter by category'}>
        {categories.map(cat => (
          <button
            class="filter-btn"
            data-category={cat}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat === 'All' ? (isDE ? 'Alle' : 'All') : cat}
          </button>
        ))}
      </div>

      {episodes.length === 0 ? (
        <p class="empty-state">{isDE ? 'Noch keine Episoden veröffentlicht.' : 'No episodes published yet.'}</p>
      ) : (
        <ul class="episodes-list" id="episodes-list">
          {episodes.map(entry => {
            const artwork = getArtwork(entry.data.spotify_url);
            const hasVideo = !!entry.data.youtube_url;
            return (
              <li class="ep-card" data-category={entry.data.category}>
                <a href={`${prefix}/podcast/${slugify(entry)}`} class="ep-card__link">

                  <!-- Artwork column -->
                  <div class="ep-card__art">
                    {artwork ? (
                      <Image
                        src={artwork}
                        alt=""
                        width={120}
                        height={120}
                        class="ep-card__img"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="ep-card__img ep-card__img--fallback" aria-hidden="true">
                        <span class="ep-card__num">
                          {String(entry.data.episode_number).padStart(3, '0')}
                        </span>
                      </div>
                    )}
                    {hasVideo && (
                      <span class="ep-card__video-badge" title={isDE ? 'Video verfügbar' : 'Video available'} aria-label={isDE ? 'Video verfügbar' : 'Video available'}>
                        <svg width="10" height="8" viewBox="0 0 20 14" fill="none" aria-hidden="true">
                          <path d="M19.582 2.186A2.506 2.506 0 0 0 17.822.418C16.254 0 10 0 10 0S3.746 0 2.178.418A2.506 2.506 0 0 0 .418 2.186C0 3.76 0 7 0 7s0 3.24.418 4.814a2.506 2.506 0 0 0 1.76 1.768C3.746 14 10 14 10 14s6.254 0 7.822-.418a2.506 2.506 0 0 0 1.76-1.768C20 10.24 20 7 20 7s0-3.24-.418-4.814Z" fill="currentColor"/>
                          <path d="M8 10l5.196-3L8 4v6Z" fill="#090c14"/>
                        </svg>
                      </span>
                    )}
                  </div>

                  <!-- Content column -->
                  <div class="ep-card__body">
                    <div class="ep-card__meta">
                      <span class="ep-cat">{entry.data.category}</span>
                      <time datetime={entry.data.date.toISOString()} class="ep-date">
                        {formatDate(entry.data.date)}
                      </time>
                    </div>
                    <h2 class="ep-card__title">{entry.data.title}</h2>
                    {entry.data.summary && (
                      <p class="ep-card__summary">{entry.data.summary}</p>
                    )}
                    <div class="ep-card__actions">
                      <span class="ep-card__read">
                        {isDE ? 'Episode lesen' : 'Read episode'}
                        <span aria-hidden="true"> →</span>
                      </span>
                      <div class="ep-card__platforms">
                        <span class="ep-platform ep-platform--spotify" aria-label="Spotify">
                          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                          </svg>
                        </span>
                        {hasVideo && (
                          <span class="ep-platform ep-platform--youtube" aria-label="YouTube">
                            <svg width="13" height="9" viewBox="0 0 20 14" fill="none" aria-hidden="true">
                              <path d="M19.582 2.186A2.506 2.506 0 0 0 17.822.418C16.254 0 10 0 10 0S3.746 0 2.178.418A2.506 2.506 0 0 0 .418 2.186C0 3.76 0 7 0 7s0 3.24.418 4.814a2.506 2.506 0 0 0 1.76 1.768C3.746 14 10 14 10 14s6.254 0 7.822-.418a2.506 2.506 0 0 0 1.76-1.768C20 10.24 20 7 20 7s0-3.24-.418-4.814Z" fill="currentColor"/>
                              <path d="M8 10l5.196-3L8 4v6Z" fill="#090c14"/>
                            </svg>
                          </span>
                        )}
                      </div>
                    </div>
                  </div>

                  <!-- Episode number -->
                  <div class="ep-card__num-col" aria-hidden="true">
                    {String(entry.data.episode_number).padStart(3, '0')}
                  </div>

                </a>
              </li>
            );
          })}
        </ul>
      )}

    </div>
  </section>

</Base>

<script>
  const btns  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('.ep-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;
      btns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      cards.forEach(card => {
        const show = cat === 'All' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .pod-hero {
    position: relative;
    padding: calc(68px + var(--section)) 0 var(--section);
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
  }

  .pod-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .pod-hero__content { max-width: 54ch; }

  .pod-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 1.25rem 0 1.5rem;
  }
  .pod-hero__title em { font-style: italic; color: var(--gold); }

  .pod-hero__desc {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .pod-hero__meta-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .pod-hero__count-num {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--gold);
    margin-right: 0.3em;
    letter-spacing: 0;
  }

  .pod-hero__latest-link {
    color: var(--gold);
    text-decoration: none;
    margin-left: 0.3em;
  }
  .pod-hero__latest-link:hover { text-decoration: underline; }

  /* Platform pills */
  .pod-hero__platforms { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .platform-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 1rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .platform-pill--spotify {
    color: #1db954;
    border-color: rgba(29,185,84,0.25);
  }
  .platform-pill--spotify:hover {
    background: rgba(29,185,84,0.08);
    border-color: #1db954;
  }

  .platform-pill--youtube {
    color: var(--gold);
    border-color: var(--border);
  }
  .platform-pill--youtube:hover {
    background: var(--gold-trans);
    border-color: var(--gold);
  }

  /* Cover art */
  .pod-hero__cover {
    position: relative;
    width: clamp(200px, 22vw, 320px);
    aspect-ratio: 1;
    flex-shrink: 0;
  }

  .pod-hero__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    border: 1px solid var(--border);
  }

  .pod-hero__cover-fallback {
    width: 100%;
    height: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .pod-hero__cover-label {
    font-family: var(--serif);
    font-size: clamp(1rem, 2vw, 1.4rem);
    color: var(--gold);
    line-height: 1.3;
    font-style: italic;
  }

  .pod-hero__cover-glow {
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(196,154,60,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  /* ── Filter bar ────────────────────────────────────────────────────── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .filter-btn {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: border-color 0.18s, color 0.18s, background 0.18s;
  }
  .filter-btn:hover,
  .filter-btn[aria-pressed="true"] {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-trans);
  }

  /* ── Episode list ──────────────────────────────────────────────────── */
  .episodes-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border-light); /* shows as divider between cards */
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .ep-card {
    background: var(--bg-card);
    transition: background-color 0.18s;
  }
  .ep-card:hover { background: var(--bg-elevated); }

  .ep-card__link {
    display: grid;
    grid-template-columns: 120px 1fr auto;
    gap: 0;
    text-decoration: none;
    color: inherit;
    min-height: 120px;
  }

  /* Artwork cell */
  .ep-card__art {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ep-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .ep-card:hover .ep-card__img { transform: scale(1.04); }

  .ep-card__img--fallback {
    background: var(--bg-elevated);
    border-right: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ep-card__num {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--gold-dim);
    letter-spacing: 0.08em;
  }

  /* Video badge on artwork */
  .ep-card__video-badge {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(9,12,20,0.82);
    border: 1px solid rgba(196,154,60,0.3);
    border-radius: 2px;
    padding: 3px 5px;
    display: flex;
    align-items: center;
    color: var(--gold);
    backdrop-filter: blur(4px);
  }

  /* Content cell */
  .ep-card__body {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .ep-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .ep-cat {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 2px 7px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }

  .ep-date {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .ep-card__title {
    font-family: var(--serif);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .ep-card__summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 0.9rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ep-card__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .ep-card__read {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .ep-card__platforms {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ep-platform {
    display: inline-flex;
    align-items: center;
    padding: 3px 7px;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-muted);
  }

  .ep-platform--spotify { color: #1db954; border-color: rgba(29,185,84,0.2); }
  .ep-platform--youtube { color: var(--gold); border-color: rgba(196,154,60,0.2); }

  /* Episode number far-right column */
  .ep-card__num-col {
    width: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    border-left: 1px solid var(--border-light);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    padding: 1rem 0;
  }

  .empty-state { color: var(--text-muted); font-style: italic; padding: 3rem 0; }

  /* ── Responsive ────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .pod-hero__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .pod-hero__cover {
      width: clamp(140px, 40vw, 220px);
      order: -1;
    }
  }

