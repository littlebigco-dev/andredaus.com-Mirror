---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import YouTubePlayer  from '../../components/YouTubePlayer.astro';
import PodcastPlayer  from '../../components/PodcastPlayer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('podcast');
  return entries
    .filter(e => e.id.startsWith('en/') && e.data.status === 'published')
    .map(entry => ({
      params: { slug: entry.id.replace(/^en\//, '').replace(/\.md$/, '') },
      props:  { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function fmtDuration(d?: string): string {
  if (!d) return '';
  const parts = d.split(':').map(Number);
  if (parts.length === 3) {
    const h = parts[0];
    const m = parts[1];
    return h > 0 ? `${h}h ${m}m` : `${m} min`;
  }
  return d;
}

// YouTube video ID extraction
function extractYtId(url?: string): string | null {
  if (!url) return null;
  return new URL(url).searchParams.get('v')
    ?? url.match(/youtu\.be\/([^?&]+)/)?.[1]
    ?? url.match(/youtube\.com\/embed\/([^?&]+)/)?.[1]
    ?? null;
}
const ytVideoId = extractYtId(entry.data.youtube_url);

// Artwork lookup
const allArtwork = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/media/thumbnails/*.{jpg,jpeg,webp,png}',
  { eager: true }
);

function getArtwork(ep: typeof entry): ImageMetadata | null {
  const id = ep.data.episode_id
    ?? ep.data.spotify_url?.match(/spotify\.com\/(?:embed\/)?[a-z]+\/([a-zA-Z0-9]+)/)?.[1]
    ?? null;
  if (!id) return null;
  const found = Object.entries(allArtwork).find(([path]) =>
    path.split('/').pop()?.replace(/\.[^.]+$/, '') === id
  );
  return found?.[1]?.default ?? null;
}

const artwork = getArtwork(entry);
const artworkId = entry.data.episode_id
  ?? entry.data.spotify_url?.match(/spotify\.com\/(?:embed\/)?[a-z]+\/([a-zA-Z0-9]+)/)?.[1]
  ?? entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');

// Related episodes (same category, excluding current, up to 3)
const allEpisodes = await getCollection('podcast');
const published = allEpisodes
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.episode_number - a.data.episode_number);

const related = published
  .filter(e => e.id !== entry.id)
  .slice(0, 3);

function slugify(e: typeof published[number]) {
  return e.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

// Spotify icon path
const spPath = 'M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z';

const shareUrl = `https://andredaus.com${prefix}/podcast/${entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '')}`;
---

<Base
  title={`${entry.data.title} — Iconoclast Insights Ep. ${entry.data.episode_number} · André Daus`}
  description={entry.data.summary}
  ogImage={entry.data.og_image}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ── BREADCRUMB ─────────────────────────────────────────────────────── -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb__inner">
        <li><a href={`${prefix}/`} class="breadcrumb__link">{isDE ? 'Start' : 'Home'}</a></li>
        <li aria-hidden="true"><span class="breadcrumb__sep">/</span></li>
        <li><a href={`${prefix}/podcast`} class="breadcrumb__link">Iconoclast Insights</a></li>
        <li aria-hidden="true"><span class="breadcrumb__sep">/</span></li>
        <li><span class="breadcrumb__current" aria-current="page">{entry.data.title}</span></li>
      </ol>
    </div>
  </nav>

  <!-- ── EPISODE HERO ───────────────────────────────────────────────────── -->
  <header class="ep-hero" aria-labelledby="ep-title">
    <div class="ep-hero__grid" aria-hidden="true"></div>
    <div class="container">
      <div class="ep-hero__inner">

        <!-- Left: title + meta -->
        <div>
          <div class="ep-hero__meta" role="list" aria-label={isDE ? 'Episoden-Metadaten' : 'Episode metadata'}>
            <span class="ep-badge ep-badge--num" role="listitem">
              {isDE ? 'Episode' : 'Episode'} {String(entry.data.episode_number).padStart(3,'0')}
            </span>
            <span class="ep-badge" role="listitem">{entry.data.category}</span>
            {ytVideoId && (
              <span class="ep-badge ep-badge--video" role="listitem">
                {isDE ? 'Video verfügbar' : 'Video available'}
              </span>
            )}
          </div>

          <h1 class="ep-hero__title" id="ep-title">{entry.data.title}</h1>

          {entry.data.summary && (
            <p class="ep-summary" aria-label={isDE ? 'Episoden-Zusammenfassung' : 'Episode summary'}>
              {entry.data.summary}
            </p>
          )}

          <div class="ep-hero__timestamps" role="list" aria-label={isDE ? 'Episodendetails' : 'Episode details'}>
            {entry.data.duration && (
              <span role="listitem">{fmtDuration(entry.data.duration)}</span>
            )}
            {entry.data.duration && <span class="ep-hero__timestamps-sep" aria-hidden="true">·</span>}
            <time role="listitem" datetime={entry.data.date.toISOString()}>
              {formatDate(entry.data.date)}
            </time>
            <span class="ep-hero__timestamps-sep" aria-hidden="true">·</span>
            <span role="listitem">Iconoclast Insights</span>
          </div>
        </div>

        <!-- Right: listen aside -->
        <aside aria-label={isDE ? 'Auf Ihrer Plattform hören' : 'Listen on your platform'}>
          <div class="ep-listen">
            {ytVideoId && (
              <a
                href={entry.data.youtube_url}
                class="ep-listen-btn ep-listen-btn--primary"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={isDE ? 'Auf YouTube ansehen' : 'Watch on YouTube'}
              >
                <svg class="ep-listen-btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                </svg>
                {isDE ? 'Auf YouTube ansehen' : 'Watch on YouTube'}
              </a>
            )}
            {entry.data.spotify_url && (
              <a
                href={entry.data.spotify_url}
                class="ep-listen-btn"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={isDE ? 'Auf Spotify anhören' : 'Listen on Spotify'}
              >
                <svg class="ep-listen-btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={spPath}/>
                </svg>
                {isDE ? 'Auf Spotify anhören' : 'Listen on Spotify'}
              </a>
            )}
            <a
              href="https://podcasts.apple.com/podcast/iconoclast-insights/id0000000"
              class="ep-listen-btn"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={isDE ? 'Auf Apple Podcasts anhören' : 'Listen on Apple Podcasts'}
            >
              <svg class="ep-listen-btn__icon" xmlns="http://www.w3.org/2000/svg" xml:space="preserve" viewBox="0 0 300 300" aria-hidden="true">
                <linearGradient id="apple-grad-detail" x1="150" x2="150" y1="0" y2="300" gradientUnits="userSpaceOnUse">
                  <stop offset="0" style="stop-color:#f452ff"/>
                  <stop offset="1" style="stop-color:#832bc1"/>
                </linearGradient>
                <path fill="url(#apple-grad-detail)" fill-rule="evenodd" d="M294.1 260c-2.9 7.4-9.6 17.8-19.2 25.2-5.5 4.2-12.1 8.3-21.1 11-9.6 2.9-21.5 3.8-36.3 3.8h-135c-14.8 0-26.6-1-36.3-3.8-9-2.7-15.6-6.7-21.1-11-9.5-7.3-16.3-17.8-19.2-25.2C.1 245.1 0 228.2 0 217.5v-135C0 71.8.1 54.9 5.9 40c2.9-7.4 9.6-17.8 19.2-25.2 5.5-4.2 12.1-8.3 21.1-11C55.9 1 67.7 0 82.5 0h135c14.8 0 26.6 1 36.3 3.8 9 2.7 15.6 6.7 21.1 11 9.5 7.3 16.3 17.8 19.2 25.2 5.9 14.9 5.9 31.9 5.9 42.5v135c0 10.7-.1 27.6-5.9 42.5" clip-rule="evenodd"/>
                <g fill="#fff">
                  <path d="M175.7 181.1c-.4-3.6-1.6-6.2-4-8.6-4.5-4.7-12.4-7.8-21.7-7.8s-17.2 3-21.7 7.8c-2.3 2.5-3.6 5-4 8.6-.8 7-.3 13 .5 22.7.8 9.2 2.3 21.5 4.2 33.9 1.4 8.9 2.5 13.7 3.5 17.1 1.7 5.6 7.8 10.4 17.5 10.4s15.9-4.9 17.5-10.4c1-3.4 2.1-8.2 3.5-17.1 1.9-12.5 3.4-24.7 4.2-33.9.9-9.7 1.3-15.7.5-22.7M174.6 130.1c0 13.6-11 24.6-24.6 24.6s-24.6-11-24.6-24.6 11-24.6 24.6-24.6 24.6 11.1 24.6 24.6"/>
                  <path d="M149.7 33.2C92.3 33.4 45.3 80 44.5 137.4c-.6 46.5 29.1 86.3 70.6 100.9 1 .4 2-.5 1.9-1.5-.5-3.6-1.1-7.2-1.5-10.8-.2-1.3-1-2.3-2.1-2.9-32.8-14.3-55.7-47.2-55.3-85.3.5-50 41.3-90.7 91.2-91.1 51.1-.4 92.8 41 92.8 92 0 37.7-22.8 70.1-55.3 84.4-1.2.5-2 1.6-2.1 2.9l-1.5 10.8c-.2 1.1.9 1.9 1.9 1.5 41.1-14.4 70.6-53.6 70.6-99.6-.2-58.2-47.7-105.6-106-105.5"/>
                  <path d="M147.3 68.2c-37.4 1.4-67.4 32.3-67.9 69.7-.3 24.6 12 46.4 30.9 59.3.9.6 2.2-.1 2.2-1.2-.3-4.3-.3-8.1-.1-12.1.1-1.3-.4-2.5-1.4-3.4-11.5-10.8-18.5-26.2-18.1-43.2.8-30 24.9-54.4 54.9-55.6 32.6-1.3 59.4 24.9 59.4 57.1 0 16.4-7 31.2-18.1 41.7-.9.9-1.4 2.1-1.4 3.4.2 3.9.1 7.7-.1 12-.1 1.1 1.2 1.9 2.2 1.2 18.6-12.7 30.9-34.2 30.9-58.4.1-39.8-33.2-72.1-73.4-70.5"/>
                </g>
              </svg>
              Apple Podcasts
            </a>
          </div>

          <p class="ep-listen-note">
            {isDE
              ? 'Audio auf allen Plattformen · Video auf YouTube'
              : 'Audio-only available on all platforms · Video on YouTube'}
          </p>

          <!-- Share buttons -->
          <div class="ep-share">
            <span class="ep-share-label">{isDE ? 'Teilen' : 'Share'}</span>
            <button
              class="ep-share-btn"
              id="copy-link-btn"
              data-url={shareUrl}
              aria-label={isDE ? 'Link kopieren' : 'Copy link to clipboard'}
              title={isDE ? 'Link kopieren' : 'Copy link'}
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
            </button>
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(shareUrl)}`}
              class="ep-share-btn"
              aria-label={isDE ? 'Auf X teilen' : 'Share on X'}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0.25 500 452" fill="currentColor" aria-hidden="true">
                <path d="M394.033.25h76.67L303.202 191.693l197.052 260.511h-154.29L225.118 294.205 86.844 452.204H10.127l179.16-204.77L.254.25H158.46l109.234 144.417zm-26.908 406.063h42.483L135.377 43.73h-45.59z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
              class="ep-share-btn"
              aria-label={isDE ? 'Auf LinkedIn teilen' : 'Share on LinkedIn'}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 5 1036 990" fill="currentColor" aria-hidden="true">
                <path d="M0 120c0-33.334 11.667-60.834 35-82.5C58.333 15.833 88.667 5 126 5c36.667 0 66.333 10.666 89 32 23.333 22 35 50.666 35 86 0 32-11.333 58.666-34 80-23.333 22-54 33-92 33h-1c-36.667 0-66.333-11-89-33S0 153.333 0 120zm13 875V327h222v668H13zm345 0h222V622c0-23.334 2.667-41.334 8-54 9.333-22.667 23.5-41.834 42.5-57.5 19-15.667 42.833-23.5 71.5-23.5 74.667 0 112 50.333 112 151v357h222V612c0-98.667-23.333-173.5-70-224.5S857.667 311 781 311c-86 0-153 37-201 111v2h-1l1-2v-95H358c1.333 21.333 2 87.666 2 199 0 111.333-.667 267.666-2 469z"/>
              </svg>
            </a>
          </div>
        </aside>

      </div>
    </div>
  </header>

  <!-- ── VIDEO / AUDIO EMBED ────────────────────────────────────────────── -->
  {ytVideoId ? (
    <section class="ep-video" aria-labelledby="video-section-label">
      <div class="container">
        <h2 class="sr-only" id="video-section-label">
          {isDE ? 'Episodenvideo' : 'Episode video'}
        </h2>
        <YouTubePlayer
          videoId={ytVideoId}
          title={entry.data.title}
        />
        {entry.data.audio_url && (
          <div style="margin-top:1rem">
            <PodcastPlayer
              audioUrl={entry.data.audio_url}
              title={entry.data.title}
              artworkId={artworkId}
              spotifyUrl={entry.data.spotify_url}
              duration={entry.data.duration}
              compact={true}
            />
          </div>
        )}
      </div>
    </section>
  ) : entry.data.audio_url ? (
    <section class="ep-video ep-video--audio" aria-labelledby="audio-section-label">
      <div class="container">
        <h2 class="sr-only" id="audio-section-label">
          {isDE ? 'Episodenaudio' : 'Episode audio'}
        </h2>
        <PodcastPlayer
          audioUrl={entry.data.audio_url}
          title={entry.data.title}
          artworkId={artworkId}
          spotifyUrl={entry.data.spotify_url}
          duration={entry.data.duration}
          compact={false}
          aspect="1/1"
        />
      </div>
    </section>
  ) : null}

  <!-- ── BODY LAYOUT ────────────────────────────────────────────────────── -->
  <div class="container">
    <div class="ep-layout">

      <!-- Main content -->
      <article class="ep-body" aria-label={isDE ? 'Episodeninhalt' : 'Episode content'}>

        <!-- Transcript / description -->
        <section class="ep-section fade-up" aria-labelledby="transcript-heading">
          <h2 class="ep-section__heading" id="transcript-heading">
            {isDE ? 'Transkript' : 'Transcript'}
            <span class="ep-section__badge">
              {isDE ? 'Vollständig' : 'Full text'}
            </span>
          </h2>
          <div class="ep-description">
            <Content />
          </div>
        </section>

      </article>

      <!-- Sticky sidebar -->
      <aside class="ep-sidebar" aria-label={isDE ? 'Episoden-Sidebar' : 'Episode sidebar'}>

        <!-- Episode meta card -->
        <div class="ep-meta-card">
          <div class="ep-meta-row">
            <span class="ep-meta-key">{isDE ? 'Episode' : 'Episode'}</span>
            <span class="ep-meta-val">
              {String(entry.data.episode_number).padStart(3,'0')}
            </span>
          </div>
          <div class="ep-meta-row">
            <span class="ep-meta-key">{isDE ? 'Datum' : 'Date'}</span>
            <time class="ep-meta-val" datetime={entry.data.date.toISOString()}>
              {formatDate(entry.data.date)}
            </time>
          </div>
          {entry.data.duration && (
            <div class="ep-meta-row">
              <span class="ep-meta-key">{isDE ? 'Dauer' : 'Duration'}</span>
              <span class="ep-meta-val">{fmtDuration(entry.data.duration)}</span>
            </div>
          )}
          <div class="ep-meta-row">
            <span class="ep-meta-key">{isDE ? 'Kategorie' : 'Category'}</span>
            <span class="ep-meta-val">{entry.data.category}</span>
          </div>
          {entry.data.spotify_url && (
            <div class="ep-meta-row">
              <span class="ep-meta-key">Spotify</span>
              <span class="ep-meta-val">
                <a href={entry.data.spotify_url} target="_blank" rel="noopener noreferrer">
                  {isDE ? 'Öffnen ↗' : 'Open ↗'}
                </a>
              </span>
            </div>
          )}
        </div>

        <!-- Show card -->
        <a href={`${prefix}/podcast`} class="show-card">
          <div class="show-card__art">
            {artwork ? (
              <Image
                src={artwork}
                alt=""
                width={48}
                height={48}
                class="show-card__art-img"
                loading="lazy"
                decoding="async"
                aria-hidden="true"
              />
            ) : (
              <div class="show-card__art-ph" aria-hidden="true">II</div>
            )}
          </div>
          <div class="show-card__info">
            <p class="show-card__label">{isDE ? 'Podcast' : 'Podcast'}</p>
            <p class="show-card__name">Iconoclast Insights</p>
            <p class="show-card__sub">
              {isDE ? 'Alle Episoden ansehen' : 'View all episodes'}
            </p>
          </div>
        </a>

      </aside>
    </div>
  </div>

  <!-- Mobile sticky CTA -->
  <div class="mobile-cta" aria-label={isDE ? 'Episodenaktionen' : 'Episode actions'}>
    {entry.data.spotify_url && (
      <a href={entry.data.spotify_url} class="btn btn--outline" target="_blank" rel="noopener noreferrer">
        {isDE ? 'Auf Spotify' : 'On Spotify'}
      </a>
    )}
    {ytVideoId && (
      <a href={entry.data.youtube_url} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
        {isDE ? 'Auf YouTube' : 'On YouTube'}
      </a>
    )}
  </div>

  <!-- ── RELATED EPISODES ───────────────────────────────────────────────── -->
  {related.length > 0 && (
    <section class="related" aria-labelledby="related-heading">
      <div class="container">
        <h2 class="related__heading" id="related-heading">
          {isDE ? 'Weitere Episoden' : 'More episodes'}
        </h2>
        <ul class="related__grid">
          {related.map(rel => {
            const relArt = getArtwork(rel);
            return (
              <li>
                <a href={`${prefix}/podcast/${slugify(rel)}`} class="rel-ep-card">
                  <div class="rel-ep-card__thumb">
                    {relArt ? (
                      <Image
                        src={relArt}
                        alt=""
                        width={56}
                        height={56}
                        class="rel-ep-card__thumb-img"
                        loading="lazy"
                        decoding="async"
                        aria-hidden="true"
                      />
                    ) : (
                      <div class="rel-ep-card__thumb-ph" aria-hidden="true">
                        {String(rel.data.episode_number).padStart(3,'0')}
                      </div>
                    )}
                  </div>
                  <div class="rel-ep-card__info">
                    <p class="rel-ep-card__ep">
                      {isDE ? 'Ep.' : 'Ep.'} {rel.data.episode_number} · {rel.data.category}
                    </p>
                    <p class="rel-ep-card__title">{rel.data.title}</p>
                    {rel.data.duration && (
                      <p class="rel-ep-card__duration">
                        {rel.data.duration.split(':').slice(0,2).map(Number).reduce((h,m) => h*60+m, 0)} min
                      </p>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  <!-- ── CTA BAND ───────────────────────────────────────────────────────── -->
  <section class="cta-band" aria-labelledby="cta-heading">
    <div class="container cta-band__inner">
      <p class="label cta-band__label">{isDE ? 'Jenseits des Podcasts' : 'Beyond the podcast'}</p>
      <h2 class="cta-band__heading" id="cta-heading">
        {isDE
          ? <Fragment>Wenn das hier wie<br><em>Ihr Problem</em> klingt,</Fragment>
          : <Fragment>If this sounds like<br><em>your problem,</em></Fragment>}
      </h2>
      <p class="cta-band__sub">
        {isDE
          ? '30 Minuten. Keine Vorbereitung. Wir finden die Annahme, die am dringendsten zu untersuchen ist.'
          : '30 minutes. No preparation. We find the assumption most worth examining first.'}
      </p>
      <div class="cta-band__actions">
        <a href={`${prefix}/contact`} class="btn btn--primary btn-arrow">
          {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
        </a>
        <a href={`${prefix}/podcast`} class="btn btn--outline">
          {isDE ? 'Alle Episoden' : 'All Episodes'}
        </a>
