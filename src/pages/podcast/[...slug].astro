---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('podcast');
  return entries
    .filter(e => e.id.startsWith('en/') && e.data.status === 'published')
    .map(entry => ({
      params: { slug: entry.id.replace(/^en\//, '').replace(/\.md$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={`${entry.data.title} — André Daus`}
  description={entry.data.summary}
  ogImage={entry.data.og_image}
  lang={isDE ? 'de' : 'en'}
>

  <!-- EPISODE HERO -->
  <header class="episode-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={`${prefix}/podcast`}>{isDE ? 'Podcast' : 'Podcast'}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">
          {isDE ? 'Episode' : 'Episode'} {entry.data.episode_number}
        </span>
      </nav>

      <div class="episode-hero__inner">
        <div class="episode-hero__cover" aria-hidden="true">
          <div class="img-ph" style="min-height:160px;min-width:160px;max-width:160px;border-radius:var(--radius-lg)">
            <span class="img-ph__icon" aria-hidden="true">◎</span>
            <span class="img-ph__label" style="font-size:10px">Cover Art</span>
          </div>
        </div>

        <div class="episode-hero__content">
          <div class="episode-hero__meta">
            <span class="episode-cat">{entry.data.category}</span>
            <span class="episode-num">
              {isDE ? 'Episode' : 'Episode'} {String(entry.data.episode_number).padStart(3, '0')}
            </span>
            <time datetime={entry.data.date.toISOString()} class="episode-date">
              {formatDate(entry.data.date)}
            </time>
          </div>

          <h1 class="episode-hero__title">{entry.data.title}</h1>

          {entry.data.summary && (
            <p class="episode-hero__summary">{entry.data.summary}</p>
          )}

          <div class="episode-hero__actions">
            {entry.data.spotify_url && (
              <a href={entry.data.spotify_url} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
                {isDE ? 'Auf Spotify anhören' : 'Listen on Spotify'}
              </a>
            )}
            {entry.data.youtube_url && (
              <a href={entry.data.youtube_url} class="btn btn--outline" target="_blank" rel="noopener noreferrer">
                {isDE ? 'Auf YouTube ansehen' : 'Watch on YouTube'}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- TRANSCRIPT -->
  <div class="episode-layout container">
    <article class="article-body prose" aria-label={isDE ? 'Episoden-Transkript' : 'Episode transcript'}>
      <Content />
    </article>

    <aside class="article-aside">
      <div class="aside-card">
        <p class="label" style="margin-bottom:1rem">{isDE ? 'Abonnieren' : 'Subscribe'}</p>
        <p class="aside-card__text">
          {isDE
            ? 'Neue Episoden direkt auf Ihrer bevorzugten Plattform.'
            : 'New episodes directly on your preferred platform.'}
        </p>
        {entry.data.spotify_url && (
          <a href={entry.data.spotify_url} class="btn btn--outline" style="margin-top:1.25rem;width:100%;justify-content:center" target="_blank" rel="noopener noreferrer">
            Spotify
          </a>
        )}
      </div>

      <div class="aside-card" style="margin-top:1.5rem">
        <p class="aside-card__back">
          <a href={`${prefix}/podcast`} class="back-link">
            {isDE ? '← Alle Episoden' : '← All Episodes'}
          </a>
        </p>
      </div>
    </aside>
  </div>

</Base>

<style>
  .episode-hero {
    position: relative;
    padding: calc(68px + 4rem) 0 4rem;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
  .breadcrumb a { color: var(--gold); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .episode-hero__inner {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }
  .episode-hero__cover { flex-shrink: 0; }

  .episode-hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .episode-cat {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .episode-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-secondary);
  }
  .episode-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .episode-hero__title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-primary);
    max-width: 25ch;
    margin-bottom: 1.25rem;
  }
  .episode-hero__summary {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 55ch;
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .episode-hero__actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Layout */
  .episode-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    padding-top: 4rem;
    padding-bottom: 6rem;
    align-items: start;
  }

  /* Article body */
  .article-body :global(h2) {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .article-body :global(h3) {
    font-family: var(--sans);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-body :global(p) {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .article-body :global(strong) { color: var(--text-primary); font-weight: 600; }
  .article-body :global(em) { font-style: italic; color: var(--text-primary); }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }
  .article-body :global(li) { margin-bottom: 0.5rem; list-style: disc; }
  .article-body :global(ol li) { list-style: decimal; }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 3rem 0;
  }

  /* Aside */
  .article-aside { position: sticky; top: calc(68px + 2rem); }
  .aside-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }
  .aside-card__text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .back-link {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .episode-hero__inner { flex-direction: column; gap: 1.5rem; }
    .episode-layout { grid-template-columns: 1fr; gap: 3rem; }
    .article-aside { position: static; }
  }
</style>
