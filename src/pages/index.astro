---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allEpisodes = await getCollection('podcast');
const latestEpisodes = allEpisodes
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.episode_number - a.data.episode_number)
  .slice(0, 3);

const episodeCount = allEpisodes
  .filter(e => e.id.startsWith('en/') && e.data.status === 'published').length;

function epSlug(e: typeof latestEpisodes[number]) {
  return e.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

function fmtDuration(d?: string): string {
  if (!d) return '';
  // "00:11:48" → "11 min", "01:02:00" → "62 min"
  const parts = d.split(':').map(Number);
  if (parts.length === 3) {
    const mins = parts[0] * 60 + parts[1];
    return `${mins} min`;
  }
  return d;
}

// Show artwork: use the most recent episode's artwork as the show cover
const allArtwork = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/media/thumbnails/*.{jpg,jpeg,webp,png}',
  { eager: true }
);

function findArtwork(episodeId?: string, slug?: string): ImageMetadata | null {
  const id = episodeId ?? slug;
  if (!id) return null;
  const entry = Object.entries(allArtwork).find(([path]) =>
    path.split('/').pop()?.replace(/\.[^.]+$/, '') === id
  );
  return entry?.[1]?.default ?? null;
}

const showCover = latestEpisodes.length > 0
  ? findArtwork(
      latestEpisodes[0].data.episode_id,
      latestEpisodes[0].id.replace(/^(en|de)\//, '').replace(/\.md$/, '')
    )
  : null;

const allFaqs = await getCollection('faqs');
const enFaqs = allFaqs
  .filter(f => f.id.startsWith('en/') && f.data.category === 'Methodology')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const deFaqs = allFaqs
  .filter(f => f.id.startsWith('de/') && f.data.category === 'Methodology')
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
const homeFaqs = isDE ? deFaqs : enFaqs;
---

