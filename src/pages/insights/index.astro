---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allInsights = await getCollection('insights');
const insights = allInsights
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = ['All', ...Array.from(new Set(insights.map(e => e.data.category))).sort()];

function slugify(entry: typeof insights[number]) {
  return entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={isDE ? 'Insights — André Daus' : 'Insights — André Daus'}
  description={isDE
    ? 'Artikel zu Strategic Opposition, Entscheidungspsychologie und Unternehmensführung.'
    : 'Articles on Strategic Opposition, decision psychology, and organizational leadership.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="coll-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container">
      <p class="label">{isDE ? 'Erkenntnisse' : 'Insights'}</p>
      <h1 class="coll-hero__heading">
        {isDE
          ? <Fragment>Denken, das <em>stört.</em></Fragment>
          : <Fragment>Thinking that <em>disrupts.</em></Fragment>}
      </h1>
      <p class="coll-hero__sub">
        {isDE
          ? 'Artikel zu Strategic Opposition, Entscheidungspsychologie und den Annahmen, auf denen Organisationen aufgebaut sind.'
          : 'Articles on Strategic Opposition, decision psychology, and the assumptions organisations are built on.'}
      </p>
    </div>
  </header>

  <!-- FILTER + GRID -->
  <section class="section" aria-label={isDE ? 'Artikel-Archiv' : 'Article archive'}>
    <div class="container">

      <!-- Category filter -->
      <div class="filter-bar" role="group" aria-label={isDE ? 'Nach Kategorie filtern' : 'Filter by category'}>
        {categories.map(cat => (
          <button
            class="filter-btn"
            data-category={cat}
            aria-pressed={cat === 'All' ? 'true' : 'false'}
          >
            {cat === 'All' ? (isDE ? 'Alle' : 'All') : cat}
          </button>
        ))}
      </div>

      <!-- Entry grid -->
      {insights.length === 0 ? (
        <p class="empty-state">{isDE ? 'Noch keine Artikel veröffentlicht.' : 'No articles published yet.'}</p>
      ) : (
        <ul class="card-grid" id="insights-grid">
          {insights.map(entry => (
            <li class="insight-card fade-up" data-category={entry.data.category}>
              <a href={`${prefix}/insights/${slugify(entry)}`} class="insight-card__link">
                <div class="insight-card__meta">
                  <span class="insight-card__cat">{entry.data.category}</span>
                  <time datetime={entry.data.date.toISOString()} class="insight-card__date">
                    {formatDate(entry.data.date)}
                  </time>
                </div>
                <h2 class="insight-card__title">{entry.data.title}</h2>
                {entry.data.summary && (
                  <p class="insight-card__summary">{entry.data.summary}</p>
                )}
                <span class="insight-card__read btn-arrow">{isDE ? 'Lesen' : 'Read'}</span>
              </a>
            </li>
          ))}
        </ul>
      )}

    </div>
  </section>

</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLLIElement>('.insight-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;
      btns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach(card => {
        const match = cat === 'All' || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>

<style>
  /* Hero */
  .coll-hero {
    position: relative;
    padding: calc(68px + var(--section)) 0 var(--section);
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .coll-hero .label { margin-bottom: 1.25rem; }
  .coll-hero__heading {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }
  .coll-hero__heading em { font-style: italic; color: var(--gold); }
  .coll-hero__sub {
    max-width: 52ch;
    color: var(--text-secondary);
    font-size: var(--text-lg);
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }
  .filter-btn {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: transparent;
    color: var(--text-subtle);
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-btn:hover,
  .filter-btn[aria-pressed="true"] {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-trans);
  }

  /* Card grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .insight-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base);
  }
  .insight-card:hover { border-color: var(--border); }

  .insight-card__link {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .insight-card__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .insight-card__cat {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .insight-card__date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .insight-card__title {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
    flex: 1;
  }
  .insight-card__summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .insight-card__read {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: auto;
  }
  .insight-card__read::after {
    content: ' →';
  }

  .empty-state {
    color: var(--text-subtle);
    font-style: italic;
    padding: 3rem 0;
  }

  @media (max-width: 640px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
