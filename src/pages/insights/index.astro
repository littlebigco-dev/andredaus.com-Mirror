---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allInsights = await getCollection('insights');
const insights = allInsights
  .filter(e => e.id.startsWith(isDE ? 'de/' : 'en/') && e.data.status === 'published')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featured = insights[0] ?? null;
const rest     = insights.slice(1);

// All categories from published articles
const allCats = Array.from(new Set(insights.map(e => e.data.category))).sort();

function slugify(entry: typeof insights[number]) {
  return entry.id.replace(/^(en|de)\//, '').replace(/\.md$/, '');
}

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

// Estimate read time from summary word count — real time is in body
// schema doesn't have readtime field yet; we'll show category for now
---

<Base
  title={isDE ? 'Insights — André Daus' : 'Insights — André Daus'}
  description={isDE
    ? 'Artikel über Denken, Strategie und die Annahmen, die beides leise steuern. Kein Framework-Kult. Keine höfliche Zustimmung.'
    : 'Articles on thinking, strategy, and the assumptions that quietly run both. No framework worship. No polite agreement.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ── PAGE HERO ──────────────────────────────────────────────────────── -->
  <header class="page-hero" aria-labelledby="page-heading">
    <div class="page-hero__grid" aria-hidden="true"></div>
    <div class="container">
      <div class="page-hero__inner">
        <p class="label page-hero__label">
          {isDE ? 'Schreiben' : 'Writing'}
        </p>
        <h1 class="page-hero__heading" id="page-heading">
          {isDE
            ? <Fragment>Kein Framework-Kult.<br><em>Keine höfliche Zustimmung.</em></Fragment>
            : <Fragment>No framework worship.<br><em>No polite agreement.</em></Fragment>}
        </h1>
        <p class="page-hero__lede">
          {isDE
            ? 'Artikel über Denken, Strategie und die Annahmen, die beides leise steuern. Wenn Sie Bestätigung suchen, gibt es Tausende andere Blogs dafür.'
            : 'Articles on thinking, strategy, and the assumptions that quietly run both. If you want validation, there are thousands of other blogs for that.'}
        </p>
      </div>
    </div>
  </header>

  <!-- ── STICKY CATEGORY FILTER ────────────────────────────────────────── -->
  <nav
    class="cat-nav"
    aria-label={isDE ? 'Insights nach Kategorie filtern' : 'Filter insights by category'}
  >
    <div class="container">
      <div class="cat-nav__inner" role="list">
        <button class="cat-btn is-active" data-cat="all" role="listitem" aria-pressed="true">
          {isDE ? 'Alle' : 'All'}
        </button>
        {allCats.map(cat => (
          <button class="cat-btn" data-cat={cat} role="listitem" aria-pressed="false">
            {cat}
          </button>
        ))}
      </div>
    </div>
  </nav>

  <!-- ── FEATURED ARTICLE ───────────────────────────────────────────────── -->
  {featured && (
    <section
      class="featured"
      aria-labelledby="featured-heading"
      data-cat={featured.data.category}
    >
      <div class="container">
        <a
          href={`${prefix}/insights/${slugify(featured)}`}
          class="featured__inner"
          aria-label={featured.data.title}
        >
          <!-- Image side -->
          <div class="featured__image" role="img" aria-label={featured.data.og_title ?? featured.data.title}>
            {featured.data.og_image ? (
              <img
                src={featured.data.og_image}
                alt=""
                loading="eager"
                decoding="async"
                style="width:100%;height:100%;object-fit:cover"
              />
            ) : (
              <div class="img-ph">
                <span class="img-ph__icon" aria-hidden="true">◎</span>
                <span class="img-ph__label">{featured.data.category}</span>
              </div>
            )}
          </div>

          <!-- Content side -->
          <div class="featured__content">
            <span class="featured__badge">
              {isDE ? 'Aktuell' : 'Featured'}
            </span>
            <div class="featured__cat" role="list" aria-label={isDE ? 'Kategorien' : 'Categories'}>
              <span class="cat-tag" role="listitem">{featured.data.category}</span>
            </div>
            <h2 class="featured__title" id="featured-heading">
              {featured.data.title}
            </h2>
            {featured.data.summary && (
              <p class="featured__deck">{featured.data.summary}</p>
            )}
            <div class="featured__meta">
              <span class="featured__read">
                {isDE ? 'Artikel lesen' : 'Read article'}
              </span>
              <time class="featured__readtime" datetime={featured.data.date.toISOString()}>
                {formatDate(featured.data.date)}
              </time>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ── ARTICLES GRID ──────────────────────────────────────────────────── -->
  <section class="articles-section section" aria-labelledby="articles-heading">
    <div class="container">
      <div class="section-header">
        <h2 class="section-heading" id="articles-heading">
          {isDE ? 'Alle Artikel' : 'All articles'}
        </h2>
      </div>

      {insights.length === 0 ? (
        <p class="empty-state">
          {isDE ? 'Noch keine Artikel veröffentlicht.' : 'No articles published yet.'}
        </p>
      ) : (
        <ul class="articles-grid" id="articles-grid">
          {insights.map((entry, i) => (
            <li
              class="fade-up"
              data-cat={entry.data.category}
              style={i > 0 ? `transition-delay:${Math.min((i % 3) * 0.1, 0.3)}s` : ''}
            >
              <a
                href={`${prefix}/insights/${slugify(entry)}`}
                class="article-card"
                aria-label={entry.data.title}
              >
                <!-- 16:9 image -->
                <div class="article-card__image" aria-hidden="true">
                  {entry.data.og_image ? (
                    <img
                      src={entry.data.og_image}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      style="width:100%;height:100%;object-fit:cover"
                    />
                  ) : (
                    <div class="img-ph" style="min-height:140px">
                      <span class="img-ph__icon" aria-hidden="true">◎</span>
                      <span class="img-ph__label">{entry.data.category}</span>
                    </div>
                  )}
                </div>

                <div class="article-card__body">
                  <div class="article-card__cats">
                    <span class="article-card__cat">{entry.data.category}</span>
                  </div>
                  <h3 class="article-card__title">{entry.data.title}</h3>
                  {entry.data.summary && (
                    <p class="article-card__excerpt">{entry.data.summary}</p>
                  )}
                  <div class="article-card__footer">
                    <span class="article-card__read">{isDE ? 'Lesen' : 'Read'}</span>
                    <time class="article-card__meta" datetime={entry.data.date.toISOString()}>
                      {formatDate(entry.data.date)}
                    </time>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- ── NEWSLETTER STRIP ───────────────────────────────────────────────── -->
  <section class="newsletter" aria-labelledby="newsletter-heading">
    <div class="container">
      <div class="newsletter__inner">
        <div>
          <h2 class="newsletter__heading" id="newsletter-heading">
            {isDE
              ? <Fragment>Neues Denken,<br><em>wenn es etwas zu sagen gibt.</em></Fragment>
              : <Fragment>New thinking,<br><em>when there's something worth saying.</em></Fragment>}
          </h2>
          <p class="newsletter__sub">
            {isDE
              ? 'Kein wöchentlicher Rhythmus. Kein Content um des Contents willen. Eine E-Mail, wenn es einen Artikel gibt, der etwas Herausforderndes enthält.'
              : 'No weekly cadence. No content for content\'s sake. An email when there\'s an article that challenges something worth challenging.'}
          </p>
        </div>
        <div>
          <!--
            Replace this static form with your FluentForms embed.
            The form action should POST to your Listmonk subscription endpoint.
          -->
          <form class="newsletter__form" action="/subscribe" method="POST" novalidate aria-label={isDE ? 'Newsletter abonnieren' : 'Newsletter subscription'}>
            <div class="newsletter__input-row">
              <label for="newsletter-email" class="sr-only">
                {isDE ? 'E-Mail-Adresse' : 'Email address'}
              </label>
              <input
                type="email"
                id="newsletter-email"
                name="email"
                class="newsletter__input"
                placeholder="your@email.com"
                autocomplete="email"
                required
                aria-required="true"
              />
              <button type="submit" class="btn btn--primary">
                {isDE ? 'Abonnieren' : 'Subscribe'}
              </button>
            </div>
            <p class="newsletter__note">
              {isDE
                ? 'Kein Tracking. Kein Teilen. Jederzeit abbestellen. DSGVO-konformes Double-Opt-In.'
                : 'No tracking. No sharing. Unsubscribe any time. GDPR-compliant double opt-in.'}
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA BAND ───────────────────────────────────────────────────────── -->
  <section class="cta-band" aria-labelledby="cta-heading">
    <div class="container cta-band__inner">
      <p class="label cta-band__label">
        {isDE ? 'Nächster Schritt' : 'Next step'}
      </p>
      <h2 class="cta-band__heading" id="cta-heading">
        {isDE
          ? <Fragment>Über Annahmen zu lesen<br>ist nicht dasselbe wie <em>Ihre eigenen zu finden.</em></Fragment>
          : <Fragment>Reading about assumptions<br>is not the same as <em>finding yours.</em></Fragment>}
      </h2>
      <p class="cta-band__sub">
        {isDE
          ? 'Ein Discovery Call ist der Ort, wo die eigentliche Arbeit beginnt. Kommen Sie mit Ihrer sichersten strategischen Position. Ich werde sie herausfordern.'
          : 'A discovery call is where the actual work starts. Come with your most confident strategic position. I\'ll challenge it.'}
      </p>
      <div class="cta-band__actions">
        <a href={`${prefix}/contact`} class="btn btn--primary btn-arrow">
          {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
        </a>
        <a href={`${prefix}/use-cases`} class="btn btn--outline">
          {isDE ? 'Use Cases ansehen' : 'View Use Cases'}
        </a>
      </div>
    </div>
  </section>

</Base>

<script>
  (function () {
    // Category filter
    const btns  = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
    const items = document.querySelectorAll<HTMLElement>('#articles-grid > li');
    const feat  = document.querySelector<HTMLElement>('.featured');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-pressed', 'true');
        const cat = btn.dataset.cat ?? 'all';

        // Featured
        if (feat) {
          const fc = feat.dataset.cat ?? '';
          feat.style.display = cat === 'all' || fc === cat ? '' : 'none';
        }

        // Grid items
        items.forEach(li => {
          const lc = li.dataset.cat ?? '';
          li.style.display = cat === 'all' || lc === cat ? '' : 'none';
        });
      });
    });

    // Scroll reveal
    if (!window.matchMedia('(prefers-reduced-motion:reduce)').matches) {
      const io = new IntersectionObserver(es => es.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      }), { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.fade-up').forEach(el => io.observe(el));
    } else {
      document.querySelectorAll('.fade-up').forEach(el => el.classList.add('visible'));
    }
  })();
</script>

<style>
  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0 }

  /* ── Page hero ─────────────────────────────────────────────────────────── */
  .page-hero {
    padding-top: 68px;
    background: linear-gradient(160deg, var(--bg-surface) 0%, var(--bg-base) 55%);
    border-bottom: 1px solid var(--border-light);
    position: relative;
    overflow: hidden;
  }
  .page-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    pointer-events: none;
  }
  .page-hero__inner {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 8vw, 6.5rem) clamp(3rem, 5vw, 4rem);
  }
  .page-hero__label { margin-bottom: 1.5rem; }
  .page-hero__heading {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }
  .page-hero__heading em { font-style: italic; color: var(--gold); }
  .page-hero__lede {
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 52ch;
  }

  /* ── Category filter — sticky ──────────────────────────────────────────── */
  .cat-nav {
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
    position: sticky;
    top: 68px;
    z-index: 50;
  }
  .cat-nav__inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-nav__inner::-webkit-scrollbar { display: none; }
  .cat-btn {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1.1rem 1.4rem;
    color: var(--text-secondary);
    border: none;
    background: none;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
    min-height: 44px;
  }
  .cat-btn:hover { color: var(--text-primary); }
  .cat-btn.is-active { color: var(--gold); border-bottom-color: var(--gold); }
  .cat-btn:focus-visible { outline: 3px solid var(--gold); outline-offset: -3px; }

  /* ── Featured article ──────────────────────────────────────────────────── */
  .featured {
    padding-block: clamp(4rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border-light);
  }
  .featured__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .featured__image {
    aspect-ratio: 4/3;
    border-radius: 3px;
    overflow: hidden;
    background: var(--bg-elevated);
    border: 1px solid var(--border-light);
    transition: transform 0.2s;
  }
  .featured:hover .featured__image { transform: scale(1.005); }

  .img-ph {
    width: 100%;
    height: 100%;
    min-height: 200px;
    background: var(--bg-elevated);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2rem;
    text-align: center;
  }
  .img-ph__icon { font-size: 2rem; opacity: 0.15; display: block; color: var(--gold); }
  .img-ph__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .featured__badge {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-trans);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 2px;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .featured__cat {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .cat-tag {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-trans);
    border: 1px solid var(--border);
    padding: 3px 8px;
    border-radius: 2px;
  }
  .featured__title {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }
  .featured:hover .featured__title { color: var(--gold-light); }
  .featured__deck {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 1.75rem;
    max-width: 52ch;
  }
  .featured__meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .featured__read {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.2s;
  }
  .featured:hover .featured__read { gap: 14px; }
  .featured__read::after { content: '→'; }
  .featured__readtime {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-subtle);
  }

  @media (max-width: 820px) { .featured__inner { grid-template-columns: 1fr; } }

  /* ── Articles grid ─────────────────────────────────────────────────────── */
  .articles-section { padding-block: var(--section); }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  .section-heading {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .article-card {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .article-card:hover { border-color: rgba(196,154,60,.3); transform: translateY(-3px); }

  .article-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-light);
  }
  .article-card__image img { transition: transform 0.4s; }
  .article-card:hover .article-card__image img { transform: scale(1.05); }

  .article-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    flex: 1;
  }
  .article-card__cats { display: flex; gap: 0.375rem; flex-wrap: wrap; }
  .article-card__cat {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    background: var(--gold-trans);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 2px;
  }
  .article-card__title {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 400;
    line-height: 1.25;
    color: var(--text-primary);
    transition: color 0.2s;
  }
  .article-card:hover .article-card__title { color: var(--gold-light); }
  .article-card__excerpt {
    font-size: 13px;
    line-height: 1.75;
    color: var(--text-secondary);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.875rem;
    border-top: 1px solid var(--border-light);
    margin-top: auto;
  }
  .article-card__read {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s;
  }
  .article-card:hover .article-card__read { gap: 12px; }
  .article-card__read::after { content: '→'; }
  .article-card__meta { font-family: var(--mono); font-size: 10px; color: var(--text-subtle); }

  @media (max-width: 900px) { .articles-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 560px) { .articles-grid { grid-template-columns: 1fr; } }

  /* ── Newsletter ────────────────────────────────────────────────────────── */
  .newsletter {
    background: var(--navy);
    border-top: 1px solid rgba(29,45,68,.8);
    border-bottom: 1px solid rgba(29,45,68,.8);
    padding-block: 4rem;
  }
  .newsletter__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .newsletter__heading {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: 0.875rem;
  }
  .newsletter__heading em { font-style: italic; color: var(--gold); }
  .newsletter__sub { font-size: 14px; line-height: 1.8; color: var(--text-secondary); }
  .newsletter__form { display: flex; flex-direction: column; gap: 1rem; }
  .newsletter__input-row { display: flex; gap: 0.75rem; }
  .newsletter__input {
    flex: 1;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 0.875rem 1.25rem;
    font-family: var(--sans);
    font-size: 14px;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s;
    min-height: 44px;
  }
  .newsletter__input::placeholder { color: var(--text-subtle); }
  .newsletter__input:focus { border-color: var(--gold); }
  .newsletter__input:focus-visible { outline: 3px solid var(--gold); outline-offset: 2px; }
  .newsletter__note {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    line-height: 1.6;
  }

  @media (max-width: 760px) {
    .newsletter__inner { grid-template-columns: 1fr; }
