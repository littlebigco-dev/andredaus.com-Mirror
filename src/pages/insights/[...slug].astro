---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('insights');
  return entries
    .filter(e => e.id.startsWith('en/') && e.data.status === 'published')
    .map(entry => ({
      params: { slug: entry.id.replace(/^en\//, '').replace(/\.md$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

function formatDate(d: Date) {
  return d.toLocaleDateString(isDE ? 'de-DE' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Base
  title={`${entry.data.title} — André Daus`}
  description={entry.data.summary}
  ogImage={entry.data.og_image}
  lang={isDE ? 'de' : 'en'}
>

  <!-- ARTICLE HERO -->
  <header class="article-hero">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container">
      <nav class="breadcrumb" aria-label={isDE ? 'Breadcrumb' : 'Breadcrumb'}>
        <a href={`${prefix}/insights`}>{isDE ? 'Insights' : 'Insights'}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{entry.data.category}</span>
      </nav>

      <div class="article-hero__meta">
        <span class="article-cat">{entry.data.category}</span>
        <time datetime={entry.data.date.toISOString()} class="article-date">
          {formatDate(entry.data.date)}
        </time>
      </div>

      <h1 class="article-hero__title">{entry.data.title}</h1>

      {entry.data.summary && (
        <p class="article-hero__summary">{entry.data.summary}</p>
      )}
    </div>
  </header>

  <!-- ARTICLE BODY -->
  <div class="article-layout container">
    <article class="article-body prose" aria-label={entry.data.title}>
      <Content />
    </article>

    <aside class="article-aside">
      <div class="aside-card">
        <p class="label" style="margin-bottom:1rem">{isDE ? 'Nächster Schritt' : 'Next step'}</p>
        <p class="aside-card__text">
          {isDE
            ? 'Wenn dieser Artikel eine Frage aufgeworfen hat, die es wert ist, gestellt zu werden, ist ein Discovery Call der richtige Ort, um sie zu stellen.'
            : 'If this article raised a question worth asking, a discovery call is the right place to ask it.'}
        </p>
        <a href={`${prefix}/contact`} class="btn btn--primary" style="margin-top:1.5rem">
          {isDE ? 'Discovery Call buchen' : 'Book a Discovery Call'}
        </a>
      </div>

      <div class="aside-card" style="margin-top:1.5rem">
        <p class="aside-card__back">
          <a href={`${prefix}/insights`} class="btn-arrow back-link">
            {isDE ? '← Alle Insights' : '← All Insights'}
          </a>
        </p>
      </div>
    </aside>
  </div>

</Base>

<style>
  /* Hero */
  .article-hero {
    position: relative;
    padding: calc(68px + 4rem) 0 4rem;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--gold); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .article-hero__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .article-cat {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 2px;
  }
  .article-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-muted);
  }

  .article-hero__title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--text-primary);
    max-width: 22ch;
    margin-bottom: 1.25rem;
  }
  .article-hero__summary {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 55ch;
    line-height: 1.6;
  }

  /* Layout */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    padding-top: 4rem;
    padding-bottom: 6rem;
    align-items: start;
  }

  /* Article body — prose */
  .article-body :global(h2) {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .article-body :global(h3) {
    font-family: var(--sans);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-body :global(p) {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .article-body :global(strong) { color: var(--text-primary); font-weight: 600; }
  .article-body :global(em) { font-style: italic; color: var(--text-primary); }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }
  .article-body :global(li) { margin-bottom: 0.5rem; list-style: disc; }
  .article-body :global(ol li) { list-style: decimal; }
  .article-body :global(blockquote) {
    border-left: 3px solid var(--gold);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }
  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 3rem 0;
  }
  .article-body :global(a) { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }

  /* Aside */
  .article-aside { position: sticky; top: calc(68px + 2rem); }

  .aside-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }
  .aside-card__text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .back-link {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gold);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .article-aside { position: static; }
  }
</style>
