---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const calcomUsername = import.meta.env.PUBLIC_CALCOM_USERNAME ?? '';
const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const allFaqs = await getCollection('faqs');
const enContactFaqs = allFaqs
  .filter(f => f.id.startsWith('en/') && f.data.category === 'Working Together')
  .sort((a, b) => a.data.order - b.data.order);
const deContactFaqs = allFaqs
  .filter(f => f.id.startsWith('de/') && f.data.category === 'Working Together')
  .sort((a, b) => a.data.order - b.data.order);
const contactFaqs = isDE ? deContactFaqs : enContactFaqs;
---

<Base
  title={isDE ? 'Kontakt — André Daus' : 'Contact — André Daus'}
  description={isDE
    ? 'Buchen Sie ein 30-minütiges Entdeckungsgespräch. Kein Pitch, keine Agenda. Ich stelle die Fragen, die wahrscheinlich noch niemand gestellt hat.'
    : 'Book a 30-minute discovery call. No pitch deck, no agenda. I ask questions you probably haven\'t been asked, and we find out whether what I do is what you need.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="contact-hero" aria-labelledby="contact-heading">
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="container">
      <div class="contact-hero__inner">
        <div>
          <p class="label">{isDE ? 'Kontakt aufnehmen' : 'Get in touch'}</p>
          <h1 class="contact-hero__heading" id="contact-heading">
            {isDE
              ? <Fragment>Finden wir heraus,<br />was Sie noch nicht<br /><em>sehen.</em></Fragment>
              : <Fragment>Let's find out<br />what you're not<br /><em>seeing yet.</em></Fragment>
            }
          </h1>
          <p class="contact-hero__sub">
            {isDE
              ? 'Ein 30-minütiges Entdeckungsgespräch. Kein Pitch, keine Agenda. Ich stelle Fragen, die wahrscheinlich noch niemand gestellt hat — und wir finden heraus, ob das, was ich tue, das ist, was Sie brauchen.'
              : 'A 30-minute discovery call. No pitch deck, no agenda. I ask questions you probably haven\'t been asked, and we find out whether what I do is what you need.'
            }
          </p>
        </div>

        <div class="reach-aside" aria-label={isDE ? 'Schnelle Kontaktoptionen' : 'Quick contact options'}>
          <a href="mailto:hello@andredaus.com" class="reach-card">
            <span class="reach-card__icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m2 7 10 7 10-7"/>
              </svg>
            </span>
            <div>
              <p class="reach-card__label">Email</p>
              <p class="reach-card__value">hello@andredaus.com</p>
            </div>
          </a>
          <a href="https://linkedin.com/in/andredaus" class="reach-card" target="_blank" rel="noopener noreferrer">
            <span class="reach-card__icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 5 1036 990" fill="currentColor" aria-hidden="true">
                <path d="M0 120c0-33.334 11.667-60.834 35-82.5C58.333 15.833 88.667 5 126 5c36.667 0 66.333 10.666 89 32 23.333 22 35 50.666 35 86 0 32-11.333 58.666-34 80-23.333 22-54 33-92 33h-1c-36.667 0-66.333-11-89-33S0 153.333 0 120zm13 875V327h222v668H13zm345 0h222V622c0-23.334 2.667-41.334 8-54 9.333-22.667 23.5-41.834 42.5-57.5 19-15.667 42.833-23.5 71.5-23.5 74.667 0 112 50.333 112 151v357h222V612c0-98.667-23.333-173.5-70-224.5S857.667 311 781 311c-86 0-153 37-201 111v2h-1l1-2v-95H358c1.333 21.333 2 87.666 2 199 0 111.333-.667 267.666-2 469z"/>
              </svg>
            </span>
            <div>
              <p class="reach-card__label">LinkedIn</p>
              <p class="reach-card__value">{isDE ? 'Direkt verbinden' : 'Connect directly'} <span class="sr-only">{isDE ? '(öffnet neues Tab)' : '(opens in new tab)'}</span></p>
            </div>
          </a>
          <a href={`${prefix}/podcast`} class="reach-card">
            <span class="reach-card__icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 2a14.5 14.5 0 0 0 0 20M12 2a14.5 14.5 0 0 1 0 20"/>
              </svg>
            </span>
            <div>
              <p class="reach-card__label">Podcast</p>
              <p class="reach-card__value">Iconoclast Insights</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- MAIN: Booking + Sidebar -->
  <section class="contact-main" aria-labelledby="booking-heading">
    <div class="container">
      <div class="contact-main__inner">

        <!-- Left: Booking -->
        <div>
          <p class="label">{isDE ? 'Entdeckungsgespräch' : 'Discovery call'}</p>
          <h2 class="booking-heading" id="booking-heading">
            {isDE ? 'Buchen Sie ein 30-minütiges Gespräch' : 'Book a 30-minute call'}
          </h2>
          <div class="booking-body">
            <p>
              {isDE
                ? 'Das ist kein Verkaufsgespräch. Ich nutze es so, wie ich jedes Engagement nutze — um die Frage zu stellen, die noch niemand gestellt hat. Manchmal führt das zu etwas, das es wert ist, gemeinsam zu verfolgen. Manchmal nicht. In jedem Fall verlassen Sie das Gespräch mit etwas Nützlichem.'
                : 'This isn\'t a sales call. I use it the same way I use every engagement — to ask the question nobody\'s asked yet. Sometimes that surfaces something worth pursuing together. Sometimes it doesn\'t. Either way, you leave with something useful.'
              }
            </p>
            <p>
              {isDE
                ? 'Wählen Sie einen Termin. Kein Formular, kein Fragebogen vorher.'
                : 'Pick a time that works. No form, no questionnaire beforehand.'
              }
            </p>
          </div>

          <!-- Cal.com booking block -->
          <div class="booking-block" aria-label={isDE ? 'Buchungskalender' : 'Booking calendar'}>
            <div class="booking-block__header">
              <span class="booking-block__title">{isDE ? 'Entdeckungsgespräch — André Daus' : 'Discovery Call — André Daus'}</span>
              <span class="booking-block__duration">{isDE ? '30 Min · Video oder Telefon' : '30 min · Video or phone'}</span>
            </div>
            <!-- Cal.com inline embed — set CALCOM_USERNAME to your Cal.com username to activate -->
            {import.meta.env.PUBLIC_CALCOM_USERNAME ? (
              <div id="cal-booking" style="min-height:600px;"></div>
            ) : (
              <div class="booking-placeholder" aria-label={isDE ? 'Kalender-Platzhalter' : 'Calendar placeholder'}>
                <div class="booking-placeholder__icon" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <path d="M16 2v4M8 2v4M3 10h18"/>
                  </svg>
                </div>
                <p class="booking-placeholder__heading">
                  {isDE ? 'Cal.com-Widget wird hier geladen' : 'Cal.com widget loads here'}
                </p>
                <p class="booking-placeholder__note">
                  {isDE
                    ? 'Setzen Sie PUBLIC_CALCOM_USERNAME in den Umgebungsvariablen.'
                    : 'Set PUBLIC_CALCOM_USERNAME in environment variables to activate.'
                  }
                </p>
                <a href="mailto:hello@andredaus.com?subject=Discovery%20Call%20Request" class="btn btn--outline">
                  {isDE ? 'Stattdessen per E-Mail anfragen' : 'Request by email instead'}
                </a>
              </div>
            )}
          </div>

          <!-- What happens in 30 minutes -->
          <div class="expect fade-up" aria-labelledby="expect-heading">
            <p class="expect__heading" id="expect-heading">
              {isDE ? 'Was in 30 Minuten passiert' : 'What happens in 30 minutes'}
            </p>
            <div class="expect-steps" role="list">
              <div class="expect-step" role="listitem">
                <span class="expect-step__n" aria-hidden="true">1</span>
                <div class="expect-step__body">
                  <p class="expect-step__title">
                    {isDE ? 'Ich frage nach dem Problem, das Sie bereits definiert haben' : 'I ask about the problem you\'ve already defined'}
                  </p>
                  <p class="expect-step__desc">
                    {isDE
                      ? 'Die Entscheidung, bei der Sie feststecken. Die Situation, die sich nicht verbessert. Die Strategie, die Sie in Frage stellen. Was auch immer Sie hierher gebracht hat.'
                      : 'The decision you\'re stuck on, the situation that isn\'t improving, the strategy you\'re questioning. Whatever brought you here.'
                    }
                  </p>
                </div>
              </div>
              <div class="expect-step" role="listitem">
                <span class="expect-step__n" aria-hidden="true">2</span>
                <div class="expect-step__body">
                  <p class="expect-step__title">
                    {isDE ? 'Ich hinterfrage die Problemdefinition selbst' : 'I question the problem definition itself'}
                  </p>
                  <p class="expect-step__desc">
                    {isDE
                      ? 'Meistens enthält das Framing des Problems die Annahme, die es tatsächlich verursacht. Das ist es, wonach ich suche.'
                      : 'Most of the time, the framing of the problem contains the assumption that\'s actually causing it. That\'s what I\'m looking for.'
                    }
                  </p>
                </div>
              </div>
              <div class="expect-step" role="listitem">
                <span class="expect-step__n" aria-hidden="true">3</span>
                <div class="expect-step__body">
                  <p class="expect-step__title">
                    {isDE ? 'Wir entscheiden, ob wir weitermachen' : 'We determine whether to go further'}
                  </p>
                  <p class="expect-step__desc">
                    {isDE
                      ? 'Wenn es etwas gibt, das es wert ist zu verfolgen, sage ich direkt, wie das aussieht. Wenn nicht, sage ich das auch.'
                      : 'If there\'s something worth pursuing, I\'ll be direct about what that looks like. If not, I\'ll tell you that too.'
                    }
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Sidebar -->
        <aside class="contact-sidebar" aria-label={isDE ? 'Kontaktinformationen' : 'Contact information'}>

          <!-- Fit card -->
          <div class="fit-card fade-up">
            <div class="fit-card__header">
              <p class="fit-card__label">{isDE ? 'Passt / Passt nicht' : 'Good fit / not a fit'}</p>
              <p class="fit-card__heading">
                {isDE ? 'Bevor Sie buchen, ein nützlicher Filter.' : 'Before you book, a useful filter.'}
              </p>
            </div>
            <ul>
              <li class="fit-item">
                <span class="fit-icon fit-icon--yes" aria-label={isDE ? 'Gut geeignet' : 'Good fit'}>✓</span>
                {isDE ? 'Sie vermuten, das eigentliche Problem ist ein anderes als das stated' : 'You suspect the real problem is different from the stated one'}
              </li>
              <li class="fit-item">
                <span class="fit-icon fit-icon--yes" aria-label={isDE ? 'Gut geeignet' : 'Good fit'}>✓</span>
                {isDE ? 'Sie wollen Widerspruch, keine Bestätigung' : 'You want disagreement, not validation'}
              </li>
              <li class="fit-item">
                <span class="fit-icon fit-icon--yes" aria-label={isDE ? 'Gut geeignet' : 'Good fit'}>✓</span>
                {isDE ? 'Sie sind Entscheidungsträger mit Handlungsbefugnis' : 'You\'re a decision-maker with authority to act on what you find'}
              </li>
              <li class="fit-item">
                <span class="fit-icon fit-icon--yes" aria-label={isDE ? 'Gut geeignet' : 'Good fit'}>✓</span>
                {isDE ? 'Sie haben die konventionellen Ansätze bereits ausprobiert' : 'You\'ve already tried the conventional approaches'}
              </li>
              <li class="fit-item">
                <span class="fit-icon fit-icon--no" aria-label={isDE ? 'Nicht geeignet' : 'Not a fit'}>✗</span>
                {isDE ? 'Sie suchen Implementierungsunterstützung oder Projektmanagement' : 'You\'re looking for implementation support or project management'}
              </li>
              <li class="fit-item">
                <span class="fit-icon fit-icon--no" aria-label={isDE ? 'Nicht geeignet' : 'Not a fit'}>✗</span>
                {isDE ? 'Sie brauchen jemanden, der eine bereits getroffene Entscheidung bestätigt' : 'You need someone to confirm a decision already made'}
              </li>
            </ul>
          </div>

          <!-- Alt contact -->
          <div class="alt-card fade-up" aria-labelledby="alt-heading">
            <p class="alt-card__header" id="alt-heading">
              {isDE ? 'Andere Wege, mich zu erreichen' : 'Other ways to reach me'}
            </p>
            <ul>
              <li>
                <a href="mailto:hello@andredaus.com" class="alt-item">
                  <span class="alt-item__icon" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="2" y="4" width="20" height="16" rx="2"/>
                      <path d="m2 7 10 7 10-7"/>
                    </svg>
                  </span>
                  <div>
                    <span class="alt-item__label">hello@andredaus.com</span>
                    <span class="alt-item__sub">{isDE ? 'Für längere oder komplexe Anfragen' : 'For longer or complex enquiries'}</span>
                  </div>
                </a>
              </li>
              <li>
                <a href="https://linkedin.com/in/andredaus" class="alt-item" target="_blank" rel="noopener noreferrer">
                  <span class="alt-item__icon" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 5 1036 990" fill="currentColor">
                      <path d="M0 120c0-33.334 11.667-60.834 35-82.5C58.333 15.833 88.667 5 126 5c36.667 0 66.333 10.666 89 32 23.333 22 35 50.666 35 86 0 32-11.333 58.666-34 80-23.333 22-54 33-92 33h-1c-36.667 0-66.333-11-89-33S0 153.333 0 120zm13 875V327h222v668H13zm345 0h222V622c0-23.334 2.667-41.334 8-54 9.333-22.667 23.5-41.834 42.5-57.5 19-15.667 42.833-23.5 71.5-23.5 74.667 0 112 50.333 112 151v357h222V612c0-98.667-23.333-173.5-70-224.5S857.667 311 781 311c-86 0-153 37-201 111v2h-1l1-2v-95H358c1.333 21.333 2 87.666 2 199 0 111.333-.667 267.666-2 469z"/>
                    </svg>
                  </span>
                  <div>
                    <span class="alt-item__label">LinkedIn DM<span class="sr-only"> {isDE ? '(öffnet neues Tab)' : '(opens in new tab)'}</span></span>
                    <span class="alt-item__sub">{isDE ? 'Meist schneller für kurze Fragen' : 'Usually faster for short questions'}</span>
                  </div>
                </a>
              </li>
            </ul>
          </div>

          <!-- Response note -->
          <div class="response-note fade-up" role="note">
            <span class="response-note__icon" aria-hidden="true">◎</span>
            <p class="response-note__text">
              <strong>{isDE ? 'Antwortzeit:' : 'Response time:'}</strong>
              {isDE
                ? ' Ich antworte auf jede Nachricht innerhalb von 1–2 Werktagen. Wenn Sie nach 3 Tagen nichts gehört haben, prüfen Sie Ihren Spam-Ordner und versuchen Sie es über LinkedIn.'
                : ' I respond to every message within 1–2 business days. If you haven\'t heard back in 3 days, check spam and try LinkedIn.'
              }
            </p>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ STRIP -->
  <section class="faq-strip" aria-labelledby="faq-heading">
    <div class="container">
      <div class="faq-strip__inner">
        <div>
          <p class="label">{isDE ? 'Bevor Sie fragen' : 'Before you ask'}</p>
          <h2 class="faq-intro-heading" id="faq-heading">
            {isDE ? 'Häufige Fragen zur Zusammenarbeit' : 'Common questions about working together'}
          </h2>
          <p class="faq-intro-body">
            {isDE
              ? 'Wenn Ihre Frage nicht dabei ist, stellen Sie sie einfach im Gespräch oder per E-Mail.'
              : 'If your question isn\'t here, just ask it in the call or by email.'
            }
          </p>
        </div>

        <div class="faq-list" role="list">
          {contactFaqs.map((faq, i) => {
            const btnId = `cfaq${i + 1}-btn`;
            const panelId = `cfaq${i + 1}`;
            return (
              <div class="faq-item" role="listitem">
                <button class="faq-btn" aria-expanded="false" aria-controls={panelId} id={btnId}>
                  {faq.data.question}
                  <svg class="faq-chevron" width="14" height="8" viewBox="0 0 14 8" fill="none" aria-hidden="true">
                    <path d="M1 1l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <div class="faq-panel" id={panelId} role="region" aria-labelledby={btnId}>
                  <p>{faq.data.answer}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

</Base>

{calcomUsername && (
  <script define:vars={{ calcomUsername }}>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement('script')).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === 'string') {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ['initNamespace', namespace]);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, 'https://app.cal.com/embed/embed.js', 'init');

    Cal('init', 'discovery-call', { origin: 'https://cal.com' });
    Cal.ns['discovery-call']('inline', {
      elementOrSelector: '#cal-booking',
      calLink: `${calcomUsername}/discovery-call`,
      layout: 'month_view',
    });
    Cal.ns['discovery-call']('ui', {
      styles: { branding: { brandColor: '#c49a3c' } },
      hideEventTypeDetails: true,
      layout: 'month_view',
      theme: 'dark',
      useSlotsViewOnSmallScreen: 'true',
      cssVarsPerTheme: {light:{'cal-brand':'#cd0202'},dark:{'cal-brand':'#c49a3c', 'cal-bg': '#090c14','cal-bg-muted': '#0f1520'}}
    });
  </script>
)}

<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .contact-hero {
    padding-top: 68px;
    background: linear-gradient(160deg, var(--bg-surface) 0%, var(--bg-base) 55%);
    border-bottom: 1px solid var(--border-light);
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(196,154,60,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196,154,60,.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
    pointer-events: none;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: end;
    padding-block: clamp(4rem, 8vw, 6.5rem) clamp(3rem, 5vw, 4rem);
  }

  .contact-hero__heading {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 5.5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -.03em;
    color: var(--text-primary);
    margin-top: 1.5rem;
  }
  .contact-hero__heading em { font-style: italic; color: var(--gold); }

  .contact-hero__sub {
    font-size: clamp(1rem, 1.3vw, 1.1rem);
    color: var(--text-secondary);
    line-height: 1.85;
    margin-top: 1.25rem;
    max-width: 48ch;
  }

  /* Reach aside */
  .reach-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-self: end;
  }

  .reach-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color .2s ease, background .2s ease;
  }
  .reach-card:hover {
    border-color: rgba(196,154,60,.25);
    background: var(--bg-elevated);
  }

  .reach-card__icon {
    width: 40px;
    height: 40px;
    border-radius: 3px;
    background: var(--gold-trans);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }

  .reach-card__label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 3px;
  }

  .reach-card__value {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
    transition: color .2s ease;
  }
  .reach-card:hover .reach-card__value { color: var(--gold-light); }

  @media (max-width: 820px) {
    .contact-hero__inner { grid-template-columns: 1fr; gap: 3rem; }
    .reach-aside { display: grid; grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .reach-aside { grid-template-columns: 1fr; }
  }

  /* ── CONTACT MAIN ─────────────────────────────────────── */
  .contact-main { padding-block: var(--section); }

  .contact-main__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 5rem;
    align-items: start;
  }

  .booking-heading {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
    margin-top: 1.25rem;
    margin-bottom: 1rem;
  }

  .booking-body {
    font-size: 15px;
    line-height: 1.85;
    color: var(--text-secondary);
    max-width: 52ch;
    margin-bottom: 2rem;
  }
  .booking-body p + p { margin-top: .875rem; }

  /* Booking block (Cal.com placeholder) */
  .booking-block {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-top: 2px solid var(--gold-dim);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 2rem;
  }

  .booking-block__header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .booking-block__title {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
