---
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const policies = [
  {
    href: `${prefix}/policy/privacy`,
    title: isDE ? 'Datenschutzerklärung' : 'Privacy Policy',
    desc: isDE
      ? 'Welche personenbezogenen Daten wir verarbeiten, auf welcher Grundlage und wie lange.'
      : 'What personal data we process, on what basis, and for how long.',
    meta: isDE ? 'DSGVO · BDSG · Schweizer DSG' : 'GDPR · BDSG · Swiss DSG',
  },
  {
    href: `${prefix}/policy/legal-notice`,
    title: isDE ? 'Impressum' : 'Legal Notice',
    desc: isDE
      ? 'Pflichtangaben gemäß § 5 TMG — Verantwortlicher, Kontaktdaten, Berufsrecht.'
      : 'Mandatory disclosures under § 5 TMG — controller, contact details, professional regulations.',
    meta: isDE ? '§ 5 TMG · § 55 RStV' : '§ 5 TMG · § 55 RStV',
  },
  {
    href: `${prefix}/policy/terms`,
    title: isDE ? 'Allgemeine Geschäftsbedingungen' : 'Terms & Conditions',
    desc: isDE
      ? 'Allgemeine Bedingungen für die Erbringung von Beratungs- und Coaching-Leistungen.'
      : 'General terms governing the provision of consulting and coaching services.',
    meta: isDE ? 'BGB · HGB' : 'BGB · HGB',
  },
  {
    href: `${prefix}/policy/ai-use`,
    title: isDE ? 'KI-Nutzungsrichtlinie' : 'AI Use Policy',
    desc: isDE
      ? 'Wie und wo KI-Werkzeuge in unserer Arbeit eingesetzt werden und welche Datenschutzgarantien gelten.'
      : 'How and where AI tools are used in our work and what data protection safeguards apply.',
    meta: isDE ? 'DSGVO · EU AI Act' : 'GDPR · EU AI Act',
  },
];
---

<Base
  title={isDE ? 'Rechtliches — André Daus' : 'Legal — André Daus'}
  description={isDE
    ? 'Datenschutzerklärung, Impressum, AGB und KI-Richtlinie für andredaus.com.'
    : 'Privacy Policy, Legal Notice, Terms & Conditions, and AI Use Policy for andredaus.com.'}
  lang={isDE ? 'de' : 'en'}
>

  <section class="policy-index" aria-labelledby="policy-index-heading">
    <div class="container">

      <header class="policy-index__header">
        <p class="label">{isDE ? 'Rechtliches' : 'Legal'}</p>
        <h1 class="policy-index__heading" id="policy-index-heading">
          {isDE ? 'Transparenz,<br /><em>keine Überraschungen.</em>' : 'Transparency,<br /><em>no surprises.</em>'}
        </h1>
        <p class="policy-index__sub">
          {isDE
            ? 'Alle rechtlichen Dokumente für andredaus.com an einem Ort.'
            : 'All legal documents for andredaus.com in one place.'
          }
        </p>
      </header>

      <ul class="policy-cards" role="list">
        {policies.map(p => (
          <li role="listitem">
            <a href={p.href} class="policy-card">
              <div class="policy-card__top">
                <h2 class="policy-card__title">{p.title}</h2>
                <span class="policy-card__arrow" aria-hidden="true">→</span>
              </div>
              <p class="policy-card__desc">{p.desc}</p>
              <span class="policy-card__meta">{p.meta}</span>
            </a>
          </li>
        ))}
      </ul>

    </div>
  </section>

</Base>

<style>
  .policy-index {
    padding-top: calc(68px + var(--section));
    padding-bottom: var(--section);
    min-height: 80vh;
  }

  .policy-index__header {
    max-width: 560px;
    margin-bottom: 3.5rem;
  }

  .policy-index__heading {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text-primary);
    margin-top: 1.25rem;
    margin-bottom: 1rem;
  }
  .policy-index__heading em { font-style: italic; color: var(--gold); }

  .policy-index__sub {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .policy-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    list-style: none;
  }

  .policy-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-top: 2px solid var(--gold-dim);
    border-radius: 3px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: border-top-color .2s ease, background .2s ease;
    height: 100%;
  }
  .policy-card:hover {
    border-top-color: var(--gold);
    background: var(--bg-card);
  }

  .policy-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .policy-card__title {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .policy-card__arrow {
    font-size: 16px;
    color: var(--gold);
    flex-shrink: 0;
    transition: transform .2s ease;
  }
  .policy-card:hover .policy-card__arrow { transform: translateX(4px); }

  .policy-card__desc {
    font-size: 14px;
    line-height: 1.75;
    color: var(--text-secondary);
    flex: 1;
  }

  .policy-card__meta {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-top: auto;
  }

  @media (max-width: 640px) {
    .policy-cards { grid-template-columns: 1fr; }
  }
</style>
