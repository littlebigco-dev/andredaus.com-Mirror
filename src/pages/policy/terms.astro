---
import Base from '../../layouts/Base.astro';
import rawTerms from '../../data/terms.html?raw';

const lastUpdated = '28 March 2026';
const termsHtml = rawTerms;
---

<Base
  title="General Terms &amp; Conditions — André Daus"
  description="General Terms and Conditions with Customer Information for André Daus Consulting services."
  lang="en"
>

  <!-- HERO -->
  <header class="policy-hero" aria-labelledby="policy-title">
    <div class="container">
      <div class="policy-hero__inner">
        <div>
          <p class="policy-hero__type">Legal · Terms</p>
          <h1 class="policy-hero__title" id="policy-title">General Terms &amp; Conditions</h1>
        </div>
        <aside class="policy-meta" aria-label="Document information">
          <div class="policy-meta__row">
            <span class="policy-meta__key">Effective</span>
            <span class="policy-meta__val policy-meta__val--updated">{lastUpdated}</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Provider</span>
            <span class="policy-meta__val">André Daus Consulting</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Applies to</span>
            <span class="policy-meta__val">All Services (B2B)</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Jurisdiction</span>
            <span class="policy-meta__val">Germany · German law</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <!-- Mobile meta strip -->
  <div class="meta-strip" aria-label="Document info">
    <span>Effective: {lastUpdated}</span>
    <span class="meta-strip__sep" aria-hidden="true">·</span>
    <span>B2B · German law</span>
  </div>

  <!-- Policy nav strip -->
  <nav class="policy-nav-strip" aria-label="Other legal documents">
    <div class="container">
      <div class="policy-nav-strip__inner" role="list">
        <a href="/policy/privacy"       class="policy-nav-link" role="listitem">Privacy Policy</a>
        <a href="/policy/legal-notice"  class="policy-nav-link" role="listitem">Legal Notice</a>
        <a href="/policy/terms"         class="policy-nav-link is-active" role="listitem" aria-current="page">Terms</a>
        <a href="/policy/ai-use"        class="policy-nav-link" role="listitem">AI Policy</a>
      </div>
    </div>
  </nav>

  <!-- Main layout: TOC + content -->
  <div class="container">
    <div class="policy-layout">

      <!-- TOC Sidebar -->
      <aside class="toc-sidebar" aria-label="Table of contents">
        <nav class="toc-card" aria-labelledby="toc-heading">
          <p class="toc-card__heading" id="toc-heading">Contents</p>
          <ul class="toc__list" aria-label="Jump to section">
            <li><a href="#m2954"  class="toc__link is-active">1. Validity</a></li>
            <li><a href="#m2983"  class="toc__link">2. Contact &amp; service</a></li>
            <li><a href="#m3056"  class="toc__link">3. Ordering process</a></li>
            <li><a href="#m3073"  class="toc__link">4. Contract language</a></li>
            <li><a href="#m3175"  class="toc__link">6. Digital contents</a></li>
            <li><a href="#m2347"  class="toc__link">10. Service obligations</a></li>
            <li><a href="#m6042"  class="toc__link">11. Coaching services</a></li>
            <li><a href="#m4567"  class="toc__link">13. Duration &amp; termination</a></li>
            <li><a href="#m3027"  class="toc__link">18. Prices</a></li>
            <li><a href="#m3028"  class="toc__link">19. Payment methods</a></li>
            <li><a href="#m2975"  class="toc__link">21. Copyright</a></li>
            <li><a href="#m3163"  class="toc__link">22. Withdrawal</a></li>
            <li><a href="#m3117"  class="toc__link">23. Warranty &amp; liability</a></li>
            <li><a href="#m3973"  class="toc__link">25. Data protection</a></li>
            <li><a href="#m2981"  class="toc__link">26. Final provisions</a></li>
          </ul>
        </nav>

        <div class="sidebar-contact">
          <p class="sidebar-contact__heading">Questions?</p>
          <p class="sidebar-contact__body">For enquiries about these terms, contact us directly.</p>
          <a href="mailto:hello@andredaus.com" class="sidebar-contact__link">hello@andredaus.com</a>
        </div>
      </aside>

      <!-- Policy content -->
      <article class="policy-body" aria-label="Terms and Conditions content" set:html={termsHtml} />

    </div>
  </div>

</Base>

<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .policy-hero {
    padding-top: calc(68px + clamp(3rem, 6vw, 5rem));
    padding-bottom: clamp(3rem, 6vw, 5rem);
    background: linear-gradient(160deg, var(--bg-surface) 0%, var(--bg-base) 60%);
    border-bottom: 1px solid var(--border-light);
  }

  .policy-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
  }

  .policy-hero__type {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .875rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .policy-hero__type::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .policy-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -.025em;
    color: var(--text-primary);
  }

  .policy-meta {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .875rem;
    align-self: end;
    min-width: 220px;
  }
  .policy-meta__row { display: flex; flex-direction: column; gap: 2px; }
  .policy-meta__key {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }
  .policy-meta__val {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .policy-meta__val--updated {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gold);
  }

  @media (max-width: 640px) {
    .policy-hero__inner { grid-template-columns: 1fr; }
    .policy-meta { display: none; }
  }

  /* Mobile meta strip */
  .meta-strip {
    display: none;
    background: var(--bg-card-alt);
    border-bottom: 1px solid var(--border-light);
    padding: .75rem var(--gutter);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    color: var(--text-subtle);
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .meta-strip__sep { color: var(--border-light); user-select: none; }
  @media (max-width: 640px) { .meta-strip { display: flex; } }

  /* ── POLICY NAV STRIP ─────────────────────────────────── */
  .policy-nav-strip {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-light);
  }
  .policy-nav-strip__inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .policy-nav-strip__inner::-webkit-scrollbar { display: none; }

  .policy-nav-link {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .875rem 1.25rem;
    color: var(--text-subtle);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all .15s ease;
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .policy-nav-link:hover { color: var(--text-secondary); }
  .policy-nav-link.is-active { color: var(--gold); border-bottom-color: var(--gold); }

  /* ── LAYOUT ───────────────────────────────────────────── */
  .policy-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 4rem;
    padding-block: var(--section);
    align-items: start;
  }
  @media (max-width: 900px) { .policy-layout { grid-template-columns: 1fr; } }

  /* ── TOC SIDEBAR ──────────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: calc(68px + 2rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-light) transparent;
  }
  .toc-sidebar::-webkit-scrollbar { width: 3px; }
  .toc-sidebar::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 2px; }

  .toc-card {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
  }
  .toc-card__heading {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    padding: .875rem 1.25rem;
    border-bottom: 1px solid var(--border-light);
  }
  .toc__list { padding: .375rem 0; list-style: none; }
  .toc__link {
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-secondary);
    padding: .5rem 1.25rem;
    display: block;
    border-left: 2px solid transparent;
    transition: all .15s ease;
    text-decoration: none;
  }
  .toc__link:hover { color: var(--text-primary); background: var(--gold-trans); }
  .toc__link.is-active { color: var(--gold); border-left-color: var(--gold); background: var(--gold-trans); }

  .sidebar-contact {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .sidebar-contact__heading {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .sidebar-contact__body { font-size: 12px; line-height: 1.7; color: var(--text-secondary); }
  .sidebar-contact__link {
    font-size: 12px;
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: block;
    padding-block: 2px;
  }
  .sidebar-contact__link:hover { color: var(--gold-light); }

  @media (max-width: 900px) { .toc-sidebar { display: none; } }

  /* ── POLICY BODY ──────────────────────────────────────── */
  .policy-body { min-width: 0; }
</style>

<style is:global>
  /* ── POLICY BODY CONTENT ──────────────────────────────────
     set:html injects HTML without Astro's scoping attribute,
     so these must be global selectors.                        */
  .policy-body [id] { scroll-margin-top: 90px; }

  .policy-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    padding-bottom: .875rem;
    border-bottom: 1px solid var(--border-light);
  }
  .policy-body h2:first-child { margin-top: 0; }

  .policy-body h3 {
    font-family: var(--sans);
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin-top: 2.25rem;
    margin-bottom: .75rem;
  }

  .policy-body h4 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 1.75rem;
    margin-bottom: .625rem;
  }

  .policy-body p {
    font-size: clamp(14px, 1.05vw, 15.5px);
    line-height: 1.9;
    color: var(--text-secondary);
    margin-bottom: 1.1rem;
  }
  .policy-body p:last-child { margin-bottom: 0; }
  .policy-body p strong { color: var(--text-primary); font-weight: 600; }

  .policy-body a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .policy-body a:hover { color: var(--gold-light); }

  /* All li elements — inside ul or bare (GTC uses bare <li> without <ul> wrapper) */
  .policy-body li {
    padding-left: 1.25rem;
    position: relative;
    font-size: clamp(14px, 1.05vw, 15.5px);
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: .375rem;
    display: block;
  }
  .policy-body li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--gold-dim);
  }
  .policy-body ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .policy-body ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .policy-body ol li {
    padding-left: .25rem;
  }
  .policy-body ol li::before { display: none; }
  .policy-body li strong { color: var(--text-primary); font-weight: 600; }

  /* Dr. Schwenke seal */
  .policy-body .seal { margin-block: 2rem; }
  .policy-body .seal img {
    width: 120px;
    height: auto;
    opacity: 0.7;
    filter: grayscale(0.3);
  }
</style>

<script>
  // TOC active section tracking — watch h2 headings with IDs
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
  const headings = document.querySelectorAll<HTMLElement>('.policy-body h2[id]');

  if (headings.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('is-active'));
            const active = document.querySelector<HTMLAnchorElement>(`.toc__link[href="#${entry.target.id}"]`);
            active?.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-68px 0px -60% 0px', threshold: 0 }
    );
    headings.forEach(h => observer.observe(h));
  }
</script>
