---
import Base from '../../layouts/Base.astro';
import rawPrivacy from '../../data/privacy-policy.html?raw';

const lastUpdated = '9 May 2026';
const privacyHtml = rawPrivacy;
---

<Base
  title="Privacy Policy — André Daus"
  description="Privacy Policy in accordance with GDPR, BDSG and Swiss DSG for andredaus.com."
  lang="en"
>

  <!-- HERO -->
  <header class="policy-hero" aria-labelledby="policy-title">
    <div class="container">
      <div class="policy-hero__inner">
        <div>
          <p class="policy-hero__type">Legal · Privacy</p>
          <h1 class="policy-hero__title" id="policy-title">Privacy Policy</h1>
        </div>
        <aside class="policy-meta" aria-label="Document information">
          <div class="policy-meta__row">
            <span class="policy-meta__key">Last updated</span>
            <span class="policy-meta__val policy-meta__val--updated">{lastUpdated}</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Controller</span>
            <span class="policy-meta__val">André Daus, Cologne DE</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Applies to</span>
            <span class="policy-meta__val">andredaus.com</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Framework</span>
            <span class="policy-meta__val">GDPR · BDSG · Swiss DSG</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <!-- Mobile meta strip -->
  <div class="meta-strip" aria-label="Document info">
    <span>Updated: {lastUpdated}</span>
    <span class="meta-strip__sep" aria-hidden="true">·</span>
    <span>GDPR · BDSG · Swiss DSG</span>
  </div>

  <!-- Policy nav strip -->
  <nav class="policy-nav-strip" aria-label="Other legal documents">
    <div class="container">
      <div class="policy-nav-strip__inner" role="list">
        <a href="/policy/privacy"       class="policy-nav-link is-active" role="listitem" aria-current="page">Privacy Policy</a>
        <a href="/policy/legal-notice"  class="policy-nav-link" role="listitem">Legal Notice</a>
        <a href="/policy/terms"         class="policy-nav-link" role="listitem">Terms</a>
        <a href="/policy/ai-use"        class="policy-nav-link" role="listitem">AI Policy</a>
      </div>
    </div>
  </nav>

  <!-- Main layout: TOC + content -->
  <div class="container">
    <div class="policy-layout">

      <!-- TOC Sidebar -->
      <aside class="toc-sidebar" aria-label="Table of contents">
        <nav class="toc-card" aria-labelledby="toc-heading">
          <p class="toc-card__heading" id="toc-heading">Contents</p>
          <ul class="toc__list" aria-label="Jump to section">
            <li><a href="#m716"      class="toc__link is-active">Preamble</a></li>
            <li><a href="#m3"        class="toc__link">Controller</a></li>
            <li><a href="#mOverview" class="toc__link">Overview</a></li>
            <li><a href="#m2427"     class="toc__link">Legal bases</a></li>
            <li><a href="#m27"       class="toc__link">Security</a></li>
            <li><a href="#m24"       class="toc__link">International transfers</a></li>
            <li><a href="#m12"       class="toc__link">Data retention</a></li>
            <li><a href="#m10"       class="toc__link">Your rights</a></li>
            <li><a href="#m317"      class="toc__link">Business services</a></li>
            <li><a href="#m225"      class="toc__link">Hosting &amp; online</a></li>
            <li><a href="#m134"      class="toc__link">Cookies</a></li>
            <li><a href="#m182"      class="toc__link">Contact &amp; enquiries</a></li>
            <li><a href="#m2555"     class="toc__link">Artificial intelligence</a></li>
            <li><a href="#m17"       class="toc__link">Newsletter</a></li>
            <li><a href="#m263"      class="toc__link">Analytics</a></li>
            <li><a href="#m136"      class="toc__link">Social media</a></li>
            <li><a href="#m15"       class="toc__link">Changes &amp; updates</a></li>
            <li><a href="#m42"       class="toc__link">Definitions</a></li>
          </ul>
        </nav>

        <div class="sidebar-contact">
          <p class="sidebar-contact__heading">Questions?</p>
          <p class="sidebar-contact__body">For data protection enquiries, contact us directly.</p>
          <a href="mailto:hello@andredaus.com" class="sidebar-contact__link">hello@andredaus.com</a>
        </div>
      </aside>

      <!-- Policy content -->
      <article class="policy-body" aria-label="Privacy Policy content" set:html={privacyHtml} />

    </div>
  </div>

</Base>

<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .policy-hero {
    padding-top: calc(68px + clamp(3rem, 6vw, 5rem));
    padding-bottom: clamp(3rem, 6vw, 5rem);
    background: linear-gradient(160deg, var(--bg-surface) 0%, var(--bg-base) 60%);
    border-bottom: 1px solid var(--border-light);
  }

  .policy-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
  }

  .policy-hero__type {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .875rem;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .policy-hero__type::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--gold);
  }

  .policy-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -.025em;
    color: var(--text-primary);
  }

  .policy-meta {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .875rem;
    align-self: end;
    min-width: 220px;
  }
  .policy-meta__row { display: flex; flex-direction: column; gap: 2px; }
  .policy-meta__key {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }
  .policy-meta__val {
    font-size: 13px;
    color: var(--text-secondary);
  }
  .policy-meta__val--updated {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--gold);
  }

  @media (max-width: 640px) {
    .policy-hero__inner { grid-template-columns: 1fr; }
    .policy-meta { display: none; }
  }

  /* Mobile meta strip */
  .meta-strip {
    display: none;
    background: var(--bg-card-alt);
    border-bottom: 1px solid var(--border-light);
    padding: .75rem var(--gutter);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    color: var(--text-subtle);
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .meta-strip__sep { color: var(--border-light); user-select: none; }
  @media (max-width: 640px) { .meta-strip { display: flex; } }

  /* ── POLICY NAV STRIP ─────────────────────────────────── */
  .policy-nav-strip {
    background: var(--bg-elevated);
    border-bottom: 1px solid var(--border-light);
  }
  .policy-nav-strip__inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .policy-nav-strip__inner::-webkit-scrollbar { display: none; }

  .policy-nav-link {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .875rem 1.25rem;
    color: var(--text-subtle);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all .15s ease;
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .policy-nav-link:hover { color: var(--text-secondary); }
  .policy-nav-link.is-active { color: var(--gold); border-bottom-color: var(--gold); }

  /* ── LAYOUT ───────────────────────────────────────────── */
  .policy-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 4rem;
    padding-block: var(--section);
    align-items: start;
  }
  @media (max-width: 900px) { .policy-layout { grid-template-columns: 1fr; } }

  /* ── TOC SIDEBAR ──────────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: calc(68px + 2rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-light) transparent;
  }
  .toc-sidebar::-webkit-scrollbar { width: 3px; }
  .toc-sidebar::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 2px; }

  .toc-card {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
  }
  .toc-card__heading {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
    padding: .875rem 1.25rem;
    border-bottom: 1px solid var(--border-light);
  }
  .toc__list { padding: .375rem 0; list-style: none; }
  .toc__link {
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-secondary);
    padding: .5rem 1.25rem;
    display: block;
    border-left: 2px solid transparent;
    transition: all .15s ease;
    text-decoration: none;
  }
  .toc__link:hover { color: var(--text-primary); background: var(--gold-trans); }
  .toc__link.is-active { color: var(--gold); border-left-color: var(--gold); background: var(--gold-trans); }

  .sidebar-contact {
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }
  .sidebar-contact__heading {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .sidebar-contact__body { font-size: 12px; line-height: 1.7; color: var(--text-secondary); }
  .sidebar-contact__link {
    font-size: 12px;
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: block;
    padding-block: 2px;
  }
  .sidebar-contact__link:hover { color: var(--gold-light); }

  @media (max-width: 900px) { .toc-sidebar { display: none; } }

  /* ── POLICY BODY (container only) ────────────────────── */
  .policy-body { min-width: 0; }
</style>

<style is:global>
  /* ── POLICY BODY CONTENT ──────────────────────────────────
     set:html injects HTML that won't receive Astro's scoping
     attribute, so these must be global selectors.             */
  .policy-body [id] { scroll-margin-top: 90px; }

  .policy-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--text-primary);
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    padding-bottom: .875rem;
    border-bottom: 1px solid var(--border-light);
  }
  .policy-body h2:first-child { margin-top: 0; }

  .policy-body h3 {
    font-family: var(--sans);
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin-top: 2.25rem;
    margin-bottom: .75rem;
  }

  .policy-body h4 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-top: 1.75rem;
    margin-bottom: .625rem;
  }

  .policy-body p {
    font-size: clamp(14px, 1.05vw, 15.5px);
    line-height: 1.9;
    color: var(--text-secondary);
    margin-bottom: 1.1rem;
  }
  .policy-body p:last-child { margin-bottom: 0; }
  .policy-body p strong { color: var(--text-primary); font-weight: 600; }

  .policy-body a {
    color: var(--gold);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .policy-body a:hover { color: var(--gold-light); }

  .policy-body ul {
    list-style: none;
    padding-left: 0;
    margin-bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .policy-body ul li {
    padding-left: 1.25rem;
    position: relative;
    font-size: clamp(14px, 1.05vw, 15.5px);
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .policy-body ul li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--gold-dim);
  }
  .policy-body ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .policy-body ol li {
    font-size: clamp(14px, 1.05vw, 15.5px);
    line-height: 1.8;
    color: var(--text-secondary);
    padding-left: .25rem;
  }
  .policy-body li strong { color: var(--text-primary); font-weight: 600; }

  /* ── LAWYER-SPECIFIC CLASSES ──────────────────────────── */

  /* Primary structured data card: <dl class="m-elements"> */
  .policy-body .m-elements {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.5rem;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
  }
  .policy-body .m-elements > dt {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: .75rem 1.25rem .2rem;
    font-weight: 400;
    margin-bottom: 0;
  }
  .policy-body .m-elements > dt:not(:first-child) {
    border-top: 1px solid var(--border-light);
    padding-top: .875rem;
  }
  .policy-body .m-elements > dd {
    font-size: clamp(13px, 1vw, 14.5px);
    line-height: 1.75;
    color: var(--text-secondary);
    padding: 0 1.25rem .75rem;
    border-left: none;
    margin-left: 0;
  }

  /* Provider info block nested inside m-elements: <dl class="provider-meta"> */
  .policy-body .provider-meta {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: .625rem;
    border: 1px solid var(--border-light);
    border-radius: 2px;
    background: var(--bg-elevated);
    overflow: hidden;
  }
  .policy-body .provider-meta > dt {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: .5rem 1rem .125rem;
    font-weight: 400;
    margin-bottom: 0;
  }
  .policy-body .provider-meta > dt:not(:first-child) {
    border-top: 1px solid var(--border-light);
    padding-top: .625rem;
  }
  .policy-body .provider-meta > dd {
    font-size: 12px;
    line-height: 1.7;
    color: var(--text-secondary);
    padding: 0 1rem .5rem;
    border-left: none;
    margin-left: 0;
  }

  /* Transfer basis nested inside provider-meta: <dl class="transfer-basis"> */
  .policy-body .transfer-basis {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: .5rem;
    padding: .5rem .75rem;
    background: var(--bg-base);
    border: 1px solid var(--border-light);
    border-radius: 2px;
  }
  .policy-body .transfer-basis > dt {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--gold-dim);
    padding: 0;
    font-weight: 400;
    margin-bottom: .1rem;
  }
  .policy-body .transfer-basis > dt:not(:first-child) { margin-top: .375rem; }
  .policy-body .transfer-basis > dd {
    font-size: 11px;
    line-height: 1.65;
    color: var(--text-subtle);
    padding-left: .5rem;
    border-left: 1px solid var(--border-light);
    margin-left: 0;
  }

  /* Legal basis definitions: <dl class="legal-basis"> */
  .policy-body .legal-basis {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.5rem;
    background: var(--bg-card-alt);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    overflow: hidden;
  }
  .policy-body .legal-basis > dt {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    border-left: 2px solid var(--gold);
    padding: .75rem 1.25rem .25rem;
    margin-bottom: 0;
  }
  .policy-body .legal-basis > dt:not(:first-child) {
    border-top: 1px solid var(--border-light);
    padding-top: .75rem;
  }
  .policy-body .legal-basis > dd {
    font-size: 13px;
    line-height: 1.8;
    color: var(--text-secondary);
    padding: 0 1.25rem .75rem;
    border-left: none;
    margin-left: 0;
  }

  /* Rights and retention definition lists */
  .policy-body .rights,
  .policy-body .retention {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 1.5rem;
  }
  .policy-body .rights > dt,
  .policy-body .retention > dt {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: .25rem;
  }
  .policy-body .rights > dt:not(:first-child),
  .policy-body .retention > dt:not(:first-child) { margin-top: 1rem; }
  .policy-body .rights > dd,
  .policy-body .retention > dd {
    font-size: clamp(13px, 1vw, 14.5px);
    line-height: 1.75;
    color: var(--text-secondary);
    padding-left: 1rem;
    border-left: 2px solid var(--border-light);
    margin-left: 0;
    margin-bottom: 0;
  }

  /* No-break inline spans */
  .policy-body .no-break { white-space: nowrap; }

  /* Dr. Schwenke seal */
  .policy-body .seal { margin-block: 1.5rem; }
  .policy-body .seal img {
    width: 120px;
    height: auto;
    opacity: 0.7;
    filter: grayscale(0.3);
  }

  /* Glossary (definitions section) */
  .policy-body .glossary {
    list-style: none;
    padding-left: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .policy-body .glossary li {
    padding-left: 0;
    font-size: clamp(13px, 1vw, 14.5px);
    line-height: 1.8;
    color: var(--text-secondary);
  }
  .policy-body .glossary li::before { display: none; }
  .policy-body .glossary li strong {
    color: var(--text-primary);
    font-weight: 600;
    display: block;
    margin-bottom: .25rem;
  }
</style>

<script>
  // TOC active section tracking — watch h2 headings with IDs
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
  const headings = document.querySelectorAll<HTMLElement>('.policy-body h2[id]');

  if (headings.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('is-active'));
            const active = document.querySelector<HTMLAnchorElement>(`.toc__link[href="#${entry.target.id}"]`);
            active?.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-68px 0px -60% 0px', threshold: 0 }
    );
    headings.forEach(h => observer.observe(h));
  }
</script>
