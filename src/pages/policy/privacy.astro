---
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const lastUpdated = '25 May 2025';
---

<Base
  title={isDE ? 'Datenschutzerklärung — André Daus' : 'Privacy Policy — André Daus'}
  description={isDE
    ? 'Datenschutzerklärung gemäß DSGVO, BDSG und Schweizer DSG für andredaus.com.'
    : 'Privacy Policy in accordance with GDPR, BDSG and Swiss DSG for andredaus.com.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="policy-hero" aria-labelledby="policy-title">
    <div class="container">
      <div class="policy-hero__inner">
        <div>
          <p class="policy-hero__type">{isDE ? 'Rechtliches · Datenschutz' : 'Legal · Privacy'}</p>
          <h1 class="policy-hero__title" id="policy-title">
            {isDE ? 'Datenschutzerklärung' : 'Privacy Policy'}
          </h1>
        </div>
        <aside class="policy-meta" aria-label={isDE ? 'Dokumentinformationen' : 'Document information'}>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Zuletzt aktualisiert' : 'Last updated'}</span>
            <span class="policy-meta__val policy-meta__val--updated">{lastUpdated}</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Verantwortlicher' : 'Controller'}</span>
            <span class="policy-meta__val">André Daus, Cologne DE</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Gilt für' : 'Applies to'}</span>
            <span class="policy-meta__val">andredaus.com</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">Framework</span>
            <span class="policy-meta__val">GDPR · BDSG · Swiss DSG</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <!-- Mobile meta strip -->
  <div class="meta-strip" aria-label={isDE ? 'Dokumentinformationen' : 'Document info'}>
    <span>{isDE ? 'Aktualisiert' : 'Updated'}: {lastUpdated}</span>
    <span class="meta-strip__sep" aria-hidden="true">·</span>
    <span>GDPR · BDSG · Swiss DSG</span>
  </div>

  <!-- Policy nav strip -->
  <nav class="policy-nav-strip" aria-label={isDE ? 'Andere rechtliche Dokumente' : 'Other legal documents'}>
    <div class="container">
      <div class="policy-nav-strip__inner" role="list">
        <a href={`${prefix}/policy/privacy`}       class="policy-nav-link is-active" role="listitem" aria-current="page">{isDE ? 'Datenschutz' : 'Privacy Policy'}</a>
        <a href={`${prefix}/policy/legal-notice`}  class="policy-nav-link" role="listitem">{isDE ? 'Impressum' : 'Legal Notice'}</a>
        <a href={`${prefix}/policy/terms`}         class="policy-nav-link" role="listitem">{isDE ? 'AGB' : 'Terms'}</a>
        <a href={`${prefix}/policy/ai-use`}        class="policy-nav-link" role="listitem">{isDE ? 'KI-Richtlinie' : 'AI Policy'}</a>
      </div>
    </div>
  </nav>

  <!-- Main layout: TOC + content -->
  <div class="container">
    <div class="policy-layout">

      <!-- TOC Sidebar -->
      <aside class="toc-sidebar" aria-label={isDE ? 'Inhaltsverzeichnis' : 'Table of contents'}>
        <nav class="toc-card" aria-labelledby="toc-heading">
          <p class="toc-card__heading" id="toc-heading">{isDE ? 'Inhalt' : 'Contents'}</p>
          <ul class="toc__list" aria-label={isDE ? 'Zum Abschnitt springen' : 'Jump to section'}>
            <li><a href="#preamble"      class="toc__link is-active">{isDE ? 'Präambel' : 'Preamble'}</a></li>
            <li><a href="#controller"    class="toc__link">{isDE ? 'Verantwortlicher' : 'Controller'}</a></li>
            <li><a href="#overview"      class="toc__link">{isDE ? 'Verarbeitungsübersicht' : 'Overview of processing'}</a></li>
            <li><a href="#legal-bases"   class="toc__link">{isDE ? 'Rechtsgrundlagen' : 'Legal bases'}</a></li>
            <li><a href="#security"      class="toc__link">{isDE ? 'Sicherheit' : 'Security'}</a></li>
            <li><a href="#transmission"  class="toc__link">{isDE ? 'Datenweitergabe' : 'Data transmission'}</a></li>
            <li><a href="#international" class="toc__link">{isDE ? 'Internationaler Transfer' : 'International transfers'}</a></li>
            <li><a href="#retention"     class="toc__link">{isDE ? 'Speicherung &amp; Löschung' : 'Retention &amp; deletion'}</a></li>
            <li><a href="#rights"        class="toc__link">{isDE ? 'Ihre Rechte' : 'Your rights'}</a></li>
            <li><a href="#business"      class="toc__link">{isDE ? 'Geschäftliche Dienste' : 'Business services'}</a></li>
            <li><a href="#hosting"       class="toc__link">{isDE ? 'Hosting &amp; Online-Dienste' : 'Hosting &amp; online services'}</a></li>
            <li><a href="#cookies"       class="toc__link">Cookies</a></li>
            <li><a href="#contact"       class="toc__link">{isDE ? 'Kontakt &amp; Anfragen' : 'Contact &amp; enquiries'}</a></li>
            <li><a href="#newsletter"    class="toc__link">Newsletter</a></li>
            <li><a href="#analytics"     class="toc__link">{isDE ? 'Analyse' : 'Analytics'}</a></li>
            <li><a href="#social"        class="toc__link">{isDE ? 'Soziale Medien' : 'Social media'}</a></li>
            <li><a href="#ai"            class="toc__link">{isDE ? 'Künstliche Intelligenz' : 'Artificial intelligence'}</a></li>
            <li><a href="#changes"       class="toc__link">{isDE ? 'Änderungen' : 'Changes &amp; updates'}</a></li>
            <li><a href="#definitions"   class="toc__link">{isDE ? 'Begriffsbestimmungen' : 'Definitions'}</a></li>
          </ul>
        </nav>

        <div class="sidebar-contact">
          <p class="sidebar-contact__heading">{isDE ? 'Fragen?' : 'Questions?'}</p>
          <p class="sidebar-contact__body">{isDE ? 'Für Datenschutzanfragen kontaktieren Sie uns direkt.' : 'For data protection enquiries, contact us directly.'}</p>
          <a href="mailto:hello@andredaus.com" class="sidebar-contact__link">hello@andredaus.com</a>
        </div>
      </aside>

      <!-- Policy content -->
      <article class="policy-body" aria-label={isDE ? 'Inhalt der Datenschutzerklärung' : 'Privacy Policy content'}>

        <section id="preamble">
          <h2>{isDE ? 'Präambel' : 'Preamble'}</h2>
          <p>{isDE
            ? 'Mit der folgenden Datenschutzerklärung möchten wir Sie darüber aufklären, welche Arten Ihrer personenbezogenen Daten (nachfolgend auch kurz als "Daten" bezeichnet) wir zu welchen Zwecken und in welchem Umfang verarbeiten. Die Datenschutzerklärung gilt für alle von uns durchgeführten Verarbeitungen personenbezogener Daten, sowohl im Rahmen der Erbringung unserer Leistungen als auch insbesondere auf unseren Webseiten.'
            : 'With the following privacy policy we would like to inform you which types of your personal data (hereinafter also abbreviated as "data") we process for which purposes and in which scope. The privacy statement applies to all processing of personal data carried out by us, both in the context of providing our services and in particular on our websites, in mobile applications and within external online presences, such as our social media profiles (hereinafter collectively referred to as "online services").'
          }</p>
          <p>{isDE ? 'Die verwendeten Begriffe sind nicht geschlechtsspezifisch.' : 'The terms used are not gender-specific.'}</p>
          <p>Source: <a href="https://datenschutz-generator.de/" target="_blank" rel="noopener noreferrer">datenschutz-generator.de <span class="sr-only">{isDE ? '(öffnet neues Tab)' : '(opens in new tab)'}</span></a></p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="controller">
          <h2>{isDE ? 'Verantwortlicher' : 'Controller'}</h2>
          <p>
            André Daus<br />
            c/o Block Services<br />
            Stuttgarter Str. 106<br />
            70736 Fellbach<br />
            {isDE ? 'Deutschland' : 'Germany'}
          </p>
          <p>
            Email: <a href="mailto:hello@andredaus.com">hello@andredaus.com</a><br />
            {isDE ? 'Telefon' : 'Phone'}: <a href="tel:+492211653180">+49 (221) 1653180</a>
          </p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="overview">
          <h2>{isDE ? 'Übersicht der Verarbeitungen' : 'Overview of processing operations'}</h2>
          <p>{isDE
            ? 'Die nachfolgende Übersicht fasst die Arten der verarbeiteten Daten und die Zwecke ihrer Verarbeitung zusammen und verweist auf die betroffenen Personen.'
            : 'The following table summarises the types of data processed, the purposes for which they are processed and the concerned data subjects.'
          }</p>

          <h3>{isDE ? 'Arten der verarbeiteten Daten' : 'Categories of processed data'}</h3>
          <ul>
            <li>{isDE ? 'Bestandsdaten' : 'Inventory data'}</li>
            <li>{isDE ? 'Zahlungsdaten' : 'Payment data'}</li>
            <li>{isDE ? 'Kontaktdaten' : 'Contact data'}</li>
            <li>{isDE ? 'Inhaltsdaten' : 'Content data'}</li>
            <li>{isDE ? 'Vertragsdaten' : 'Contract data'}</li>
            <li>{isDE ? 'Nutzungsdaten' : 'Usage data'}</li>
            <li>{isDE ? 'Meta-, Kommunikations- und Verfahrensdaten' : 'Meta, communication and process data'}</li>
            <li>{isDE ? 'Protokolldaten' : 'Log data'}</li>
          </ul>

          <h3>{isDE ? 'Kategorien betroffener Personen' : 'Categories of data subjects'}</h3>
          <ul>
            <li>{isDE ? 'Leistungsempfänger und Auftraggeber' : 'Service recipients and clients'}</li>
            <li>{isDE ? 'Interessenten' : 'Prospective customers'}</li>
            <li>{isDE ? 'Kommunikationspartner' : 'Communication partners'}</li>
            <li>{isDE ? 'Nutzer' : 'Users'}</li>
            <li>{isDE ? 'Geschäfts- und Vertragspartner' : 'Business and contractual partners'}</li>
          </ul>

          <h3>{isDE ? 'Zwecke der Verarbeitung' : 'Purposes of processing'}</h3>
          <ul>
            <li>{isDE ? 'Erbringung vertraglicher Leistungen und Erfüllung vertraglicher Pflichten' : 'Provision of contractual services and fulfilment of contractual obligations'}</li>
            <li>{isDE ? 'Kommunikation' : 'Communication'}</li>
            <li>{isDE ? 'Sicherheitsmaßnahmen' : 'Security measures'}</li>
            <li>{isDE ? 'Direktmarketing' : 'Direct marketing'}</li>
            <li>{isDE ? 'Webanalyse' : 'Web analytics'}</li>
            <li>{isDE ? 'Büro- und Organisationsverfahren' : 'Office and organisational procedures'}</li>
            <li>{isDE ? 'Bereitstellung unserer Onlineangebote und Nutzerfreundlichkeit' : 'Provision of our online services and usability'}</li>
            <li>{isDE ? 'Informationstechnische Infrastruktur' : 'Information technology infrastructure'}</li>
            <li>{isDE ? 'Finanz- und Zahlungsmanagement' : 'Financial and payment management'}</li>
          </ul>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="legal-bases">
          <h2>{isDE ? 'Maßgebliche Rechtsgrundlagen' : 'Relevant legal bases'}</h2>

          <h3>{isDE ? 'Rechtsgrundlagen nach der DSGVO' : 'Legal bases according to the GDPR'}</h3>
          <p>{isDE
            ? 'Im Folgenden erhalten Sie eine Übersicht der Rechtsgrundlagen der DSGVO, auf deren Basis wir personenbezogene Daten verarbeiten. Bitte nehmen Sie zur Kenntnis, dass neben den Regelungen der DSGVO nationale Datenschutzvorgaben in Ihrem oder unserem Wohn- oder Sitzland gelten können.'
            : 'In the following, you will find an overview of the legal bases of the GDPR on which we base the processing of personal data. Please note that in addition to the provisions of the GDPR, national data protection provisions of your or our country of residence or domicile may apply.'
          }</p>

          <dl>
            <dt>{isDE ? 'Einwilligung (Art. 6(1)(a) DSGVO)' : 'Consent (Art. 6(1)(a) GDPR)'}</dt>
            <dd>{isDE
              ? 'Die betroffene Person hat ihre Einwilligung in die Verarbeitung der sie betreffenden personenbezogenen Daten für einen oder mehrere bestimmte Zwecke gegeben.'
              : 'The data subject has given consent to the processing of their personal data for one or more specific purposes.'
            }</dd>

            <dt>{isDE ? 'Vertragserfüllung (Art. 6(1)(b) DSGVO)' : 'Performance of a contract (Art. 6(1)(b) GDPR)'}</dt>
            <dd>{isDE
              ? 'Die Verarbeitung ist für die Erfüllung eines Vertrags, dessen Vertragspartei die betroffene Person ist, oder zur Durchführung vorvertraglicher Maßnahmen erforderlich.'
              : 'Processing is necessary for the performance of a contract to which the data subject is party, or in order to take steps at the request of the data subject prior to entering into a contract.'
            }</dd>

            <dt>{isDE ? 'Rechtliche Verpflichtung (Art. 6(1)(c) DSGVO)' : 'Compliance with a legal obligation (Art. 6(1)(c) GDPR)'}</dt>
            <dd>{isDE
              ? 'Die Verarbeitung ist zur Erfüllung einer rechtlichen Verpflichtung erforderlich, der der Verantwortliche unterliegt.'
              : 'Processing is necessary for compliance with a legal obligation to which the controller is subject.'
            }</dd>

            <dt>{isDE ? 'Berechtigte Interessen (Art. 6(1)(f) DSGVO)' : 'Legitimate interests (Art. 6(1)(f) GDPR)'}</dt>
            <dd>{isDE
              ? 'Die Verarbeitung ist zur Wahrung der berechtigten Interessen des Verantwortlichen oder eines Dritten erforderlich, sofern nicht die Interessen oder Grundrechte der betroffenen Person überwiegen.'
              : 'Processing is necessary for the purposes of the legitimate interests pursued by the controller or by a third party, except where such interests are overridden by the interests or fundamental rights and freedoms of the data subject.'
            }</dd>
          </dl>

          <h3>{isDE ? 'Nationale Datenschutzregelungen in Deutschland' : 'National data protection regulations in Germany'}</h3>
          <p>{isDE
            ? 'Zusätzlich zu den Datenschutzregelungen der DSGVO gelten nationale Regelungen zum Datenschutz in Deutschland. Hierzu gehört insbesondere das Bundesdatenschutzgesetz (BDSG), das besondere Vorschriften über das Recht auf Auskunft, das Recht auf Löschung, das Widerspruchsrecht sowie die Verarbeitung besonderer Kategorien personenbezogener Daten enthält.'
            : 'In addition to the data protection regulations of the GDPR, national regulations apply in Germany. This includes in particular the Federal Data Protection Act (BDSG), which contains special provisions on the right to access, the right to erasure, the right to object, and the processing of special categories of personal data.'
          }</p>

          <h3>{isDE ? 'Schweizerisches Datenschutzgesetz' : 'Swiss Data Protection Act'}</h3>
          <p>{isDE
            ? 'Wenn Sie sich in der Schweiz befinden, verarbeiten wir Ihre Daten auf Grundlage des Bundesgesetzes über den Datenschutz (Schweizer DSG). Diese Datenschutzhinweise gelten sowohl für die DSGVO als auch für das Schweizer DSG.'
            : 'If you are located in Switzerland, we process your data on the basis of the Federal Act on Data Protection (Swiss DPA). These privacy policy provisions apply to both the GDPR and the Swiss DPA. Where terms differ between the two frameworks, GDPR terminology is used for readability; the legal meaning is determined by whichever framework applies to your situation.'
          }</p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="security">
          <h2>{isDE ? 'Sicherheitsmaßnahmen' : 'Security precautions'}</h2>
          <p>{isDE
            ? 'Wir treffen nach Maßgabe der gesetzlichen Vorgaben unter Berücksichtigung des Stands der Technik, der Implementierungskosten und der Art, des Umfangs, der Umstände und der Zwecke der Verarbeitung sowie der unterschiedlichen Eintrittswahrscheinlichkeiten und des Ausmaßes der Bedrohung der Rechte und Freiheiten natürlicher Personen geeignete technische und organisatorische Maßnahmen.'
            : 'We take appropriate technical and organisational measures in accordance with legal requirements, taking into account the state of the art, the costs of implementation, and the nature, scope, context and purposes of processing, as well as the varying risks to the rights and freedoms of natural persons.'
          }</p>
          <p>{isDE
            ? 'Zu den Maßnahmen gehören insbesondere die Sicherung der Vertraulichkeit, Integrität und Verfügbarkeit von Daten durch Kontrolle des physischen und elektronischen Zugangs zu den Daten sowie des sie betreffenden Zugriffs, der Eingabe, der Weitergabe, der Sicherung der Verfügbarkeit und ihrer Trennung.'
            : 'The measures include, in particular, safeguarding the confidentiality, integrity and availability of data by controlling physical and electronic access, as well as access to, input, transmission, securing and separation of data. We have established procedures to ensure that data subjects\' rights are respected, that data is erased, and that we are prepared to respond to data threats rapidly.'
          }</p>

          <h3>{isDE ? 'IP-Adressmasking' : 'IP address masking'}</h3>
          <p>{isDE
            ? 'Soweit IP-Adressen von uns oder von eingesetzten Dienstleistern verarbeitet werden und die Verarbeitung einer vollständigen IP-Adresse nicht erforderlich ist, wird die IP-Adresse gekürzt ("IP-Masking"). Dabei werden die letzten zwei Stellen bzw. der letzte Teil der IP-Adresse nach einem Punkt gelöscht oder durch Platzhalter ersetzt.'
            : 'Where IP addresses are processed by us or by service providers and full IP address processing is not necessary, the IP address is shortened ("IP masking"). The last two digits or the last part of the IP address after a full stop are removed or replaced by wildcards. This prevents identification of a person by means of their IP address.'
          }</p>

          <h3>{isDE ? 'TLS/SSL-Verschlüsselung (HTTPS)' : 'TLS/SSL encryption (HTTPS)'}</h3>
          <p>{isDE
            ? 'Um die Daten der Nutzer vor einem unberechtigten Zugriff zu schützen, setzen wir das TLS/SSL-Verschlüsselungsverfahren ein. HTTPS in der URL zeigt an, dass Ihre Verbindung sicher verschlüsselt ist.'
            : 'To protect user data from unauthorised access, we employ TLS/SSL encryption on all data transmitted via our online services. HTTPS in the URL indicates that your connection is securely encrypted.'
          }</p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="transmission">
          <h2>{isDE ? 'Weitergabe von personenbezogenen Daten' : 'Transmission of personal data'}</h2>
          <p>{isDE
            ? 'Im Rahmen unserer Verarbeitung von personenbezogenen Daten kommt es vor, dass diese an andere Stellen, Unternehmen, rechtlich selbstständige Organisationseinheiten oder Personen übermittelt oder ihnen gegenüber offengelegt werden. Wir schließen entsprechende Verträge oder Vereinbarungen ab, die dem Schutz Ihrer Daten dienen.'
            : 'In the course of processing personal data, it may happen that data is transmitted to or disclosed to other entities, companies, legally independent organisational units, or individuals. Recipients of this data may include service providers tasked with IT duties or providers of services and content integrated into a website. In such cases, we observe the legal requirements and, in particular, conclude relevant contracts or agreements that serve to protect your data with the recipients of your data.'
          }</p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="international">
          <h2>{isDE ? 'Internationale Datentransfers' : 'International data transfers'}</h2>
          <p>{isDE
            ? 'Sofern wir Daten in einem Drittland (außerhalb der EU oder des EWR) verarbeiten oder dies im Rahmen der Inanspruchnahme von Diensten Dritter oder der Offenlegung von Daten an andere Personen, Stellen oder Unternehmen geschieht, erfolgt dies stets im Einklang mit den gesetzlichen Vorgaben.'
            : 'If we transfer data to a third country (outside the European Union or European Economic Area), or if this occurs in the context of using third-party services or the disclosure of data to other parties, this is always done in accordance with legal requirements.'
          }</p>
          <p>{isDE
            ? 'Für Datentransfers in die USA stützen wir uns primär auf den <strong>Data Privacy Framework (DPF)</strong>, der durch den Angemessenheitsbeschluss der EU-Kommission vom 10. Juli 2023 als sicherer Rechtsrahmen anerkannt wurde. Zusätzlich haben wir mit entsprechenden Anbietern Standardvertragsklauseln (SCC) abgeschlossen.'
            : 'For data transfers to the USA, we primarily rely on the <strong>Data Privacy Framework (DPF)</strong>, recognised as a secure legal framework by the EU Commission\'s adequacy decision of 10 July 2023. Additionally, we have concluded Standard Contractual Clauses (SCCs) with respective providers, which comply with the EU Commission\'s requirements and establish contractual obligations to protect your data.'
          }</p>

          <div class="legal-box">
            <p class="legal-box__label">{isDE ? 'Rechtsgrundlage' : 'Legal basis'}</p>
            <p>Art. 46 GDPR (Standard Contractual Clauses); EU-US Data Privacy Framework adequacy decision (July 2023).</p>
          </div>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="retention">
          <h2>{isDE ? 'Allgemeine Informationen zur Datenspeicherung und Löschung' : 'General information on data retention and deletion'}</h2>
          <p>{isDE
            ? 'Wir löschen personenbezogene Daten, die wir verarbeiten, gemäß den gesetzlichen Vorgaben, sobald die zugrundeliegenden Einwilligungen widerrufen werden oder keine weiteren rechtlichen Grundlagen für die Verarbeitung bestehen und die Zwecke der Verarbeitung weggefallen sind.'
            : 'We delete personal data that we process in accordance with legal requirements as soon as the consent on which the processing is based is revoked, or where no other permission applies and the purposes for which the data was originally stored have ceased to apply.'
          }</p>
          <p>{isDE
            ? 'Sofern die Daten nicht gelöscht werden, weil sie für andere und gesetzlich zulässige Zwecke erforderlich sind, wird deren Verarbeitung auf diese Zwecke beschränkt. Gesetzliche Aufbewahrungsfristen nach deutschem Recht (HGB, AO) betragen in der Regel 6 bis 10 Jahre.'
            : 'If data is not deleted because it is required for other and legally permissible purposes, its processing is restricted to those purposes. Legal retention periods under German law (HGB, AO) are typically 6 to 10 years. We will inform you of specific retention periods in the relevant sections of this policy where applicable.'
          }</p>
        </section>

        <div class="policy-divider" aria-hidden="true"></div>

        <section id="rights">
          <h2>{isDE ? 'Rechte der betroffenen Personen' : 'Rights of data subjects'}</h2>
          <p>{isDE
            ? 'Ihnen stehen nach der DSGVO folgende Rechte zu:'
            : 'Under the GDPR, you have the following rights with respect to personal data concerning you:'
          }</p>

          <dl>
            <dt>{isDE ? 'Auskunftsrecht (Art. 15 DSGVO)' : 'Right of access (Art. 15 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, eine Bestätigung darüber zu verlangen, ob betreffende Daten verarbeitet werden und auf Auskunft über diese Daten sowie auf weitere Informationen und Kopie der Daten entsprechend den gesetzlichen Vorgaben.'
              : 'You have the right to obtain confirmation of whether we process personal data concerning you, and if so, to access that data and receive a copy.'
            }</dd>

            <dt>{isDE ? 'Recht auf Berichtigung (Art. 16 DSGVO)' : 'Right to rectification (Art. 16 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, die Vervollständigung der Sie betreffenden Daten oder die Berichtigung der Sie betreffenden unrichtigen Daten zu verlangen.'
              : 'You have the right to request correction of inaccurate personal data, or completion of incomplete personal data.'
            }</dd>

            <dt>{isDE ? 'Recht auf Löschung (Art. 17 DSGVO)' : 'Right to erasure (Art. 17 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, die Löschung der Sie betreffenden Daten unverzüglich zu verlangen, soweit die gesetzlichen Voraussetzungen vorliegen.'
              : 'You have the right to request that personal data concerning you be deleted without undue delay where one of the statutory grounds applies.'
            }</dd>

            <dt>{isDE ? 'Recht auf Einschränkung der Verarbeitung (Art. 18 DSGVO)' : 'Right to restriction of processing (Art. 18 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, unter den gesetzlichen Voraussetzungen die Einschränkung der Verarbeitung der Sie betreffenden Daten zu verlangen.'
              : 'You have the right to request restriction of processing of personal data concerning you under certain conditions.'
            }</dd>

            <dt>{isDE ? 'Recht auf Datenübertragbarkeit (Art. 20 DSGVO)' : 'Right to data portability (Art. 20 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, die Sie betreffenden Daten, die Sie uns bereitgestellt haben, in einem strukturierten, gängigen und maschinenlesbaren Format zu erhalten oder deren Übermittlung an einen anderen Verantwortlichen zu fordern.'
              : 'You have the right to receive personal data you have provided to us in a structured, commonly used and machine-readable format, and to transmit that data to another controller.'
            }</dd>

            <dt>{isDE ? 'Widerspruchsrecht (Art. 21 DSGVO)' : 'Right to object (Art. 21 GDPR)'}</dt>
            <dd>{isDE
              ? 'Sie haben das Recht, jederzeit der Verarbeitung der Sie betreffenden Daten zu widersprechen, soweit die Verarbeitung auf Art. 6(1)(f) DSGVO basiert.'
