</style>

<script>
  // TOC active section tracking
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc__link');
  const sections = document.querySelectorAll<HTMLElement>('.policy-body section[id]');

  if (sections.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('is-active'));
            const active = document.querySelector<HTMLAnchorElement>(`.toc__link[href="#${entry.target.id}"]`);
            active?.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-68px 0px -60% 0px', threshold: 0 }
    );
    sections.forEach(s => observer.observe(s));
  }
</script>
