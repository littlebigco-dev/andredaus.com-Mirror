---
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const lastUpdated = '1 January 2025';
---

<Base
  title={isDE ? 'Impressum — André Daus' : 'Legal Notice — André Daus'}
  description={isDE
    ? 'Pflichtangaben gemäß § 5 TMG und § 2 DL-InfoV für andredaus.com.'
    : 'Mandatory information pursuant to § 5 TMG and § 2 DL-InfoV for andredaus.com.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="policy-hero" aria-labelledby="policy-title">
    <div class="container">
      <div class="policy-hero__inner">
        <div>
          <p class="policy-hero__type">{isDE ? 'Rechtliches · Impressum' : 'Legal · Notice'}</p>
          <h1 class="policy-hero__title" id="policy-title">
            {isDE ? 'Impressum' : 'Legal Notice'}
          </h1>
        </div>
        <aside class="policy-meta" aria-label={isDE ? 'Dokumentinformationen' : 'Document information'}>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Gültig ab' : 'Effective'}</span>
            <span class="policy-meta__val">{lastUpdated}</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Sprache' : 'Language'}</span>
            <span class="policy-meta__val">{isDE ? 'Deutsch / Englisch' : 'German / English'}</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <!-- POLICY NAV STRIP -->
  <nav class="policy-nav-strip" aria-label={isDE ? 'Rechtstexte-Navigation' : 'Policy navigation'}>
    <div class="container">
      <ul class="policy-nav-strip__list" role="list">
        <li><a href={`${prefix}/policy/privacy`} class="policy-nav-strip__link">{isDE ? 'Datenschutz' : 'Privacy Policy'}</a></li>
        <li><a href={`${prefix}/policy/legal-notice`} class="policy-nav-strip__link is-active" aria-current="page">{isDE ? 'Impressum' : 'Legal Notice'}</a></li>
        <li><a href={`${prefix}/policy/terms`} class="policy-nav-strip__link">{isDE ? 'AGB' : 'Terms'}</a></li>
        <li><a href={`${prefix}/policy/ai-use`} class="policy-nav-strip__link">{isDE ? 'KI-Nutzung' : 'AI Use'}</a></li>
      </ul>
    </div>
  </nav>

  <!-- BODY -->
  <div class="container">
    <div class="policy-layout">

      <!-- TOC SIDEBAR -->
      <aside class="policy-toc" aria-label={isDE ? 'Inhaltsverzeichnis' : 'Table of contents'}>
        <p class="policy-toc__title">{isDE ? 'Inhalt' : 'Contents'}</p>
        <nav>
          <ul class="policy-toc__list" role="list">
            <li><a href="#responsible" class="toc__link">{isDE ? 'Verantwortlicher' : 'Responsible Party'}</a></li>
            <li><a href="#contact" class="toc__link">{isDE ? 'Kontakt' : 'Contact'}</a></li>
            <li><a href="#tax" class="toc__link">{isDE ? 'Steuerliche Angaben' : 'Tax Information'}</a></li>
            <li><a href="#profession" class="toc__link">{isDE ? 'Berufsbezeichnung' : 'Professional Title'}</a></li>
            <li><a href="#editorial" class="toc__link">{isDE ? 'Redaktionell Verantwortlicher' : 'Editorial Responsibility'}</a></li>
            <li><a href="#disputes" class="toc__link">{isDE ? 'Streitschlichtung' : 'Dispute Resolution'}</a></li>
            <li><a href="#liability-content" class="toc__link">{isDE ? 'Haftung für Inhalte' : 'Liability for Content'}</a></li>
            <li><a href="#liability-links" class="toc__link">{isDE ? 'Haftung für Links' : 'Liability for Links'}</a></li>
            <li><a href="#copyright" class="toc__link">{isDE ? 'Urheberrecht' : 'Copyright'}</a></li>
          </ul>
        </nav>
      </aside>

      <!-- ARTICLE -->
      <article class="policy-body" lang={isDE ? 'de' : 'en'}>

        <!-- 1. Responsible Party -->
        <section id="responsible" aria-labelledby="h-responsible">
          <h2 id="h-responsible">{isDE ? 'Verantwortlicher gemäß § 5 TMG' : 'Responsible Party pursuant to § 5 TMG'}</h2>
          <address>
            <strong>André Daus</strong><br/>
            {isDE ? 'Einzelunternehmer' : 'Sole Trader'}<br/>
            Musterstraße 1<br/>
            12345 Musterstadt<br/>
            {isDE ? 'Deutschland' : 'Germany'}
          </address>
          <p>{isDE
            ? 'Hinweis: Die vollständige Adresse wird nach Aufnahme der Geschäftstätigkeit hier eingetragen.'
            : 'Note: The full address will be added here upon commencement of trading.'}</p>
        </section>

        <hr class="policy-divider"/>

        <!-- 2. Contact -->
        <section id="contact" aria-labelledby="h-contact">
          <h2 id="h-contact">{isDE ? 'Kontakt' : 'Contact'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'E-Mail' : 'Email'}</dt>
              <dd><a href="mailto:hello@andredaus.com">hello@andredaus.com</a></dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Website' : 'Website'}</dt>
              <dd>andredaus.com</dd>
            </div>
          </dl>
        </section>

        <hr class="policy-divider"/>

        <!-- 3. Tax -->
        <section id="tax" aria-labelledby="h-tax">
          <h2 id="h-tax">{isDE ? 'Steuerliche Angaben' : 'Tax Information'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'Umsatzsteuer-ID' : 'VAT Identification Number'}</dt>
              <dd>{isDE ? 'Wird nach Erteilung hier eingetragen.' : 'Will be added here upon issuance.'}</dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Steuernummer' : 'Tax Number'}</dt>
              <dd>{isDE ? 'Wird nach Erteilung hier eingetragen.' : 'Will be added here upon issuance.'}</dd>
            </div>
          </dl>
        </section>

        <hr class="policy-divider"/>

        <!-- 4. Professional Title -->
        <section id="profession" aria-labelledby="h-profession">
          <h2 id="h-profession">{isDE ? 'Berufsbezeichnung und berufsrechtliche Regelungen' : 'Professional Title and Regulatory Information'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'Berufsbezeichnung' : 'Professional title'}</dt>
              <dd>{isDE ? 'Unternehmensberater / Coach (freiberuflich)' : 'Business Consultant / Coach (freelance)'}</dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Verliehen in' : 'Awarded in'}</dt>
              <dd>{isDE ? 'Deutschland' : 'Germany'}</dd>
            </div>
          </dl>
          <p>{isDE
            ? 'Die Berufsbezeichnung "Unternehmensberater" und "Coach" sind in Deutschland nicht gesetzlich geschützt. Es bestehen keine berufsrechtlichen Regelungen durch eine Kammer oder einen Berufsverband.'
            : 'The professional titles "Business Consultant" and "Coach" are not legally protected in Germany. There are no professional regulations by a chamber or professional association.'}</p>
        </section>

        <hr class="policy-divider"/>

        <!-- 5. Editorial Responsibility -->
        <section id="editorial" aria-labelledby="h-editorial">
          <h2 id="h-editorial">{isDE ? 'Redaktionell Verantwortlicher gemäß § 55 Abs. 2 RStV' : 'Editorial Responsibility pursuant to § 55 Para. 2 RStV'}</h2>
          <address>
            <strong>André Daus</strong><br/>
            {isDE ? '(Adresse wie oben)' : '(Address as above)'}
          </address>
        </section>

        <hr class="policy-divider"/>

        <!-- 6. Dispute Resolution -->
        <section id="disputes" aria-labelledby="h-disputes">
          <h2 id="h-disputes">{isDE ? 'Streitschlichtung' : 'Dispute Resolution'}</h2>
          <p>{isDE
            ? 'Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit: https://ec.europa.eu/consumers/odr/. Unsere E-Mail-Adresse finden Sie oben im Impressum.'
            : 'The European Commission provides a platform for online dispute resolution (ODR): https://ec.europa.eu/consumers/odr/. Our email address can be found above in the legal notice.'}</p>
          <p>{isDE
            ? 'Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.'
            : 'We are not willing or obliged to participate in dispute resolution proceedings before a consumer arbitration board.'}</p>
        </section>

        <hr class="policy-divider"/>

        <!-- 7. Liability for Content -->
        <section id="liability-content" aria-labelledby="h-liability-content">
          <h2 id="h-liability-content">{isDE ? 'Haftung für Inhalte' : 'Liability for Content'}</h2>
          <p>{isDE
            ? 'Als Diensteanbieter sind wir gemäß § 7 Abs.1 TMG für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich. Nach §§ 8 bis 10 TMG sind wir als Diensteanbieter jedoch nicht verpflichtet, übermittelte oder gespeicherte fremde Informationen zu überwachen oder nach Umständen zu forschen, die auf eine rechtswidrige Tätigkeit hinweisen.'
            : 'As a service provider, we are responsible for our own content on these pages in accordance with § 7 para. 1 TMG and general laws. However, pursuant to §§ 8 to 10 TMG, we are not obliged to monitor transmitted or stored third-party information or to investigate circumstances that indicate illegal activity.'}</p>
          <p>{isDE
            ? 'Verpflichtungen zur Entfernung oder Sperrung der Nutzung von Informationen nach den allgemeinen Gesetzen bleiben hiervon unberührt. Eine diesbezügliche Haftung ist jedoch erst ab dem Zeitpunkt der Kenntnis einer konkreten Rechtsverletzung möglich. Bei Bekanntwerden von entsprechenden Rechtsverletzungen werden wir diese Inhalte umgehend entfernen.'
            : 'Obligations to remove or block the use of information under general laws remain unaffected. However, liability in this regard is only possible from the point in time at which a specific infringement of the law becomes known. Upon notification of such violations, we will remove the content immediately.'}</p>
        </section>

        <hr class="policy-divider"/>

        <!-- 8. Liability for Links -->
        <section id="liability-links" aria-labelledby="h-liability-links">
          <h2 id="h-liability-links">{isDE ? 'Haftung für Links' : 'Liability for Links'}</h2>
          <p>{isDE
            ? 'Unser Angebot enthält Links zu externen Websites Dritter, auf deren Inhalte wir keinen Einfluss haben. Deshalb können wir für diese fremden Inhalte auch keine Gewähr übernehmen. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter oder Betreiber der Seiten verantwortlich.'
            : 'Our website contains links to external third-party websites, the content of which we have no influence over. Therefore, we cannot assume any liability for these external contents. The respective provider or operator of the linked pages is always responsible for the content of those pages.'}</p>
          <p>{isDE
            ? 'Die verlinkten Seiten wurden zum Zeitpunkt der Verlinkung auf mögliche Rechtsverstöße überprüft. Rechtswidrige Inhalte waren zum Zeitpunkt der Verlinkung nicht erkennbar. Eine permanente inhaltliche Kontrolle der verlinkten Seiten ist jedoch ohne konkrete Anhaltspunkte einer Rechtsverletzung nicht zumutbar. Bei Bekanntwerden von Rechtsverletzungen werden wir derartige Links umgehend entfernen.'
            : 'The linked pages were checked for possible legal violations at the time of linking. No illegal content was apparent at the time of linking. However, permanent monitoring of the content of the linked pages is not reasonable without concrete indications of a legal violation. Upon notification of violations, we will remove such links immediately.'}</p>
        </section>

        <hr class="policy-divider"/>

        <!-- 9. Copyright -->
        <section id="copyright" aria-labelledby="h-copyright">
          <h2 id="h-copyright">{isDE ? 'Urheberrecht' : 'Copyright'}</h2>
          <p>{isDE
            ? 'Die durch die Seitenbetreiber erstellten Inhalte und Werke auf diesen Seiten unterliegen dem deutschen Urheberrecht. Die Vervielfältigung, Bearbeitung, Verbreitung und jede Art der Verwertung außerhalb der Grenzen des Urheberrechtes bedürfen der schriftlichen Zustimmung des jeweiligen Autors bzw. Erstellers.'
            : 'The content and works created by the site operators on these pages are subject to German copyright law. Reproduction, editing, distribution and any kind of exploitation outside the limits of copyright require the written consent of the respective author or creator.'}</p>
          <p>{isDE
            ? 'Downloads und Kopien dieser Seite sind nur für den privaten, nicht kommerziellen Gebrauch gestattet. Soweit die Inhalte auf dieser Seite nicht vom Betreiber erstellt wurden, werden die Urheberrechte Dritter beachtet. Insbesondere werden Inhalte Dritter als solche gekennzeichnet. Sollten Sie trotzdem auf eine Urheberrechtsverletzung aufmerksam werden, bitten wir um einen entsprechenden Hinweis. Bei Bekanntwerden von Rechtsverletzungen werden wir derartige Inhalte umgehend entfernen.'
            : 'Downloads and copies of this site are only permitted for private, non-commercial use. Insofar as the content on this site was not created by the operator, the copyrights of third parties are respected. Third-party content is identified as such. Should you nevertheless become aware of a copyright violation, please inform us accordingly. Upon notification of violations, we will remove such content immediately.'}</p>
        </section>

      </article>
    </div>
  </div>

</Base>

<style>
  /* ── POLICY HERO ──────────────────────────────────────── */
  .policy-hero {
    padding-top: 68px;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
  }
  .policy-hero__inner {
    display: grid; grid-template-columns: 1fr auto;
    gap: 3rem; align-items: end;
    padding-block: clamp(3rem,6vw,5rem) 2.5rem;
  }
  .policy-hero__type {
    font-family: var(--mono); font-size: 10px;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
  }
  .policy-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400; line-height: 1.05; color: var(--text-primary);
  }
  .policy-meta {
    background: var(--bg-card); border: 1px solid var(--border-light);
    border-radius: 3px; padding: 1.25rem 1.5rem;
    min-width: 220px; align-self: end;
  }
  .policy-meta__row {
    display: flex; flex-direction: column; gap: .2rem;
    padding-block: .625rem;
    border-bottom: 1px solid var(--border-light);
  }
  .policy-meta__row:first-child { padding-top: 0; }
  .policy-meta__row:last-child { border-bottom: none; padding-bottom: 0; }
  .policy-meta__key {
    font-family: var(--mono); font-size: 9px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--text-subtle);
  }
  .policy-meta__val { font-size: 13px; color: var(--text-secondary); }
  @media (max-width: 700px) {
    .policy-hero__inner { grid-template-columns: 1fr; }
    .policy-meta { display: none; }
  }

  /* ── POLICY NAV STRIP ─────────────────────────────────── */
  .policy-nav-strip {
    background: var(--bg-card-alt);
    border-bottom: 1px solid var(--border-light);
    padding-block: .875rem;
    overflow-x: auto;
  }
  .policy-nav-strip__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: 2rem; flex-wrap: nowrap;
  }
  .policy-nav-strip__link {
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--text-subtle); text-decoration: none;
    padding-bottom: .25rem;
    border-bottom: 1px solid transparent;
    transition: color .2s ease, border-color .2s ease;
    white-space: nowrap;
  }
  .policy-nav-strip__link:hover { color: var(--text-secondary); }
  .policy-nav-strip__link.is-active { color: var(--gold); border-color: var(--gold); }

  /* ── POLICY LAYOUT ────────────────────────────────────── */
  .policy-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem; align-items: start;
    padding-block: clamp(3rem,6vw,5rem);
  }

  /* ── TOC ──────────────────────────────────────────────── */
  .policy-toc {
    position: sticky; top: calc(68px + 2rem);
    max-height: calc(100vh - 68px - 4rem);
    overflow-y: auto; padding-right: .5rem;
  }
  .policy-toc__title {
    font-family: var(--mono); font-size: 9px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--text-subtle); margin-bottom: 1rem;
  }
  .policy-toc__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .25rem; }
  .toc__link {
    font-size: 13px; line-height: 1.5; color: var(--text-subtle);
    text-decoration: none; display: block; padding: .35rem 0;
    border-left: 2px solid transparent; padding-left: .75rem;
    transition: color .2s ease, border-color .2s ease;
  }
  .toc__link:hover { color: var(--text-secondary); }
  .toc__link.is-active { color: var(--gold); border-color: var(--gold); }
  @media (max-width: 900px) {
    .policy-layout { grid-template-columns: 1fr; }
    .policy-toc { display: none; }
  }

  /* ── POLICY BODY ──────────────────────────────────────── */
  .policy-body { min-width: 0; }
  .policy-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 400; line-height: 1.2; color: var(--text-primary);
    margin-bottom: 1.25rem;
  }
  .policy-body h3 {
    font-family: var(--mono); font-size: 11px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--gold); margin-top: 2rem; margin-bottom: .75rem;
  }
  .policy-body p {
    font-size: clamp(14px, 1.05vw, 15.5px); line-height: 1.9;
    color: var(--text-secondary); margin-bottom: 1rem;
  }
  .policy-body p:last-child { margin-bottom: 0; }
  .policy-body a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
  .policy-body a:hover { color: var(--gold-light); }
  .policy-body address { font-style: normal; margin-bottom: 1rem; line-height: 1.9; color: var(--text-secondary); font-size: clamp(14px, 1.05vw, 15.5px); }
  .policy-body section { margin-bottom: 3rem; }
  .policy-body section:last-child { margin-bottom: 0; }
  .policy-divider { border: none; border-top: 1px solid var(--border-light); margin-block: 2.5rem; }

  /* Definition list */
  .policy-dl { margin-bottom: 1rem; }
  .policy-dl__row {
    display: grid; grid-template-columns: 200px 1fr;
    gap: 1rem; padding-block: .75rem;
    border-bottom: 1px solid var(--border-light);
    font-size: 14px; line-height: 1.7;
  }
  .policy-dl__row:first-child { border-top: 1px solid var(--border-light); }
  .policy-dl__row dt { color: var(--text-subtle); font-family: var(--mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; padding-top: .1rem; }
  .policy-dl__row dd { color: var(--text-secondary); }
  @media (max-width: 600px) { .policy-dl__row { grid-template-columns: 1fr; gap: .25rem; } }
</style>

<script>
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc__link'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.policy-body section[id]'));

  if (tocLinks.length && sections.length) {
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('is-active'));
          document.querySelector<HTMLAnchorElement>(`.toc__link[href="#${entry.target.id}"]`)?.classList.add('is-active');
        }
      }),
      { rootMargin: '-68px 0px -60% 0px', threshold: 0 }
    );
    sections.forEach(s => observer.observe(s));
  }
</script>
