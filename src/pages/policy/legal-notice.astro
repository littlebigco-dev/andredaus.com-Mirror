---
import Base from '../../layouts/Base.astro';

const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

const lastUpdated = isDE ? '28. März 2026' : '28 March 2026';
---

<Base
  title={isDE ? 'Impressum — André Daus' : 'Legal Notice — André Daus'}
  description={isDE
    ? 'Pflichtangaben gemäß § 5 TMG und § 2 DL-InfoV für andredaus.com.'
    : 'Mandatory information pursuant to § 5 TMG and § 2 DL-InfoV for andredaus.com.'}
  lang={isDE ? 'de' : 'en'}
>

  <!-- HERO -->
  <header class="policy-hero" aria-labelledby="policy-title">
    <div class="container">
      <div class="policy-hero__inner">
        <div>
          <p class="policy-hero__type">{isDE ? 'Rechtliches · Impressum' : 'Legal · Notice'}</p>
          <h1 class="policy-hero__title" id="policy-title">
            {isDE ? 'Impressum' : 'Legal Notice'}
          </h1>
        </div>
        <aside class="policy-meta" aria-label={isDE ? 'Dokumentinformationen' : 'Document information'}>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Aktualisiert' : 'Last updated'}</span>
            <span class="policy-meta__val">{lastUpdated}</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Verantwortlicher' : 'Controller'}</span>
            <span class="policy-meta__val">André Daus, Cologne DE</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Gilt für' : 'Applies to'}</span>
            <span class="policy-meta__val">andredaus.com</span>
          </div>
          <div class="policy-meta__row">
            <span class="policy-meta__key">{isDE ? 'Rahmenwerk' : 'Framework'}</span>
            <span class="policy-meta__val">DDGEU · DSA · MStV</span>
          </div>
        </aside>
      </div>
    </div>
  </header>

  <!-- POLICY NAV STRIP -->
  <nav class="policy-nav-strip" aria-label={isDE ? 'Rechtstexte-Navigation' : 'Policy navigation'}>
    <div class="container">
      <ul class="policy-nav-strip__list" role="list">
        <li><a href={`${prefix}/policy/privacy`} class="policy-nav-strip__link">{isDE ? 'Datenschutz' : 'Privacy Policy'}</a></li>
        <li><a href={`${prefix}/policy/legal-notice`} class="policy-nav-strip__link is-active" aria-current="page">{isDE ? 'Impressum' : 'Legal Notice'}</a></li>
        <li><a href={`${prefix}/policy/terms`} class="policy-nav-strip__link">{isDE ? 'AGB' : 'Terms'}</a></li>
        <li><a href={`${prefix}/policy/ai-use`} class="policy-nav-strip__link">{isDE ? 'KI-Nutzung' : 'AI Use'}</a></li>
      </ul>
    </div>
  </nav>

  <!-- BODY -->
  <div class="container">
    <div class="policy-layout">

      <!-- TOC SIDEBAR -->
      <aside class="policy-toc" aria-label={isDE ? 'Inhaltsverzeichnis' : 'Table of contents'}>
        <p class="policy-toc__title">{isDE ? 'Inhalt' : 'Contents'}</p>
        <nav>
          <ul class="policy-toc__list" role="list">
            <li><a href="#responsible" class="toc__link">{isDE ? 'Anbieter' : 'Provider'}</a></li>
            <li><a href="#contact" class="toc__link">{isDE ? 'Kontaktmöglichkeiten' : 'Contact Options'}</a></li>
            <li><a href="#audiovisual" class="toc__link">{isDE ? 'Audiovisuelle Mediendienste' : 'Audiovisual Media Services'}</a></li>
            <li><a href="#company" class="toc__link">{isDE ? 'Unternehmensangaben' : 'Company Details'}</a></li>
            <li><a href="#social" class="toc__link">{isDE ? 'Social-Media-Konten' : 'Social Media Accounts'}</a></li>
            <li><a href="#tdm" class="toc__link">{isDE ? 'Nutzungsvorbehalt TDM' : 'Text and Data Mining'}</a></li>
          </ul>
        </nav>
      </aside>

      <!-- ARTICLE -->
      <article class="policy-body" lang={isDE ? 'de' : 'en'}>

        <!-- 1. Provider -->
        <section id="responsible" aria-labelledby="h-responsible">
          <h2 id="h-responsible">{isDE ? 'Anbieter' : 'Provider'}</h2>
          <address>
            <strong>André Daus</strong><br/>
            c/o Block Services<br/>
            Stuttgarter Str. 106<br/>
            70736 Fellbach<br/>
            {isDE ? 'Deutschland' : 'Germany'}
          </address>
        </section>

        <hr class="policy-divider"/>

        <!-- 2. Contact Options -->
        <section id="contact" aria-labelledby="h-contact">
          <h2 id="h-contact">{isDE ? 'Kontaktmöglichkeiten' : 'Contact Options'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'E-Mail-Adresse' : 'E-Mail Address'}</dt>
              <dd><a href="mailto:contact@andredaus.com">contact@andredaus.com</a></dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Telefon' : 'Phone'}</dt>
              <dd><a href="tel:+492211653180">+49 221 16 53 18-0</a></dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Kontaktformular' : 'Contact form'}</dt>
              <dd><a href="/contact">andredaus.com/contact</a></dd>
            </div>
          </dl>
        </section>

        <hr class="policy-divider"/>

        <!-- 3. Audiovisual Media Services -->
        <section id="audiovisual" aria-labelledby="h-audiovisual">
          <h2 id="h-audiovisual">{isDE ? 'Audiovisuelle Mediendienste' : 'Audiovisual Media Services'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'Niederlassungsland' : 'Country of domicile'}</dt>
              <dd>{isDE ? 'Deutschland' : 'Germany'}</dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'Zuständige Aufsichtsbehörde' : 'Competent regulatory authority'}</dt>
              <dd>
                <a href="https://www.medienanstalt-nrw.de/" target="_blank" rel="noopener noreferrer">
                  {isDE ? 'Medienanstalt NRW' : 'State Media Authority NRW'}
                </a>
              </dd>
            </div>
          </dl>
        </section>

        <hr class="policy-divider"/>

        <!-- 4. Company Details -->
        <section id="company" aria-labelledby="h-company">
          <h2 id="h-company">{isDE ? 'Unternehmensangaben' : 'Company Details'}</h2>
          <dl class="policy-dl">
            <div class="policy-dl__row">
              <dt>{isDE ? 'Umsatzsteuer-Identifikationsnummer' : 'VAT identification number'}</dt>
              <dd>DE311510201</dd>
            </div>
            <div class="policy-dl__row">
              <dt>{isDE ? 'AGB' : 'Terms'}</dt>
              <dd><a href={`${prefix}/policy/terms`}>{isDE ? 'andredaus.com/de/policy/terms' : 'andredaus.com/policy/terms'}</a></dd>
            </div>
          </dl>
        </section>

        <hr class="policy-divider"/>

        <!-- 5. Social Media Accounts -->
        <section id="social" aria-labelledby="h-social">
          <h2 id="h-social">{isDE ? 'Social-Media-Konten und andere Onlineprofile' : 'Social Media Accounts and other Online Profiles'}</h2>
          <p>{isDE
            ? 'Dieses Impressum gilt auch für folgende Social-Media-Konten und Onlineprofile:'
            : 'This legal notice also applies to the following social media accounts and online profiles:'}</p>
          <ul class="policy-list">
            <li><a href="https://linkedin.com/in/andredaus" target="_blank" rel="noopener noreferrer">linkedin.com/in/andredaus</a></li>
            <li><a href="https://youtube.com/@AndreDaus" target="_blank" rel="noopener noreferrer">youtube.com/@AndreDaus</a></li>
            <li><a href="https://instagram.com/andredaus" target="_blank" rel="noopener noreferrer">instagram.com/andredaus</a></li>
          </ul>
        </section>

        <hr class="policy-divider"/>

        <!-- 6. Text and Data Mining -->
        <section id="tdm" aria-labelledby="h-tdm">
          <h2 id="h-tdm">{isDE ? 'Nutzungsvorbehalt für Text und Data Mining' : 'Reservation of use for text and data mining'}</h2>
          <p>{isDE
            ? 'Nutzungsvorbehalt für Text und Data Mining: Der Inhaber dieser Website gestattet die Nutzung oder das Herunterladen von Inhalten dieser Website durch Dritte für die Entwicklung, das Training oder den Betrieb von künstlicher Intelligenz oder anderen maschinellen Lernsystemen („Text und Data Mining") ausschließlich mit der ausdrücklichen schriftlichen Zustimmung des Inhabers. Ohne eine solche Zustimmung ist es verboten, die Inhalte für Text und Data Mining zu nutzen. Dies gilt auch dann, wenn auf der Website keine Meta-Tags vorhanden sind, die solche Prozesse blockieren, und auch dann, wenn Bots, die die Website zu Text- und Data-Mining-Zwecken auslesen sollen, nicht blockiert werden.'
            : 'Reservation of use for text and data mining: The owner of this website permits the use or downloading of content from this website by third parties for the development, training, or operation of artificial intelligence or other machine learning systems ("Text and Data Mining") exclusively with the express written consent of the owner. Without such consent, it is prohibited to use the content for Text and Data Mining. This applies even if there are no meta tags on the website that block such processes, and even if bots designed to read the website for Text and Data Mining purposes are not blocked.'}</p>
        </section>

      </article>
    </div>
  </div>

</Base>

<style>
  /* ── POLICY HERO ──────────────────────────────────────── */
  .policy-hero {
    padding-top: 68px;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
  }
  .policy-hero__inner {
    display: grid; grid-template-columns: 1fr auto;
    gap: 3rem; align-items: end;
    padding-block: clamp(3rem,6vw,5rem) 2.5rem;
  }
  .policy-hero__type {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 1rem;
  }
  .policy-hero__title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400; line-height: 1.05; color: var(--text-primary);
  }
  .policy-meta {
    background: var(--bg-card); border: 1px solid var(--border-light);
    border-radius: 3px; padding: 1.25rem 1.5rem;
    min-width: 220px; align-self: end;
  }
  .policy-meta__row {
    display: flex; flex-direction: column; gap: .2rem;
    padding-block: .625rem;
    border-bottom: 1px solid var(--border-light);
  }
  .policy-meta__row:first-child { padding-top: 0; }
  .policy-meta__row:last-child { border-bottom: none; padding-bottom: 0; }
  .policy-meta__key {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--text-subtle);
  }
  .policy-meta__val { font-size: 13px; color: var(--text-secondary); }
  @media (max-width: 700px) {
    .policy-hero__inner { grid-template-columns: 1fr; }
    .policy-meta { display: none; }
  }

  /* ── POLICY NAV STRIP ─────────────────────────────────── */
  .policy-nav-strip {
    background: var(--bg-card-alt);
    border-bottom: 1px solid var(--border-light);
    padding-block: .875rem;
    overflow-x: auto;
  }
  .policy-nav-strip__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; gap: 2rem; flex-wrap: nowrap;
  }
  .policy-nav-strip__link {
    font-family: var(--mono); font-size: 13px;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--text-subtle); text-decoration: none;
    padding-bottom: .25rem;
    border-bottom: 1px solid transparent;
    transition: color .2s ease, border-color .2s ease;
    white-space: nowrap;
  }
  .policy-nav-strip__link:hover { color: var(--text-secondary); }
  .policy-nav-strip__link.is-active { color: var(--gold); border-color: var(--gold); }

  /* ── POLICY LAYOUT ────────────────────────────────────── */
  .policy-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem; align-items: start;
    padding-block: clamp(3rem,6vw,5rem);
  }

  /* ── TOC ──────────────────────────────────────────────── */
  .policy-toc {
    position: sticky; top: calc(68px + 2rem);
    max-height: calc(100vh - 68px - 4rem);
    overflow-y: auto; padding-right: .5rem;
  }
  .policy-toc__title {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--text-subtle); margin-bottom: 1rem;
  }
  .policy-toc__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .25rem; }
  .toc__link {
    font-size: 13px; line-height: 1.5; color: var(--text-subtle);
    text-decoration: none; display: block; padding: .35rem 0;
    border-left: 2px solid transparent; padding-left: .75rem;
    transition: color .2s ease, border-color .2s ease;
  }
  .toc__link:hover { color: var(--text-secondary); }
  .toc__link.is-active { color: var(--gold); border-color: var(--gold); }
  @media (max-width: 900px) {
    .policy-layout { grid-template-columns: 1fr; }
    .policy-toc { display: none; }
  }

  /* ── POLICY BODY ──────────────────────────────────────── */
  .policy-body { min-width: 0; }
  .policy-body h2 {
    font-family: var(--serif);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    font-weight: 400; line-height: 1.2; color: var(--text-primary);
    margin-bottom: 1.25rem;
  }
  .policy-body h3 {
    font-family: var(--mono); font-size: 13px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--gold); margin-top: 2rem; margin-bottom: .75rem;
  }
  .policy-body p {
    font-size: clamp(14px, 1.05vw, 15.5px); line-height: 1.9;
    color: var(--text-secondary); margin-bottom: 1rem;
  }
  .policy-body p:last-child { margin-bottom: 0; }
  .policy-body a { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; }
  .policy-body a:hover { color: var(--gold-light); }
  .policy-body address { font-style: normal; margin-bottom: 1rem; line-height: 1.9; color: var(--text-secondary); font-size: clamp(14px, 1.05vw, 15.5px); }
  .policy-body section { margin-bottom: 3rem; }
  .policy-body section:last-child { margin-bottom: 0; }
  .policy-divider { border: none; border-top: 1px solid var(--border-light); margin-block: 2.5rem; }

  /* Inline list (social links) */
  .policy-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: .375rem;
  }
  .policy-list li::before { content: '→ '; color: var(--gold); font-family: var(--mono); font-size: 12px; }
  .policy-list a { color: var(--gold); text-underline-offset: 3px; }
  .policy-list a:hover { color: var(--gold-light); }

  /* Definition list */
  .policy-dl { margin-bottom: 1rem; }
  .policy-dl__row {
    display: grid; grid-template-columns: 200px 1fr;
    gap: 1rem; padding-block: .75rem;
    border-bottom: 1px solid var(--border-light);
    font-size: 14px; line-height: 1.7;
  }
  .policy-dl__row:first-child { border-top: 1px solid var(--border-light); }
  .policy-dl__row dt { color: var(--text-subtle); font-family: var(--mono); font-size: 13px; letter-spacing: .08em; text-transform: uppercase; padding-top: .1rem; }
  .policy-dl__row dd { color: var(--text-secondary); }
  @media (max-width: 600px) { .policy-dl__row { grid-template-columns: 1fr; gap: .25rem; } }
</style>

<script>
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc__link'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.policy-body section[id]'));

  if (tocLinks.length && sections.length) {
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('is-active'));
          document.querySelector<HTMLAnchorElement>(`.toc__link[href="#${entry.target.id}"]`)?.classList.add('is-active');
        }
      }),
      { rootMargin: '-68px 0px -60% 0px', threshold: 0 }
    );
    sections.forEach(s => observer.observe(s));
  }
</script>
