---
const currentPath = Astro.url.pathname;
const isDE = currentPath.startsWith('/de');
const prefix = isDE ? '/de' : '';

// Strip /de prefix to get the path-only part, then build alt-lang URL
const pathWithoutLang = isDE ? (currentPath.slice(3) || '/') : currentPath;
const altLangHref = isDE ? pathWithoutLang : `/de${currentPath}`;

const navLinks = [
  { href: `${prefix}/services`,    label: isDE ? 'Leistungen'   : 'Services' },
  { href: `${prefix}/use-cases`,   label: isDE ? 'Fallstudien'  : 'Use Cases' },
  { href: `${prefix}/insights`,    label: isDE ? 'Einblicke'    : 'Insights' },
  { href: `${prefix}/podcast`,     label: 'Podcast' },
  { href: `${prefix}/opposition`,  label: isDE ? 'Methodik'     : 'Opposition' },
  { href: `${prefix}/about`,       label: isDE ? 'Über André'   : 'About' },
];

function isActive(href: string) {
  if (href === prefix + '/' || href === '/') {
    return currentPath === href;
  }
  return currentPath.startsWith(href);
}
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav__inner">
    <a href={prefix + '/'} class="nav__brand" aria-label="André Daus — Strategic Opposition, home">
      <span class="nav__brand-name">André Daus</span>
      <span class="nav__brand-sub">Strategic Opposition</span>
    </a>

    <!-- Desktop links -->
    <div class="nav__links" role="list">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav__link', { 'is-active': isActive(link.href) }]}
          role="listitem"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Language switcher -->
    <a href={altLangHref} class="nav__lang" aria-label={isDE ? 'Switch to English' : 'Zu Deutsch wechseln'}>
      {isDE ? 'EN' : 'DE'}
    </a>

    <a href={`${prefix}/contact`} class="nav__cta">
      {isDE ? 'Blinde Flecken finden' : 'Find Your Blind Spots'}
    </a>

    <!-- Mobile toggle — WCAG 2.5.8 44×44 -->
    <button
      class="nav__toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <svg class="nav__toggle-icon" width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
        <rect y="0"  width="22" height="2" rx="1" fill="currentColor"/>
        <rect y="7"  width="16" height="2" rx="1" fill="currentColor"/>
        <rect y="14" width="22" height="2" rx="1" fill="currentColor"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="nav-drawer" class="nav__drawer" aria-label="Mobile navigation">
  {navLinks.map(link => (
    <a
      href={link.href}
      class:list={['nav__drawer-link', { 'is-active': isActive(link.href) }]}
    >
      {link.label}
    </a>
  ))}
  <a href={altLangHref} class="nav__drawer-link nav__drawer-lang">
    {isDE ? '🌐 English' : '🌐 Deutsch'}
  </a>
  <div class="nav__drawer-cta">
    <a href={`${prefix}/contact`} class="btn btn--primary" style="width:100%;justify-content:center;">
      {isDE ? 'Blinde Flecken finden' : 'Find Your Blind Spots'}
    </a>
  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 var(--gutter);
    height: 68px;
    display: flex;
    align-items: center;
    background: rgba(9, 12, 20, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-light);
  }

  .nav__inner {
    max-width: var(--max-w);
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .nav__brand {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex-shrink: 0;
    text-decoration: none;
  }
  .nav__brand-name {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    text-transform: uppercase;
  }
  .nav__brand-sub {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.75rem);
    flex: 1;
    justify-content: center;
  }

  .nav__link {
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
    position: relative;
    padding-block: 4px;
    text-decoration: none;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.25s ease;
  }
  .nav__link:hover { color: var(--text-primary); }
  .nav__link:hover::after,
  .nav__link.is-active::after { width: 100%; }
  .nav__link.is-active { color: var(--gold); }

  .nav__lang {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-subtle);
    padding: 6px 10px;
    border-radius: 3px;
    transition: color 0.2s ease;
    flex-shrink: 0;
    text-decoration: none;
  }
  .nav__lang:hover { color: var(--text-secondary); }

  .nav__cta {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(196, 154, 60, 0.35);
    padding: 10px 18px;
    min-height: 44px;
    border-radius: 3px;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }
  .nav__cta:hover { background: var(--gold-trans); border-color: var(--gold); }
  .nav__cta:focus-visible {
    outline: 3px solid var(--gold);
    outline-offset: 2px;
  }

  /* Mobile toggle */
  .nav__toggle {
    display: none;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-primary);
    align-items: center;
    justify-content: center;
    border-radius: 3px;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }
  .nav__toggle:hover { color: var(--gold); }
  .nav__toggle-icon { pointer-events: none; }

  /* Mobile drawer */
  .nav__drawer {
    display: none;
    position: fixed;
    top: 68px;
    left: 0;
    right: 0;
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-light);
    padding: 1.5rem var(--gutter);
    flex-direction: column;
    gap: 1rem;
    z-index: 99;
  }
  .nav__drawer.is-open { display: flex; }

  .nav__drawer-link {
    font-size: 15px;
    color: var(--text-secondary);
    padding-block: 8px;
    border-bottom: 1px solid var(--border-light);
    transition: color 0.2s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .nav__drawer-link:hover,
  .nav__drawer-link.is-active { color: var(--gold); }

  .nav__drawer-lang {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--text-subtle);
  }

  .nav__drawer-cta {
    margin-top: 0.5rem;
    text-align: center;
  }

  @media (max-width: 820px) {
    .nav__links { display: none; }
    .nav__lang   { display: none; }
    .nav__cta    { display: none; }
    .nav__toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.nav__toggle') as HTMLButtonElement | null;
  const drawer = document.getElementById('nav-drawer');
  if (toggle && drawer) {
    toggle.addEventListener('click', () => {
      const open = drawer.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
    });

    // Close drawer on outside click
    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target as Node) && !drawer.contains(e.target as Node)) {
        drawer.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
      }
    });

    // Close drawer on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) {
        drawer.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open navigation menu');
        toggle.focus();
      }
    });
  }
</script>
