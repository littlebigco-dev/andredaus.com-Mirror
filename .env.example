# PostHog analytics (EU endpoint, cookieless mode — no cookie consent banner needed)
PUBLIC_POSTHOG_KEY=phc_your_key_here

# Zoho OAuth credentials (server-side only — for contact form + booking API)
ZOHO_CLIENT_ID=1000.your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=1000.your_refresh_token_here

# Zoho Booking (public — safe to expose)
PUBLIC_ZOHO_BOOKING_SERVICE=187822000002657036
PUBLIC_ZOHO_BOOKING_WORKSPACE=187822000000034018
