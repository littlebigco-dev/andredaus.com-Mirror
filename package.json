{
  "name": "andredaus-com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/import-podcast.mjs && node scripts/generate-summaries.mjs && node scripts/og-images.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "podcast:summaries": "node --env-file=.env scripts/podcast-summaries.mjs",
    "podcast:artwork": "node scripts/podcast-artwork.mjs",
    "import:podcast": "node --env-file=.env scripts/import-podcast.mjs",
    "import:library": "node scripts/import-library.mjs",
    "import:insights": "node scripts/import-insights.mjs",
    "process:koala": "node scripts/process-koala-library.mjs",
    "process:koala:dry": "node scripts/process-koala-library.mjs --dry-run"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/work-sans": "^5.2.8",
    "@fontsource/dm-mono": "^5.2.7",
    "astro": "^6.1.5",
    "gray-matter": "^4.0.3",
    "posthog-js": "^1.365.5",
    "remark-directive": "^4.0.0",
    "wrangler": "^4.81.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.0",
    "typescript": "^5.9.3"
  }
}
